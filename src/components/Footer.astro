---
import {
  whoWeHelp,
  solutions,
  footerCompanyLinks,
  businessInfo,
  logoUrls,
} from '../data/navigation';

const year = new Date().getFullYear();
---

<footer class="relative border-t border-white/5 bg-[#0a0e12]">
  <div class="container-page py-16">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <a href="/" class="inline-block mb-5" aria-label="Killerspots Agency — Home">
          <img
            src={logoUrls.white}
            alt="Killerspots Agency"
            width="180"
            height="36"
            class="h-9 w-auto"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="text-sm text-muted max-w-sm">
          Full-service creative and digital marketing for brands that want to be impossible to ignore.
        </p>
        <address class="not-italic mt-6 space-y-1 text-sm text-ink">
          <div>{businessInfo.address.street}</div>
          <div>
            {businessInfo.address.city}, {businessInfo.address.region} {businessInfo.address.postal}
          </div>
          <div class="pt-2">
            <a href={`tel:${businessInfo.phoneTel}`} class="hover:text-white">
              {businessInfo.phone}
            </a>
          </div>
          <div>
            <a href={`mailto:${businessInfo.email}`} class="hover:text-white">
              {businessInfo.email}
            </a>
          </div>
        </address>
        <div class="mt-6 flex items-center gap-3">
          <a
            href={businessInfo.social.facebook}
            aria-label="Killerspots on Facebook"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-ink hover:border-brand-500 hover:text-white transition-colors"
            rel="noopener"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M13.5 21v-7.5h2.5l.4-3h-2.9V8.6c0-.9.3-1.5 1.5-1.5H16.5V4.4C16.2 4.4 15 4.3 13.7 4.3c-2.5 0-4.2 1.5-4.2 4.3V10.5H7v3h2.5V21h4z"
              />
            </svg>
          </a>
          <a
            href={businessInfo.social.linkedin}
            aria-label="Killerspots on LinkedIn"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-ink hover:border-brand-500 hover:text-white transition-colors"
            rel="noopener"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M4.98 3.5c0 1.4-1.1 2.5-2.5 2.5S0 4.9 0 3.5 1.1 1 2.5 1s2.48 1.1 2.48 2.5zM0 8h5v15H0V8zm7.5 0h4.78v2.05h.07c.66-1.25 2.28-2.55 4.7-2.55 5 0 5.95 3.3 5.95 7.6V23h-5v-7.4c0-1.77-.03-4.05-2.46-4.05-2.46 0-2.84 1.92-2.84 3.92V23h-5V8z"
              />
            </svg>
          </a>
          <a
            href={businessInfo.social.instagram}
            aria-label="Killerspots on Instagram"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-ink hover:border-brand-500 hover:text-white transition-colors"
            rel="noopener"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.3 1 .4 2.2.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1.2-.2 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .3-2.2.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2-.1-1.8-.2-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.3-1-.4-2.2-.1-1.2-.1-1.6-.1-4.8s0-3.6.1-4.8c.1-1.2.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.3 2.2-.4 1.2-.1 1.6-.1 4.8-.1zM12 0C8.7 0 8.3 0 7.1.1 5.8.1 5 .3 4.2.6 3.4.9 2.7 1.3 2 2c-.7.7-1.1 1.4-1.4 2.2-.3.8-.5 1.6-.6 2.9C0 8.3 0 8.7 0 12s0 3.7.1 4.9c.1 1.3.3 2.1.6 2.9.3.8.7 1.5 1.4 2.2.7.7 1.4 1.1 2.2 1.4.8.3 1.6.5 2.9.6 1.2.1 1.6.1 4.9.1s3.7 0 4.9-.1c1.3-.1 2.1-.3 2.9-.6.8-.3 1.5-.7 2.2-1.4.7-.7 1.1-1.4 1.4-2.2.3-.8.5-1.6.6-2.9.1-1.2.1-1.6.1-4.9s0-3.7-.1-4.9c-.1-1.3-.3-2.1-.6-2.9-.3-.8-.7-1.5-1.4-2.2-.7-.7-1.4-1.1-2.2-1.4-.8-.3-1.6-.5-2.9-.6C15.7 0 15.3 0 12 0zm0 5.8a6.2 6.2 0 1 0 0 12.4 6.2 6.2 0 0 0 0-12.4zm0 10.2a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-10.5a1.4 1.4 0 1 1-2.9 0 1.4 1.4 0 0 1 2.9 0z"
              />
            </svg>
          </a>
        </div>
      </div>

      <div class="lg:col-span-3">
        <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-500 mb-4">
          Who We Help
        </h4>
        <ul class="space-y-3 text-sm">
          {
            whoWeHelp.sections.map((s) => (
              <li>
                <a href={s.href} class="text-ink hover:text-white">
                  {s.heading}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="lg:col-span-3">
        <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-500 mb-4">
          Solutions
        </h4>
        <ul class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm lg:grid-cols-1">
          {
            solutions.sections.map((s) => (
              <li>
                <a href={s.href} class="text-ink hover:text-white">
                  {s.heading}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-500 mb-4">
          Company
        </h4>
        <ul class="space-y-3 text-sm">
          {
            footerCompanyLinks.map((l) => (
              <li>
                <a href={l.href} class="text-ink hover:text-white">
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="mt-12 pt-8 border-t border-white/5 flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-xs text-muted"
    >
      <div>© {year} {businessInfo.name}. All rights reserved.</div>
      <div class="flex items-center gap-5">
        <a href="/privacy" class="hover:text-white">Privacy</a>
        <a href="/terms" class="hover:text-white">Terms</a>
        <a href="/sitemap-index.xml" class="hover:text-white">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
