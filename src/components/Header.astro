---
import { megaMenus, simpleNavItems, businessInfo, logoUrls } from '../data/navigation';
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-white/5 bg-canvas/80 backdrop-blur-xl"
>
  <div class="container-page flex items-center justify-between gap-6 py-4">
    <a href="/" class="flex items-center shrink-0" aria-label="Killerspots Agency — Home">
      <img
        src={logoUrls.white}
        alt="Killerspots Agency"
        width="160"
        height="32"
        class="h-8 w-auto"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </a>

    <nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
      {
        megaMenus.map((menu) => (
          <button
            type="button"
            class="inline-flex items-center gap-1 rounded-full px-3 py-2 text-sm font-medium text-ink transition-colors hover:text-white"
            data-mega-trigger={menu.id}
            aria-expanded="false"
            aria-controls={`mega-${menu.id}`}
            aria-haspopup="true"
          >
            {menu.label}
            <svg
              class="chevron h-3.5 w-3.5 transition-transform"
              viewBox="0 0 12 12"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M3 4.5L6 7.5L9 4.5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </button>
        ))
      }
      {
        simpleNavItems.map((item) => (
          <a
            href={item.href}
            class="rounded-full px-3 py-2 text-sm font-medium text-ink transition-colors hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden lg:flex items-center gap-4 shrink-0">
      <a
        href={`tel:${businessInfo.phoneTel}`}
        class="text-sm font-medium text-ink hover:text-white"
      >
        {businessInfo.phone}
      </a>
      <a href="/contact" class="btn btn-primary">Get a Quote</a>
    </div>

    <button
      type="button"
      class="lg:hidden inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 text-white"
      data-mobile-toggle
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <svg
        data-icon-open
        class="h-5 w-5"
        viewBox="0 0 20 20"
        fill="none"
        aria-hidden="true"
      >
        <path d="M3 6h14M3 10h14M3 14h14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
      </svg>
      <svg
        data-icon-close
        class="hidden h-5 w-5"
        viewBox="0 0 20 20"
        fill="none"
        aria-hidden="true"
      >
        <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  {
    megaMenus.map((menu) => (
      <div
        id={`mega-${menu.id}`}
        data-mega-panel={menu.id}
        class="mega-panel hidden absolute left-0 right-0 top-full border-t border-white/5 bg-canvas/95 backdrop-blur-xl shadow-2xl"
        role="region"
        aria-label={menu.label}
      >
        <div class="container-page py-10">
          <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-8 gap-y-10">
            {menu.sections.map((section) => (
              <div class="min-w-0">
                <a
                  href={section.href}
                  class="block text-xs font-semibold uppercase tracking-[0.18em] text-brand-500 mb-4 hover:text-brand-300"
                >
                  {section.heading}
                </a>
                <ul class="space-y-2.5">
                  {section.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class="block text-sm text-ink transition-colors hover:text-white"
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    ))
  }

  <div
    id="mobile-nav"
    data-mobile-menu
    class="hidden lg:hidden border-t border-white/5 bg-canvas max-h-[calc(100dvh-72px)] overflow-y-auto"
  >
    <div class="container-page py-6 space-y-2">
      {
        megaMenus.map((menu) => (
          <details class="group rounded-xl border border-white/10 bg-white/[0.02]">
            <summary class="flex cursor-pointer items-center justify-between px-4 py-3 text-sm font-semibold text-white list-none [&::-webkit-details-marker]:hidden">
              {menu.label}
              <svg
                class="h-4 w-4 transition-transform group-open:rotate-180"
                viewBox="0 0 12 12"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M3 4.5L6 7.5L9 4.5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </summary>
            <div class="px-4 pb-4 pt-1 space-y-5">
              {menu.sections.map((section) => (
                <div>
                  <a
                    href={section.href}
                    class="block text-[11px] font-semibold uppercase tracking-[0.18em] text-brand-500 mb-2"
                  >
                    {section.heading}
                  </a>
                  <ul class="space-y-1">
                    {section.items.map((item) => (
                      <li>
                        <a
                          href={item.href}
                          class="block py-1.5 text-sm text-ink hover:text-white"
                        >
                          {item.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </details>
        ))
      }

      {
        simpleNavItems.map((item) => (
          <a
            href={item.href}
            class="block rounded-xl border border-white/10 bg-white/[0.02] px-4 py-3 text-sm font-semibold text-white"
          >
            {item.label}
          </a>
        ))
      }

      <div class="pt-3 grid gap-2">
        <a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">
          {businessInfo.phone}
        </a>
        <a href="/contact" class="btn btn-primary">Get a Quote</a>
      </div>
    </div>
  </div>
</header>

<script>
  const triggers = document.querySelectorAll<HTMLButtonElement>('[data-mega-trigger]');
  const panels = document.querySelectorAll<HTMLElement>('[data-mega-panel]');
  const header = document.getElementById('site-header');

  let active: string | null = null;

  function setActive(id: string | null) {
    active = id;
    panels.forEach((p) => {
      p.classList.toggle('hidden', p.dataset.megaPanel !== id);
    });
    triggers.forEach((t) => {
      t.setAttribute('aria-expanded', t.dataset.megaTrigger === id ? 'true' : 'false');
    });
  }

  triggers.forEach((t) => {
    t.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = t.dataset.megaTrigger ?? null;
      if (!id) return;
      setActive(active === id ? null : id);
    });
  });

  document.addEventListener('click', (e) => {
    if (!active || !header) return;
    if (!header.contains(e.target as Node)) setActive(null);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setActive(null);
  });

  // Mobile menu
  const mobileToggle = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
  const mobileMenu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const iconOpen = document.querySelector<HTMLElement>('[data-icon-open]');
  const iconClose = document.querySelector<HTMLElement>('[data-icon-close]');

  function setMobileOpen(open: boolean) {
    mobileMenu?.classList.toggle('hidden', !open);
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
    mobileToggle?.setAttribute('aria-expanded', open ? 'true' : 'false');
    mobileToggle?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    document.body.classList.toggle('menu-open', open);
  }

  mobileToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden');
    setMobileOpen(Boolean(isOpen));
  });

  // Close mobile menu on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) setMobileOpen(false);
  });

  // Sticky shrink shadow
  function onScroll() {
    if (!header) return;
    if (window.scrollY > 8) header.classList.add('is-scrolled');
    else header.classList.remove('is-scrolled');
  }
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
