---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'LinkedIn Ads Management | B2B Lead Generation | Killerspots',
  description: 'LinkedIn Ads management for B2B lead generation, account-based marketing, and professional services. Sponsored content, message ads, lead gen forms, and ABM campaigns.',
  ogTitle: 'LinkedIn Ads That Generate Real B2B Pipeline | Killerspots',
  ogDescription: 'B2B campaigns on LinkedIn — sponsored content, message ads, ABM, and lead gen forms. Built for high-value B2B sales cycles, not vanity clicks.',
};

const trustPills = ['B2B Specialists', 'ABM Capable', 'Pipeline-Driven Reporting'];

const what = [
  { title: 'Sponsored Content', body: 'Single image, video, document, and carousel ads in the LinkedIn feed. Targeted by job title, company, industry, and seniority.' },
  { title: 'Message Ads + Conversation Ads', body: 'Direct InMail-style ads that drop into prospect inboxes. Higher CTR than feed ads, better for high-value accounts.' },
  { title: 'Lead Gen Forms', body: 'In-platform forms pre-filled with LinkedIn profile data. High conversion, fast follow-up via LeadConnector integration.' },
  { title: 'Account-Based Marketing (ABM)', body: 'Target named accounts by company list. Run dedicated campaigns to specific decision-makers at specific employers.' },
  { title: 'Retargeting + Matched Audiences', body: 'Retarget website visitors, CRM contacts, and event attendees. Layer with LinkedIn\'s native targeting for high-precision reach.' },
  { title: 'Pipeline Attribution', body: 'Track LinkedIn impact through to closed-won revenue, not just MQLs. Connect campaign data to your CRM for full-funnel attribution.' },
];

const faqs = [
  { q: 'What\'s a realistic LinkedIn cost-per-lead?', a: 'B2B is expensive. Typical CPL: $80–$300+ depending on industry and target seniority. The math works because LinkedIn leads close at higher rates and bigger deal sizes than other channels.' },
  { q: 'Is LinkedIn worth it for small B2B?', a: 'For small B2B with ACV $5K+, yes. Below that, the math is hard because LinkedIn CPM and CPC are 5–10× other platforms. We\'ll be honest if your unit economics don\'t fit.' },
  { q: 'Can you do account-based marketing?', a: 'Yes — upload a target account list (1,000+ companies typical), build segmented campaigns per persona, and report by account-level engagement. Standard ABM toolkit.' },
  { q: 'Do you handle creative?', a: 'Yes — single image, video, carousel, document, and message-ad creative produced in-house. B2B creative needs different tone than B2C; we know the difference.' },
  { q: 'What\'s the minimum spend?', a: 'Typically $3K+/mo. LinkedIn ad costs are higher, so smaller budgets get drowned out. ABM campaigns work at smaller spends because they\'re hyper-targeted.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/ppc/linkedin-ads#webpage', url: 'https://killerspots.com/services/ppc/linkedin-ads', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'PPC', item: 'https://killerspots.com/services/ppc' }, { '@type': 'ListItem', position: 3, name: 'LinkedIn Ads', item: 'https://killerspots.com/services/ppc/linkedin-ads' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/ppc" class="hover:text-white">PPC</a><span class="mx-2">/</span><span class="text-ink">LinkedIn Ads</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">LinkedIn Ads</span>
        <h1 id="hero-headline" class="hero-headline mt-5">B2B campaigns built for <span class="text-brand-500">pipeline, not vanity clicks.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Sponsored content, message ads, lead gen forms, and account-based marketing on LinkedIn. For B2B service businesses, professional firms, and SaaS with $5K+ ACV.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a LinkedIn Ads Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">LinkedIn ads cost more, but B2B leads close at higher rates and bigger deal sizes. The math works for the right buyer.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Run</span><h2 class="section-headline mt-5">Six campaign types for B2B pipeline.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">LinkedIn Ads questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Build B2B Pipeline</span><h2 class="section-headline mt-5">Tell us your ICP. We'll build the campaign.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We\'ll review your target accounts, your buyer personas, and your unit economics — then come back with a LinkedIn strategy.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
