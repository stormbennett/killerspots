---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'PPC Management | Google Ads, LSA, Meta, LinkedIn | Killerspots',
  description: 'Paid search and paid social management built for cost-per-acquisition, not vanity clicks. Google Ads, LSA, Meta, LinkedIn, and YouTube — actively managed with weekly optimization.',
  ogTitle: 'PPC That Actually Closes Deals | Killerspots',
  ogDescription: 'Google Ads, LSA, Meta, LinkedIn, YouTube — managed for case-CPA, lead-CPL, or revenue ROAS. Active LSA dispute management. Real attribution.',
};

const trustPills = ['Active Account Management', 'LSA Dispute Specialists', 'CPA-Driven Reporting'];

const services = [
  { title: 'Google Ads & LSA', href: '/services/ppc/google-ads-lsa', body: 'Paid search + Local Service Ads with active dispute management. The fastest path to qualified phone calls and form fills.' },
  { title: 'Meta Ads', href: '/services/ppc/meta-ads', body: 'Facebook + Instagram campaigns sized for local-business budgets. Creative, targeting, retargeting, and weekly optimization.' },
  { title: 'LinkedIn Ads', href: '/services/ppc/linkedin-ads', body: 'B2B lead generation and brand-building for service businesses, professional firms, and B2B SaaS.' },
  { title: 'YouTube Ads', href: '/services/ppc/youtube-ads', body: 'Pre-roll, in-stream, and discovery ads with creative production included. Cheaper reach than CTV, more targeted than TV.' },
];

const why = [
  { title: 'Active Management, Not Set-and-Forget', body: 'Most agencies build campaigns and walk away. We optimize weekly — keywords, audiences, creative rotations, bid strategies. Compounding performance, not coast.' },
  { title: 'CPA-Driven, Not Click-Driven', body: 'We report by cost-per-acquisition (lead, call, signed case, paying customer) — not impressions, CTR, or quality scores. Vanity metrics shown, but never the headline.' },
  { title: 'Aggressive LSA Dispute Management', body: 'Wrong number, out of service area, junk leads — most agencies don\'t bother disputing. We do. Most LSA clients get 20–40% of spend back in disputed-lead credits.' },
  { title: 'Creative Production Included', body: 'Static ads, video ads, copy variants — produced in-house alongside campaign management. No "we don\'t do creative" gap with a separate vendor.' },
];

const faqs = [
  { q: 'What\'s a realistic CPA / CPL for my industry?', a: 'Wildly variable. Home services: $40–$150 CPL. Legal: $200–$2,000+ depending on practice area. B2B: $80–$500. We benchmark on the discovery call against your specific market.' },
  { q: 'How fast can I see results?', a: 'Search and LSA can drive leads in 1–2 weeks. Meta/LinkedIn campaigns typically need 30–60 days for the algorithm to optimize. We set expectations up front.' },
  { q: 'Do you handle creative production?', a: 'Yes — static ads, video ads, copy, and landing pages produced in-house alongside campaign management. No separate creative vendor needed.' },
  { q: 'What\'s the minimum ad spend you work with?', a: 'For Google Ads we typically work with $3K+/month in ad spend. LSA can start lower. Meta minimums similar. Below that, the management math doesn\'t work for either side.' },
  { q: 'Do you do reporting?', a: 'Weekly campaign-level snapshots, monthly strategy reports with CPA/ROAS by channel, quarterly executive reviews. Plain-English metrics, not vanity dashboards.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/ppc#webpage', url: 'https://killerspots.com/services/ppc', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'PPC', item: 'https://killerspots.com/services/ppc' }] };
const serviceSchema = { '@context': 'https://schema.org', '@type': 'Service', serviceType: 'PPC Management', provider: { '@id': 'https://killerspots.com/#localbusiness' }, areaServed: 'US', description: meta.description, url: 'https://killerspots.com/services/ppc' };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, serviceSchema, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-44 pb-20 md:pb-28">
      <div class="max-w-5xl">
        <span class="eyebrow">PPC &amp; Media Buying</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Paid media managed for <span class="text-brand-500">cost per acquisition.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Google Ads, LSA, Meta, LinkedIn, YouTube — actively managed by humans who optimize weekly. Aggressive LSA dispute management. Real CPA reporting.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a PPC Audit</a><a href="#services" class="btn btn-ghost">See Channels</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">25+ years buying media. We've run paid search through every algorithm change, every iOS privacy update, and every economic cycle.</p></div></div></section>

  <section id="services" class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">Channels We Run</span><h2 class="section-headline mt-5">Every paid channel that drives qualified leads.</h2></div><ul class="grid sm:grid-cols-2 gap-5 md:gap-6">{services.map((s) => (<li data-reveal><a href={s.href} class="card-tile group"><h3 class="text-lg md:text-xl font-semibold text-white">{s.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{s.body}</p><div class="mt-6 inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-brand-500 group-hover:text-brand-300">Explore<svg class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg></div></a></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">Why Killerspots</span><h2 class="section-headline mt-5">Built for the way real businesses buy media.</h2></div><ul class="grid md:grid-cols-2 gap-5 md:gap-6">{why.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"><h3 class="text-lg md:text-xl font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">PPC management questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-deep"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Get the CPA Down</span><h2 class="section-headline mt-5">Tell us your accounts. We'll audit and propose.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">Free PPC audit. We'll review your accounts, your CPA targets, and your current spend — then come back with what we'd change and what we'd run.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Free Audit</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
