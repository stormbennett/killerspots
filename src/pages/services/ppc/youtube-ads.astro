---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'YouTube Ads Management | Pre-Roll, In-Stream, Discovery | Killerspots',
  description: 'YouTube Ads management — pre-roll, in-stream, bumper, and discovery campaigns. Creative production included. Cheaper reach than CTV with intent-based targeting.',
  ogTitle: 'YouTube Ads — Premium Video at Fractional Cost | Killerspots',
  ogDescription: 'Pre-roll, in-stream, bumper, and discovery YouTube campaigns. Creative production included. Geo-targeted, intent-based, retargetable.',
};

const trustPills = ['YouTube Specialists', 'Creative Included', 'Intent-Based Targeting'];

const what = [
  { title: 'Pre-Roll + In-Stream', body: ':15, :30, and :60 video ads that play before/during YouTube content. Skippable and non-skippable formats. Built for awareness and conversion.' },
  { title: 'Bumper Ads', body: '6-second non-skippable bumpers — perfect for high-frequency reinforcement of jingles, taglines, and brand recall.' },
  { title: 'Discovery Ads', body: 'Native ads in YouTube search results and recommended-video sidebars. Pulls high-intent viewers searching for solutions you offer.' },
  { title: 'Audience Targeting', body: 'Demographic, interest, in-market segments, custom intent (people searching specific terms on Google), and remarketing layered on top of geo.' },
  { title: 'Creative Production', body: 'YouTube-spec video creative produced in our Cincinnati studio. Hook-driven, fast-cut, mobile-optimized — different from broadcast TV creative.' },
  { title: 'Conversion Tracking', body: 'View-through and click-through conversions tracked. Lift studies for larger campaigns. Real attribution to website visits and form fills.' },
];

const faqs = [
  { q: 'How is YouTube different from CTV?', a: 'YouTube ads run on the YouTube app/web. CTV ads run on actual TV-screen apps (Hulu, Roku, smart TVs) — premium environments where viewers can\'t skip. Different inventory, different intent. We do both.' },
  { q: 'What\'s a realistic CPV?', a: 'Cost-per-view on YouTube: $0.03–$0.20 typically. Bumpers run higher CPM but lower CPA because they\'re unskippable.' },
  { q: 'Do you produce the video creative?', a: 'Yes — :15, :30, and :60 spots produced in our studio. YouTube creative is faster-cut and hook-driven compared to broadcast TV. We adjust style for the platform.' },
  { q: 'Can I run my existing TV spot on YouTube?', a: 'Yes, but it usually underperforms YouTube-native creative. We can re-cut or re-edit existing TV spots for the YouTube format if budget is tight.' },
  { q: 'What\'s the minimum spend?', a: 'YouTube can work at $1.5K+/mo, especially for retargeting and bumper campaigns. Discovery and pre-roll typically need $3K+/mo to optimize properly.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/ppc/youtube-ads#webpage', url: 'https://killerspots.com/services/ppc/youtube-ads', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'PPC', item: 'https://killerspots.com/services/ppc' }, { '@type': 'ListItem', position: 3, name: 'YouTube Ads', item: 'https://killerspots.com/services/ppc/youtube-ads' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/ppc" class="hover:text-white">PPC</a><span class="mx-2">/</span><span class="text-ink">YouTube Ads</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">YouTube Ads</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Premium video reach <span class="text-brand-500">at fractional cost.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Pre-roll, in-stream, bumper, and discovery campaigns on YouTube. Creative production in our Cincinnati studio. Geo-targeted, intent-based, retargetable.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a YouTube Ads Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">YouTube delivers the cheapest premium video CPM in digital. We pair it with broadcast-quality creative produced in-house.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Run</span><h2 class="section-headline mt-5">Six YouTube ad formats — each with a job.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">YouTube Ads questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Run on YouTube</span><h2 class="section-headline mt-5">Tell us your audience. We'll cut the spots.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We\'ll review your audience, your creative, and your goals — then come back with a YouTube media plan.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
