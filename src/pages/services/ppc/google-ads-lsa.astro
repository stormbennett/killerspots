---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Google Ads & LSA Management | Active Dispute Management | Killerspots',
  description: 'Google Ads + Local Service Ads (LSA) management for service businesses. Active LSA dispute management gets 20–40% of bad-lead spend back. Real CPA reporting.',
  ogTitle: 'Google Ads & LSA That Drive Calls — Not Wasted Spend | Killerspots',
  ogDescription: 'Google Ads + LSA managed for cost-per-call, not impressions. Aggressive bad-lead disputes. Built for home services, legal, and local businesses.',
};

const trustPills = ['Google Ads + LSA', 'Active Dispute Management', 'CPA-Driven Reporting'];

const what = [
  { title: 'Google Search Ads', body: 'High-intent keyword targeting, ad group structure, smart bidding, negative keyword management. Built for cost-per-conversion, not impressions.' },
  { title: 'Local Service Ads (LSA)', body: 'LSA setup, category optimization, lead-bid management, and aggressive dispute filing. Most clients recover 20–40% of LSA spend in disputed-lead credits.' },
  { title: 'Google Ads for Lawyers (LSA-L)', body: 'Bar-compliant LSA campaigns for law firms. Practice-area targeting, intake routing, and dispute management on PI mass-tort lead spam.' },
  { title: 'Performance Max', body: 'Automated cross-channel campaigns when they fit — typically for ecommerce or multi-product service businesses. Closely monitored, not blind-trusted.' },
  { title: 'YouTube + Discovery', body: 'In-stream and discovery ads for prospecting and retargeting. Cheaper reach than CTV with intent layered on top.' },
  { title: 'Conversion Tracking + Attribution', body: 'Call tracking, form attribution, offline conversion imports from your CRM. We measure what closes, not what clicks.' },
];

const faqs = [
  { q: 'How aggressive is your LSA dispute management?', a: 'Every charged lead reviewed within 48 hours. Wrong number, out of service area, junk, non-relevant inquiry → we file the dispute. Most clients recover 20–40% of LSA spend in credits.' },
  { q: 'What\'s a realistic CPA?', a: 'Wildly variable. Home services LSA: $40–$150 per qualified call. Legal: $200–$2,000+ depending on practice. We benchmark on the discovery call.' },
  { q: 'Can you run Google Ads for Lawyers (LSA-L)?', a: 'Yes — LSA for Lawyers in eligible jurisdictions. Bar-compliant copy, intake routing, and aggressive dispute management on PI mass-tort lead spam.' },
  { q: 'How fast will I see calls?', a: 'LSA can drive calls within days of approval. Standard Google Ads: 1–2 weeks for the algorithm to optimize. Performance Max: 30 days minimum.' },
  { q: 'What\'s the minimum ad spend?', a: 'For Google Ads management we typically work with $3K+/mo in spend. LSA can start lower since management is simpler. Below those, the math doesn\'t work for either side.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/ppc/google-ads-lsa#webpage', url: 'https://killerspots.com/services/ppc/google-ads-lsa', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'PPC', item: 'https://killerspots.com/services/ppc' }, { '@type': 'ListItem', position: 3, name: 'Google Ads & LSA', item: 'https://killerspots.com/services/ppc/google-ads-lsa' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/ppc" class="hover:text-white">PPC</a><span class="mx-2">/</span><span class="text-ink">Google Ads &amp; LSA</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Google Ads + LSA</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Calls that close. <span class="text-brand-500">Disputes that get refunded.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Google Search Ads + Local Service Ads managed for cost-per-call, not impressions. Aggressive dispute management gets 20–40% of LSA spend back in bad-lead credits.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a PPC Audit</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">We've run paid search through every algorithm change, every iOS privacy update, and every PE-rolled vertical. We know how to spend ad budget that returns.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Run</span><h2 class="section-headline mt-5">Six campaign types, actively managed.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Google Ads + LSA questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Audit Your Accounts</span><h2 class="section-headline mt-5">Tell us your accounts. We'll find the leaks.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">Free PPC audit. We'll review your accounts, your CPA targets, and your dispute history — then come back with what we'd change.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Free Audit</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
