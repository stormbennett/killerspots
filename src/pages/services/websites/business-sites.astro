---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Business Website Design & Development | Killerspots',
  description: 'Multi-page business websites — services, locations, about, contact. Mobile-first, SEO-ready, integrated with LeadConnector and your analytics. WordPress, Astro, or custom builds.',
  ogTitle: 'Business Websites Built to Convert | Killerspots',
  ogDescription: 'Multi-page business sites. Mobile-first, fast, SEO-ready, conversion-tracked. WordPress, Astro, or custom builds.',
};

const trustPills = ['Mobile-First', 'SEO-Ready', 'CRM Integration'];

const what = [
  { title: 'Service Pages', body: 'Dedicated pages for every service you offer. Built around the keywords your customers search and the problems they have.' },
  { title: 'Location Pages', body: 'For multi-location businesses — dedicated pages per location with local SEO, embedded maps, and location-specific content.' },
  { title: 'About + Trust Pages', body: 'About, team, careers, history. The content that builds trust before a prospect calls.' },
  { title: 'Contact + Lead Forms', body: 'Contact page with multiple conversion paths (phone, form, chat). Forms integrated with LeadConnector. Click-to-call optimized for mobile.' },
  { title: 'Blog + Content Hub', body: 'WordPress-backed blog or Astro-managed content hub. SEO-optimized, designed for ongoing publishing.' },
  { title: 'Mobile + Performance', body: 'Mobile-first design, Lighthouse 95+ targets, lazy-loaded images, and CDN delivery. Fast on every device.' },
];

const faqs = [
  { q: 'WordPress, Astro, or custom?', a: 'WordPress for sites that need easy editing or specific plugins. Astro for marketing sites where speed is paramount. Custom for unique requirements. We pick based on what fits your team and content cadence.' },
  { q: 'How long does a business site take?', a: 'Standard 5–15 page business site: 4–8 weeks. Multi-location sites with 30+ pages: 8–16 weeks. Custom builds with complex integrations longer.' },
  { q: 'Do you handle hosting?', a: 'Yes — see our Hosting page. Cloudflare Pages, WP Engine, or your platform of choice. Most clients run on Cloudflare for performance.' },
  { q: 'Will the site rank in Google?', a: 'Technical SEO (site structure, schema, performance, internal linking) is baked into every build. Content SEO (keywords, copy depth, content production) is separate — see our SEO services for ongoing work.' },
  { q: 'Can I edit the site myself after launch?', a: 'Depends on the build. WordPress: yes, fully editable. Astro: limited editing without developer help. We\'ll size the right tech stack to your team\'s editing comfort.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/websites/business-sites#webpage', url: 'https://killerspots.com/services/websites/business-sites', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Websites', item: 'https://killerspots.com/services/websites' }, { '@type': 'ListItem', position: 3, name: 'Business Sites', item: 'https://killerspots.com/services/websites/business-sites' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/websites" class="hover:text-white">Websites</a><span class="mx-2">/</span><span class="text-ink">Business Sites</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Business Websites</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Multi-page business sites <span class="text-brand-500">built to convert.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Service pages, location pages, about, contact, and blog. Mobile-first, fast, SEO-ready, and integrated with LeadConnector. WordPress, Astro, or custom builds.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Website Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">A business site\'s job is to convert visitors into leads. Most don\'t. We engineer for that — fast, mobile-first, conversion-tracked.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Build</span><h2 class="section-headline mt-5">Six page types that work together.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Business website questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Build the Site Right</span><h2 class="section-headline mt-5">Tell us what you need. We'll size the build.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We\'ll review your existing site (if any), your goals, and your timeline — then come back with a build plan and quote.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
