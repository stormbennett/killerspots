---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Web Design & Management | Landing Pages, Business Sites, Hosting | Killerspots',
  description: 'Custom websites and landing pages built for conversion. Fast, mobile-first, SEO-ready. Hosting, ongoing maintenance, and integration with LeadConnector included.',
  ogTitle: 'Websites That Convert — Not Just Sit There | Killerspots',
  ogDescription: 'Landing pages, business sites, and hosting. Built fast, mobile-first, conversion-tracked, and integrated with your CRM. Real WordPress, Astro, or custom builds.',
};

const trustPills = ['Conversion-First', 'Fast Build, Faster Site', 'CRM Integration'];

const services = [
  { title: 'Landing Pages', href: '/services/websites/landing-pages', body: 'Campaign-specific landing pages built for paid ads, lead gen, or product launches. Built fast, A/B-tested, conversion-tracked.' },
  { title: 'Business Sites', href: '/services/websites/business-sites', body: 'Multi-page business websites — services, locations, about, contact. Mobile-first, SEO-ready, integrated with your CRM and analytics.' },
  { title: 'Hosting', href: '/services/websites/hosting', body: 'Managed hosting on Cloudflare, WP Engine, or your platform of choice. Performance, security, backups, and uptime monitoring.' },
];

const why = [
  { title: 'Built For Conversion, Not Just Pretty', body: 'Every site we build is engineered around the lead funnel — clear CTAs, working forms, fast load, and tracking baked in from day one. Pretty is a bonus; converting is the promise.' },
  { title: 'Mobile-First, Always', body: 'Most of your visitors are on a phone. We design and build mobile-first, then scale up to desktop. Your site works where your customers actually are.' },
  { title: 'Fast Out of the Box', body: 'Lighthouse 95+ scores on launch. Optimized images, lazy-loaded media, minimal JS, and CDN-delivered. Speed is a ranking factor and a conversion factor.' },
  { title: 'Integrated With LeadConnector', body: 'Forms flow into LeadConnector. Calls tracked. Chat connected to AI bot. Your website actually feeds your sales pipeline instead of being a brochure.' },
];

const faqs = [
  { q: 'WordPress, Astro, or custom?', a: 'All three. WordPress for sites that need easy editing or specific plugins. Astro for marketing sites where speed is paramount. Custom builds for unique requirements. We pick based on what fits, not what we always use.' },
  { q: 'How long does a website build take?', a: 'Landing pages: 1–2 weeks. Standard business sites: 4–8 weeks. Custom builds with complex integrations: 8–16 weeks. We size and quote on the discovery call.' },
  { q: 'Do you do ongoing maintenance?', a: 'Yes. Most clients run on a maintenance retainer that covers content updates, security patches, plugin/dependency updates, and performance monitoring. Predictable monthly cost.' },
  { q: 'Can you redesign my existing site?', a: 'Yes. We audit what you have, fix what\'s broken, and only recommend a full rebuild if it\'s genuinely holding you back. Sometimes the right answer is targeted improvements, not a teardown.' },
  { q: 'Do you handle SEO during the build?', a: 'Yes — technical SEO (site structure, schema, performance, internal linking) is baked into every build. Content SEO (keywords, copy, content depth) we handle separately if you want full SEO/AIO services.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/websites#webpage', url: 'https://killerspots.com/services/websites', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Websites', item: 'https://killerspots.com/services/websites' }] };
const serviceSchema = { '@context': 'https://schema.org', '@type': 'Service', serviceType: 'Web Design and Development', provider: { '@id': 'https://killerspots.com/#localbusiness' }, areaServed: 'US', description: meta.description, url: 'https://killerspots.com/services/websites' };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, serviceSchema, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-44 pb-20 md:pb-28">
      <div class="max-w-5xl">
        <span class="eyebrow">Web Design + Management</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Websites that <span class="text-brand-500">convert — not just exist.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Landing pages, business sites, and managed hosting. Mobile-first, fast out of the box, integrated with your CRM, and engineered around your lead funnel.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Website Quote</a><a href="#services" class="btn btn-ghost">See Services</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">A website is supposed to drive leads. Most don\'t. We build sites that do — fast, conversion-tracked, integrated with your CRM.</p></div></div></section>

  <section id="services" class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Build</span><h2 class="section-headline mt-5">Sites engineered around the funnel.</h2></div><ul class="grid md:grid-cols-3 gap-5 md:gap-6">{services.map((s) => (<li data-reveal><a href={s.href} class="card-tile group"><h3 class="text-lg md:text-xl font-semibold text-white">{s.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{s.body}</p><div class="mt-6 inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-brand-500 group-hover:text-brand-300">Explore<svg class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg></div></a></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">Why Killerspots</span><h2 class="section-headline mt-5">Built fast. Built for conversion. Integrated with your stack.</h2></div><ul class="grid md:grid-cols-2 gap-5 md:gap-6">{why.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"><h3 class="text-lg md:text-xl font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Web design + dev questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-deep"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Build the Site</span><h2 class="section-headline mt-5">Tell us what you need. We'll size the build.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We\'ll review your existing site (if any), your goals, and your timeline — then come back with a build plan and quote.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
