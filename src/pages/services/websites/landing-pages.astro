---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Landing Page Design & Development | Conversion-Focused | Killerspots',
  description: 'High-converting landing pages built for paid ads, lead gen campaigns, and product launches. Mobile-first, fast, A/B-tested, and integrated with LeadConnector.',
  ogTitle: 'Landing Pages That Actually Convert | Killerspots',
  ogDescription: 'Campaign landing pages built fast, optimized hard. Mobile-first, conversion-tracked, and integrated with your CRM. Launch in 1–2 weeks.',
};

const trustPills = ['Conversion-First', 'Mobile-First', 'CRM Integration'];

const what = [
  { title: 'Paid Ad Landing Pages', body: 'Dedicated landing pages for Google Ads, Meta, LinkedIn, and CTV campaigns. Built to match ad creative and convert the click into a lead.' },
  { title: 'Lead Gen Funnels', body: 'Multi-step funnels with progressive profiling, qualification questions, and conditional logic. Built for high-ticket service sales cycles.' },
  { title: 'Product Launch Pages', body: 'Single-purpose pages for product launches, webinars, free reports, and time-sensitive offers. Built fast, replaced after the campaign.' },
  { title: 'Industry Landing Pages', body: 'Variants by industry, location, or service area for ad targeting. Same offer, different angles — generated efficiently.' },
  { title: 'A/B Testing', body: 'We test headlines, hero treatments, CTAs, and page structure to drive conversion improvement over time. Statistical significance, not gut feel.' },
  { title: 'CRM + Tracking', body: 'Forms flow into LeadConnector. Conversions tracked in Google Ads, Meta, and your analytics. Calls tracked. Every click attributed.' },
];

const faqs = [
  { q: 'How fast can you build a landing page?', a: 'Standard landing page: 1–2 weeks from kickoff to live. Includes design, build, mobile optimization, and tracking. Rush turnarounds available for time-sensitive campaigns.' },
  { q: 'What conversion rate should I expect?', a: 'Wildly variable by industry, traffic source, and offer. Service-business landing pages typically run 3–10% conversion rate when traffic is qualified. We optimize over time.' },
  { q: 'Do you do A/B testing?', a: 'Yes — for accounts with enough traffic to reach statistical significance (~5K+ visits/month). For lower-traffic accounts, we focus on best-practice optimization rather than testing.' },
  { q: 'WordPress or custom?', a: 'Whatever fits. Standard landing pages: Astro for speed. Easy-to-edit pages: WordPress. Complex multi-step funnels: custom build. We pick based on what works for your team.' },
  { q: 'Will the form integrate with my CRM?', a: 'Yes. Native LeadConnector integration is best, but we also integrate with HubSpot, Salesforce, and others via webhooks. Form data flows directly into your sales pipeline.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/websites/landing-pages#webpage', url: 'https://killerspots.com/services/websites/landing-pages', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Websites', item: 'https://killerspots.com/services/websites' }, { '@type': 'ListItem', position: 3, name: 'Landing Pages', item: 'https://killerspots.com/services/websites/landing-pages' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/websites" class="hover:text-white">Websites</a><span class="mx-2">/</span><span class="text-ink">Landing Pages</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Landing Pages</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Pages built to <span class="text-brand-500">convert clicks into leads.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Campaign-specific landing pages for paid ads, lead gen, and product launches. Mobile-first, fast, A/B-testable, and integrated with LeadConnector. Launch in 1–2 weeks.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Landing Page Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">Most landing pages we replace have load times over 4 seconds and conversion rates under 2%. We routinely double both.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Build</span><h2 class="section-headline mt-5">Six page types — each engineered for a specific use case.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Landing page questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Build the Page</span><h2 class="section-headline mt-5">Tell us the campaign. We'll build the page.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We\'ll review your campaign, your offer, and your traffic source — then come back with a wireframe and quote.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
