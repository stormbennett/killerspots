---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'AI Content & Marketing Automation | Lead Scoring + Workflows | Killerspots',
  description: 'AI-accelerated content production, marketing automation, lead scoring, and workflow triggers. Practical AI deployed alongside LeadConnector to compound human work.',
  ogTitle: 'AI Content + Marketing Automation | Killerspots',
  ogDescription: 'AI-accelerated content production + marketing automation + AI lead scoring. Built on LeadConnector. Compounds human work, doesn\'t replace it.',
};

const trustPills = ['Practical AI', 'LeadConnector Native', 'Human-Reviewed Output'];

const what = [
  { title: 'AI-Accelerated Content', body: 'AI tools speed research, outlining, and first drafts. Every piece is human-edited and reviewed for accuracy. Authentic content at production speed.' },
  { title: 'AI Lead Scoring', body: 'LeadConnector\'s AI scores incoming leads by intent, source, and behavior. High-intent leads fast-tracked to humans; low-intent goes into nurture.' },
  { title: 'Workflow Automation', body: 'Triggers based on form fills, page views, email opens, pipeline stages. Auto-tag, auto-route, auto-follow-up. The grunt work that compounds.' },
  { title: 'Email + SMS Automation', body: 'Drip sequences, behavioral triggers, and broadcast campaigns automated end-to-end. Reactivation, nurture, and post-purchase flows.' },
  { title: 'Personalization at Scale', body: 'Dynamic content, personalized email subject lines, and segment-specific landing pages. AI-generated, human-approved.' },
  { title: 'Integration + Pipeline', body: 'Connect LeadConnector to Zapier, Make, n8n, and direct API integrations. AI workflows that actually move data between tools that matter.' },
];

const faqs = [
  { q: 'Do you write content with AI?', a: 'AI accelerates research and outlining. Every piece is human-edited, fact-checked, and reviewed for brand voice. Google\'s helpful-content updates penalize raw AI content. We don\'t do that.' },
  { q: 'How does AI lead scoring work?', a: 'LeadConnector\'s built-in AI looks at intent signals (page views, time on site, form depth, source quality) and assigns a score. High-score leads alert your team in real time; low-score goes to nurture.' },
  { q: 'Can you integrate with our existing tools?', a: 'Yes — Zapier, Make, n8n, and direct API integrations to most major SaaS tools. We can connect LeadConnector to your accounting, calendar, support, or analytics stack.' },
  { q: 'What\'s the simplest automation that drives ROI?', a: 'Missed-call text-back. Phone rings, no one answers, AI texts the prospect within 30 seconds. Most clients see 4–10× ROI on this single automation alone.' },
  { q: 'How is this priced?', a: 'Setup fee + monthly retainer. Sized to scope — single-workflow projects vs. full content + automation programs have different pricing.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/ai-services/ai-content-automation#webpage', url: 'https://killerspots.com/services/ai-services/ai-content-automation', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'AI Services', item: 'https://killerspots.com/services/ai-services' }, { '@type': 'ListItem', position: 3, name: 'AI Content & Automation', item: 'https://killerspots.com/services/ai-services/ai-content-automation' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/ai-services" class="hover:text-white">AI Services</a><span class="mx-2">/</span><span class="text-ink">AI Content &amp; Automation</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">AI Content &amp; Automation</span>
        <h1 id="hero-headline" class="hero-headline mt-5">AI that compounds <span class="text-brand-500">your team\'s output.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">AI-accelerated content production, lead scoring, marketing automation, and workflow triggers. Deployed alongside LeadConnector. Human-edited, brand-aligned, ROI-tracked.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get an AI Automation Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">AI accelerates work humans then review and approve. We use it where it earns ROI — not as a replacement for craft.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Deploy</span><h2 class="section-headline mt-5">Six AI + automation layers.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">AI content + automation questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Compound Your Output</span><h2 class="section-headline mt-5">Tell us your bottlenecks. We'll deploy the AI fit.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We\'ll map where AI compounds your team\'s work and where it doesn\'t — then deploy what earns ROI.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href="/leadconnector" class="btn btn-ghost">Learn LeadConnector</a></div></div></div></section>
</BaseLayout>
