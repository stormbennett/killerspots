---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Auto-Attendant + IVR Recordings | Phone Prompts | Killerspots',
  description:
    'Professional auto-attendant, IVR menu, and voicemail prompts for your business phone system. Custom-scripted, voiced by real talent, delivered in formats that drop into any VoIP or PBX.',
  ogTitle: 'Auto-Attendant + IVR Recordings | Killerspots',
  ogDescription:
    'IVR menu prompts, voicemail greetings, directory announcements, and after-hours messages — produced and delivered phone-system-ready.',
};

const trustPills = ['VoIP + PBX Ready', 'Real Voice Talent', '2–3 Day Turnaround'];

const types = [
  {
    title: 'Main Greeting',
    body:
      'The first thing every caller hears. Branded, friendly, and professional — sets the tone for the whole interaction.',
  },
  {
    title: 'IVR Menu Prompts',
    body:
      'Press 1 for sales. Press 2 for support. Custom-recorded prompts for every menu, sub-menu, and routing path your phone tree needs.',
  },
  {
    title: 'Department Greetings',
    body:
      'Sales, support, billing, accounts — distinct greetings for each department or extension queue, recorded by the same brand voice for consistency.',
  },
  {
    title: 'Voicemail Greetings',
    body:
      'General voicemail, individual user voicemail, and after-hours mailbox greetings. Drop-in files for every extension that needs one.',
  },
  {
    title: 'After-Hours & Holiday',
    body:
      'Holiday closings, special hours, weather closures, and emergency-only routing. Pre-record once, swap in when needed.',
  },
  {
    title: 'On-Transfer & Hold',
    body:
      'Quick "transferring you now" and "thank you for holding" interstitials between menus, queues, and departments. Pairs well with on-hold messaging.',
  },
];

const fits = [
  'VoIP systems (RingCentral, Nextiva, Vonage, GoHighLevel)',
  'On-prem PBX (Avaya, Cisco, Mitel, NEC)',
  'Cloud contact centers (Five9, Genesys, Talkdesk)',
  'GoHighLevel + LeadConnector phone trees',
  'Dental and medical practice systems',
  'Multi-location franchise call routing',
];

const faqs = [
  {
    q: 'What\'s the difference between auto-attendant and IVR?',
    a: 'Auto-attendant is the simpler version: "Press 1 for sales, press 2 for support, press 0 for an operator." IVR (Interactive Voice Response) is more complex — multi-level menus, sub-menus, routing logic, and sometimes voice recognition. We produce recordings for both.',
  },
  {
    q: 'How do we deploy these recordings on our phone system?',
    a: 'We deliver in whatever format your system expects — WAV, MP3, GSM, μ-law, or system-specific formats. Most VoIP and PBX systems just need you to upload the file. Tell us your phone system on the brief and we\'ll match the spec.',
  },
  {
    q: 'Do you write the menu prompts?',
    a: 'Yes. Scripting is included. We\'ll ask about your departments, hours, common transfers, and any policies or compliance language you need. Then we write prompts that are clear, short, and easy to follow — no caller-confusion mazes.',
  },
  {
    q: 'Can you record in multiple languages?',
    a: 'Yes. Spanish-language menus and bilingual systems are common. We can also produce in other languages — French, Portuguese, Mandarin, and others — using native-speaking voice talent from VoiceTalent.Agency.',
  },
  {
    q: 'How many prompts do most businesses need?',
    a: 'A simple auto-attendant: 5–10 prompts (greeting, main menu, department transfers, voicemail, after-hours). Complex IVR: 30+. We\'ll map it on the discovery call and quote a flat package or per-prompt rate based on volume.',
  },
  {
    q: 'How fast is turnaround?',
    a: '2–3 business days from script approval through final mix. Larger IVR projects (30+ prompts) typically take 5–7 days for full production with multiple voice talents.',
  },
];

const speakable = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://killerspots.com/services/audio-production/auto-attendant#webpage',
  url: 'https://killerspots.com/services/audio-production/auto-attendant',
  name: meta.title,
  description: meta.description,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#hero-headline', '#hero-subhead'],
  },
  isPartOf: { '@id': 'https://killerspots.com/#localbusiness' },
};

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Audio Production',
      item: 'https://killerspots.com/services/audio-production',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Auto-Attendant',
      item: 'https://killerspots.com/services/audio-production/auto-attendant',
    },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Auto-Attendant and IVR Voice Recording',
  provider: { '@id': 'https://killerspots.com/#localbusiness' },
  areaServed: 'US',
  description: meta.description,
  url: 'https://killerspots.com/services/audio-production/auto-attendant',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  schema={[speakable, breadcrumbs, serviceSchema, faqSchema]}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-canvas">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"
      >
      </div>
    </div>

    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]">
        <a href="/services/audio-production" class="hover:text-white">Audio Production</a>
        <span class="mx-2">/</span>
        <span class="text-ink">Auto-Attendant &amp; IVR</span>
      </nav>

      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Auto-Attendant &amp; IVR</span>
        <h1 id="hero-headline" class="hero-headline mt-5">
          Phone prompts that actually sound
          <span class="text-brand-500">like your brand.</span>
        </h1>
        <p
          id="hero-subhead"
          class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug"
        >
          Custom-scripted auto-attendant menus, IVR routing prompts, voicemail greetings,
          and after-hours messages — voiced by real humans, mixed to broadcast spec, and
          delivered in formats that drop into any VoIP or PBX.
        </p>

        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3">
          <a href="/contact" class="btn btn-primary">Get a Quote</a>
          <a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">
            Call {businessInfo.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST -->
  <section class="bg-deep">
    <div class="container-page py-12 md:py-16">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="flex flex-wrap items-center gap-2.5">
          {trustPills.map((p) => <span class="trust-pill">{p}</span>)}
        </div>
        <p class="text-base md:text-lg text-muted leading-relaxed">
          Phone prompts shouldn't sound like the 2003 stock library. We produce
          professional, branded voice recordings that match the rest of your audio
          identity — same voices that do your radio spots and on-hold.
        </p>
      </div>
    </div>
  </section>

  <!-- TYPES -->
  <section class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">What We Record</span>
        <h2 class="section-headline mt-5">Every prompt your phone tree needs.</h2>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {
          types.map((t) => (
            <li
              data-reveal
              class="rounded-2xl border border-white/5 bg-deep/60 p-7"
            >
              <h3 class="text-lg font-semibold text-white">{t.title}</h3>
              <p class="mt-3 text-sm text-muted leading-relaxed">{t.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- COMPATIBILITY -->
  <section class="bg-deep">
    <div class="container-page py-20 md:py-28">
      <div class="mb-10 md:mb-14 max-w-3xl" data-reveal>
        <span class="eyebrow">System Compatibility</span>
        <h2 class="section-headline mt-5">Works with whatever you already run.</h2>
        <p class="mt-6 text-lg md:text-xl text-ink leading-relaxed max-w-2xl">
          We deliver phone-system-ready files in the exact format your system needs. Tell
          us what you run; we match the spec.
        </p>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3" data-reveal>
        {
          fits.map((f) => (
            <li class="rounded-xl border border-white/10 bg-surface px-5 py-4 text-sm md:text-base text-ink">
              {f}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 max-w-3xl" data-reveal>
        <span class="eyebrow">FAQ</span>
        <h2 class="section-headline mt-5">Auto-attendant + IVR questions.</h2>
      </div>

      <div class="max-w-3xl space-y-3" data-reveal>
        {
          faqs.map((f) => (
            <details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5">
              <summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4">
                <span>{f.q}</span>
                <svg
                  class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M10 4v12M4 10h12"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                  />
                </svg>
              </summary>
              <p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden bg-deep">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div
        class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"
      >
      </div>
    </div>

    <div class="container-page py-24 md:py-32">
      <div class="max-w-3xl" data-reveal>
        <span class="eyebrow">Sound Like a Real Brand</span>
        <h2 class="section-headline mt-5">Tell us your phone tree. We'll voice it.</h2>
        <p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">
          Send us a list of prompts (or a draft of your menu structure). We'll come back
          with a script and a quote — and have files ready to deploy in 2–3 days.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary">Get a Quote</a>
          <a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">
            Call {businessInfo.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
