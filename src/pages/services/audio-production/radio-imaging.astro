---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Radio Imaging | Station IDs, Sweepers & Imaging Packages | Killerspots',
  description:
    'Custom radio imaging packages for stations and broadcast groups. Station IDs, sweepers, jingles, promos, and beds — produced by a 6× Telly Award-winning audio team.',
  ogTitle: 'Award-Winning Radio Imaging | Killerspots',
  ogDescription:
    'Station IDs, sweepers, drops, and full imaging packages built around your format. White-label production for single stations and broadcast groups.',
};

const trustPills = ['Built For Broadcasters', '6× Telly Award Winner', 'Volume Retainers Available'];

const elements = [
  {
    title: 'Station IDs',
    body:
      'The voice of your station. Custom-produced legal IDs, branded IDs, and slogan tags that anchor every break and stop the dial when listeners scan past.',
  },
  {
    title: 'Sweepers & Stingers',
    body:
      'Short transitional drops between songs, between segments, between commercial breaks. Custom-built around your format\'s tempo and tonality.',
  },
  {
    title: 'Promos & Liners',
    body:
      'Show promos, contest promos, and sales liners. Production-ready promotional content for everything you need listeners to hear.',
  },
  {
    title: 'Format Jingles',
    body:
      'Format-specific jingles — country, classic rock, AC, urban, sports, news/talk. Vocal stings and full sung pieces.',
  },
  {
    title: 'Music Beds',
    body:
      'Original music beds in your format\'s aesthetic. Talkable, brand-able, and easy to drop under any voice work.',
  },
  {
    title: 'Holiday & Seasonal',
    body:
      'Holiday imaging packages, summer/winter rotations, and event-specific drops. Refreshed quarterly on volume retainers.',
  },
];

const formats = [
  'Country',
  'Classic Rock',
  'Hot AC / Adult Hits',
  'Urban / Hip-Hop',
  'Sports / News / Talk',
  'Christian / Inspiration',
  'Top 40 / CHR',
  'Spanish-Language',
];

const partnership = [
  {
    title: 'White-Label Production',
    body:
      'Full imaging delivered as your station\'s in-house team. Reports and portals branded as you. Killerspots is invisible to your listeners and your advertisers.',
  },
  {
    title: 'Single Station or Group',
    body:
      'From a single signal to multi-station broadcasting groups. Group-wide imaging packages bring consistency across the cluster while letting each station keep its identity.',
  },
  {
    title: 'Volume Retainers',
    body:
      'Monthly retainer covering a defined imaging output — sweepers, IDs, promos, and seasonal refreshes. Predictable budget, consistent voice, no per-project fees.',
  },
  {
    title: 'Same Voice, Year After Year',
    body:
      'Lock in voice talent through VoiceTalent.Agency so your station sounds the same in 2026 as it does in 2030. Continuity is the whole point of imaging.',
  },
];

const faqs = [
  {
    q: 'What\'s in a typical imaging package?',
    a: 'A typical package includes 8–15 sweepers, 3–5 station IDs (legal + branded + slogan), seasonal/holiday rotation, and 5–10 format-specific jingles or beds. We size every package to the station\'s format, hours, and budget.',
  },
  {
    q: 'Do you do single-station or group imaging?',
    a: 'Both. We produce for single-market stations all the way up to broadcasting groups with 50+ signals. Group packages can be unified (same voice across cluster) or differentiated (each station keeps its own identity).',
  },
  {
    q: 'How long does a package take?',
    a: 'A standard imaging package: 2–3 weeks from kickoff to final delivery. Volume retainers ship faster on quarterly refreshes. Rush production available for format flips and station launches.',
  },
  {
    q: 'Do you offer volume retainers?',
    a: 'Yes — monthly retainers cover a defined production volume across IDs, sweepers, promos, and seasonal refreshes. Most station-group partners run on retainers because it\'s predictable budget and consistent voice across the year.',
  },
  {
    q: 'Can we keep the same voice talent year after year?',
    a: 'Absolutely — and we recommend it. Imaging works because of continuity. Lock in your station voice through VoiceTalent.Agency and we\'ll keep producing in their voice for as long as you want.',
  },
  {
    q: 'Is this part of the white-label radio station partnership?',
    a: 'Yes. Imaging is one of the three pillars of our station partnership program (alongside white-label commercial production and digital revenue solutions). See the Radio Stations & Groups page for the full partnership model.',
  },
];

const speakable = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://killerspots.com/services/audio-production/radio-imaging#webpage',
  url: 'https://killerspots.com/services/audio-production/radio-imaging',
  name: meta.title,
  description: meta.description,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#hero-headline', '#hero-subhead'],
  },
  isPartOf: { '@id': 'https://killerspots.com/#localbusiness' },
};

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Audio Production',
      item: 'https://killerspots.com/services/audio-production',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Radio Imaging',
      item: 'https://killerspots.com/services/audio-production/radio-imaging',
    },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Radio Imaging Production',
  provider: { '@id': 'https://killerspots.com/#localbusiness' },
  areaServed: 'US',
  description: meta.description,
  url: 'https://killerspots.com/services/audio-production/radio-imaging',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const IMAGING_PLAYLIST =
  'https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/playlists/soundcloud%253Aplaylists%253A878642998%3Fsecret_token%3Ds-nTUag&color=%23ef5253&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false&visual=true';
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  schema={[speakable, breadcrumbs, serviceSchema, faqSchema]}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-canvas">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"
      >
      </div>
    </div>

    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]">
        <a href="/services/audio-production" class="hover:text-white">Audio Production</a>
        <span class="mx-2">/</span>
        <span class="text-ink">Radio Imaging</span>
      </nav>

      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Radio Imaging</span>
        <h1 id="hero-headline" class="hero-headline mt-5">
          The voice of your station —
          <span class="text-brand-500">consistent across every break.</span>
        </h1>
        <p
          id="hero-subhead"
          class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug"
        >
          Custom imaging packages for radio stations and broadcasting groups. Station IDs,
          sweepers, jingles, promos, and beds — built around your format and produced by a
          6× Telly Award-winning audio team.
        </p>

        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3">
          <a href="/contact" class="btn btn-primary">Get an Imaging Quote</a>
          <a href="#listen" class="btn btn-ghost">
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M5 3.5v9l7-4.5z" />
            </svg>
            Listen to Samples
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST -->
  <section class="bg-deep">
    <div class="container-page py-12 md:py-16">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="flex flex-wrap items-center gap-2.5">
          {trustPills.map((p) => <span class="trust-pill">{p}</span>)}
        </div>
        <p class="text-base md:text-lg text-muted leading-relaxed">
          Imaging for stations and broadcast groups across the U.S. Our work powers the
          sound of station partners like Ozark Dynacom and Horizon Broadcasting Group.
        </p>
      </div>
    </div>
  </section>

  <!-- ELEMENTS -->
  <section class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">Imaging Elements</span>
        <h2 class="section-headline mt-5">Everything in your station's audio package.</h2>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {
          elements.map((e) => (
            <li
              data-reveal
              class="rounded-2xl border border-white/10 bg-surface p-7"
            >
              <h3 class="text-lg font-semibold text-white">{e.title}</h3>
              <p class="mt-3 text-sm text-muted leading-relaxed">{e.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- FORMATS -->
  <section class="bg-deep">
    <div class="container-page py-20 md:py-28">
      <div class="mb-10 md:mb-14 max-w-3xl" data-reveal>
        <span class="eyebrow">Formats We Produce</span>
        <h2 class="section-headline mt-5">Every format. Tuned to your station.</h2>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3" data-reveal>
        {
          formats.map((f) => (
            <li class="rounded-xl border border-white/10 bg-canvas px-5 py-4 text-sm md:text-base text-ink text-center">
              {f}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- LISTEN -->
  <section id="listen" class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-10 max-w-3xl" data-reveal>
        <span class="eyebrow">Listen</span>
        <h2 class="section-headline mt-5">Sample imaging from our portfolio.</h2>
      </div>

      <div data-reveal class="rounded-2xl overflow-hidden border border-white/10">
        <iframe
          width="100%"
          height="450"
          allow="autoplay"
          src={IMAGING_PLAYLIST}
          title="Killerspots Radio Imaging — SoundCloud playlist"
          loading="lazy"
          style="display:block;border:0;background:#0a0e12;"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- PARTNERSHIP MODEL -->
  <section class="bg-deep">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">Partnership Model</span>
        <h2 class="section-headline mt-5">
          Built for stations and groups, not one-off projects.
        </h2>
      </div>

      <ul class="grid md:grid-cols-2 gap-5 md:gap-6">
        {
          partnership.map((p) => (
            <li
              data-reveal
              class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"
            >
              <h3 class="text-lg md:text-xl font-semibold text-white">{p.title}</h3>
              <p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{p.body}</p>
            </li>
          ))
        }
      </ul>

      <div class="mt-10 md:mt-14" data-reveal>
        <a href="/industries/radio-stations-groups" class="btn btn-ghost">
          See the Full Station Partnership →
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 max-w-3xl" data-reveal>
        <span class="eyebrow">FAQ</span>
        <h2 class="section-headline mt-5">Radio imaging questions.</h2>
      </div>

      <div class="max-w-3xl space-y-3" data-reveal>
        {
          faqs.map((f) => (
            <details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5">
              <summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4">
                <span>{f.q}</span>
                <svg
                  class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M10 4v12M4 10h12"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                  />
                </svg>
              </summary>
              <p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden bg-deep">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div
        class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"
      >
      </div>
    </div>

    <div class="container-page py-24 md:py-32">
      <div class="max-w-3xl" data-reveal>
        <span class="eyebrow">Build Your Station Sound</span>
        <h2 class="section-headline mt-5">
          Tell us your format. We'll build the imaging.
        </h2>
        <p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">
          Send us your format, your call letters, and any reference imaging you love. We'll
          come back with a production plan, a voice talent recommendation, and a quote
          sized for your station or group.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary">Get a Quote</a>
          <a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">
            Call {businessInfo.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
