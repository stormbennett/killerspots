---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'On-Hold Messaging | Custom Hold Messages for Business | Killerspots',
  description:
    'Professional on-hold messaging that turns hold time into marketing time. Custom-written, voiced by real talent, mixed to broadcast spec. 25+ years of audio production.',
  ogTitle: 'On-Hold Messages That Don\'t Make Callers Hang Up | Killerspots',
  ogDescription:
    'Custom on-hold messaging — scripted, voiced, and mixed by Killerspots. Turn dead air into a brand asset. Most projects ship in 2–3 days.',
};

const trustPills = ['2–3 Day Turnaround', 'Real Voice Talent', 'Phone-System Ready'];

const why = [
  {
    title: 'Hold Time Is Marketing Time',
    body:
      'Callers spend an average of 40+ seconds on hold per call. That\'s your most captive audience. Most businesses leave it as silence or generic muzak — we turn it into branded messaging that sells.',
  },
  {
    title: 'Reduce Hang-Ups, Increase Bookings',
    body:
      'Branded on-hold messaging measurably reduces hang-up rates and improves call satisfaction. Callers who hear something useful are more patient — and more likely to convert.',
  },
  {
    title: 'Reinforce Specials & FAQ',
    body:
      'Drop in current promos, hours, locations, and answers to your top FAQ. The same questions your team answers all day, baked into the wait — so they don\'t have to.',
  },
];

const included = [
  {
    title: 'Custom Scripting',
    body:
      'Original copy written for your business — your voice, your offers, your service area. Built to be heard while a customer is doing something else.',
  },
  {
    title: 'Real Voice Talent',
    body:
      'Cast from VoiceTalent.Agency. Every artist signs an anti-AI pledge. Pick the voice that fits your brand and audition demos before recording.',
  },
  {
    title: 'Background Music Bed',
    body:
      'Original or licensed music beds matched to your brand. Subtle enough to talk over, branded enough to feel like yours.',
  },
  {
    title: 'Multiple Variants',
    body:
      'Standard message, holiday version, after-hours version, Spanish-language version — whatever your call center needs to rotate through the year.',
  },
  {
    title: 'Phone-System Ready Files',
    body:
      'Delivered in the exact format your VoIP, PBX, or auto-attendant expects (WAV, MP3, GSM, μ-law, etc.). Drop in and play.',
  },
  {
    title: 'Quarterly or Seasonal Refresh',
    body:
      'Volume retainers refresh your messaging every quarter so callers don\'t hear the same script all year. Keeps it current without you thinking about it.',
  },
];

const faqs = [
  {
    q: 'How long should an on-hold message be?',
    a: 'Most businesses run 2–4 minute loops with 4–8 distinct segments. The key is variety — different topics, different read tones — so callers don\'t hear the same message twice while they\'re waiting.',
  },
  {
    q: 'How often should we update it?',
    a: 'Refresh quarterly at minimum so seasonal offers and hours stay current. Volume retainers handle this automatically. One-off messages: refresh whenever your specials or service offerings change.',
  },
  {
    q: 'Will it work with our phone system?',
    a: 'Yes. We deliver in whatever format your VoIP, PBX, IP phone, or auto-attendant expects — WAV, MP3, GSM, μ-law, or specific formats for systems like Avaya, Cisco, Nextiva, RingCentral, GoHighLevel, and others. Tell us your system on the brief.',
  },
  {
    q: 'Can you write the script?',
    a: 'Yes. Scripting is included on every package. We\'ll ask about your specials, hours, FAQs, and brand voice — then write a script designed to be heard while the caller waits.',
  },
  {
    q: 'Do you do bilingual or Spanish-only versions?',
    a: 'Yes. Spanish-language and bilingual on-hold messaging is common. We can do separate language tracks for callers who select language at your IVR menu.',
  },
  {
    q: 'How fast is turnaround?',
    a: '2–3 business days from script approval through final mix. Volume retainers ship faster on quarterly refreshes since the script template is already in place.',
  },
];

const speakable = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://killerspots.com/services/audio-production/on-hold-messaging#webpage',
  url: 'https://killerspots.com/services/audio-production/on-hold-messaging',
  name: meta.title,
  description: meta.description,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#hero-headline', '#hero-subhead'],
  },
  isPartOf: { '@id': 'https://killerspots.com/#localbusiness' },
};

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Audio Production',
      item: 'https://killerspots.com/services/audio-production',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'On-Hold Messaging',
      item: 'https://killerspots.com/services/audio-production/on-hold-messaging',
    },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'On-Hold Messaging',
  provider: { '@id': 'https://killerspots.com/#localbusiness' },
  areaServed: 'US',
  description: meta.description,
  url: 'https://killerspots.com/services/audio-production/on-hold-messaging',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const ON_HOLD_PLAYLIST =
  'https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/playlists/soundcloud%253Aplaylists%253A20082108&color=%23ef5253&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false&visual=true';
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  schema={[speakable, breadcrumbs, serviceSchema, faqSchema]}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-canvas">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"
      >
      </div>
    </div>

    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]">
        <a href="/services/audio-production" class="hover:text-white">Audio Production</a>
        <span class="mx-2">/</span>
        <span class="text-ink">On-Hold Messaging</span>
      </nav>

      <div class="max-w-5xl mt-6">
        <span class="eyebrow">On-Hold Messaging</span>
        <h1 id="hero-headline" class="hero-headline mt-5">
          Turn dead air
          <span class="text-brand-500">into a brand asset.</span>
        </h1>
        <p
          id="hero-subhead"
          class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug"
        >
          Custom on-hold messaging that reduces hang-ups, reinforces your specials, and
          makes your business sound like a real brand — not a beep on a queue.
        </p>

        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3">
          <a href="/contact" class="btn btn-primary">Get a Quote</a>
          <a href="#listen" class="btn btn-ghost">
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M5 3.5v9l7-4.5z" />
            </svg>
            Listen to Samples
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST -->
  <section class="bg-deep">
    <div class="container-page py-12 md:py-16">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="flex flex-wrap items-center gap-2.5">
          {trustPills.map((p) => <span class="trust-pill">{p}</span>)}
        </div>
        <p class="text-base md:text-lg text-muted leading-relaxed">
          We've produced on-hold messaging for thousands of businesses — home services,
          dental, legal, healthcare, retail, and multi-location franchises across the U.S.
        </p>
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">Why It Matters</span>
        <h2 class="section-headline mt-5">
          The most captive audience your marketing has — and most businesses waste it.
        </h2>
      </div>

      <ul class="grid md:grid-cols-3 gap-5 md:gap-6">
        {
          why.map((w) => (
            <li
              data-reveal
              class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"
            >
              <h3 class="text-lg md:text-xl font-semibold text-white">{w.title}</h3>
              <p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{w.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- INCLUDED -->
  <section class="bg-deep">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">What's Included</span>
        <h2 class="section-headline mt-5">Full production. Phone-system ready.</h2>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {
          included.map((i) => (
            <li
              data-reveal
              class="rounded-2xl border border-white/5 bg-canvas/60 p-7"
            >
              <h3 class="text-lg font-semibold text-white">{i.title}</h3>
              <p class="mt-3 text-sm text-muted leading-relaxed">{i.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- LISTEN -->
  <section id="listen" class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-10 max-w-3xl" data-reveal>
        <span class="eyebrow">Listen</span>
        <h2 class="section-headline mt-5">Sample on-hold messages.</h2>
      </div>

      <div data-reveal class="rounded-2xl overflow-hidden border border-white/10">
        <iframe
          width="100%"
          height="450"
          allow="autoplay"
          src={ON_HOLD_PLAYLIST}
          title="Killerspots On-Hold Messaging — SoundCloud playlist"
          loading="lazy"
          style="display:block;border:0;background:#0a0e12;"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-deep">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 max-w-3xl" data-reveal>
        <span class="eyebrow">FAQ</span>
        <h2 class="section-headline mt-5">On-hold messaging questions.</h2>
      </div>

      <div class="max-w-3xl space-y-3" data-reveal>
        {
          faqs.map((f) => (
            <details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5">
              <summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4">
                <span>{f.q}</span>
                <svg
                  class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M10 4v12M4 10h12"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                  />
                </svg>
              </summary>
              <p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden bg-canvas">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div
        class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"
      >
      </div>
    </div>

    <div class="container-page py-24 md:py-32">
      <div class="max-w-3xl" data-reveal>
        <span class="eyebrow">Stop Losing Callers</span>
        <h2 class="section-headline mt-5">
          Tell us about your phone system. We'll make on-hold work for you.
        </h2>
        <p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">
          Send us your specials, hours, and the questions your team answers all day. We'll
          come back with a script and a quote — and have files in your inbox in 2–3 days.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary">Get a Quote</a>
          <a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">
            Call {businessInfo.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
