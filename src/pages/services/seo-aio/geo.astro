---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'GEO | Generative Engine Optimization | Killerspots',
  description: 'Generative Engine Optimization (GEO) — content engineered specifically for the way generative AI engines like ChatGPT, Claude, Perplexity, and Gemini source and cite answers.',
  ogTitle: 'GEO — Generative Engine Optimization | Killerspots',
  ogDescription: 'GEO is the new SEO discipline for generative AI search. Long-tail entity coverage, structured answers, and citation-friendly content patterns.',
};

const trustPills = ['GEO Specialists', 'Citation-Friendly Content', 'Long-Tail Coverage'];

const what = [
  { title: 'Long-Tail Entity Coverage', body: 'AI engines source answers from content that covers entities deeply. We map and produce content for the long-tail terms your prospects ask AI engines.' },
  { title: 'FAQ Depth', body: 'AI engines lift FAQ answers verbatim. We build deep, comprehensive FAQ sections on every page that engines can confidently cite as authoritative.' },
  { title: 'Structured Answer Blocks', body: 'TLDR sections, summary boxes, and structured "what is" / "how to" / "why does" answer blocks that AI engines extract as citation-ready snippets.' },
  { title: 'Citation-Friendly Format', body: 'Short, declarative sentences. Clear definitions. Numbered lists. Tables for comparison. All formats AI engines preferentially cite.' },
  { title: 'Entity Disambiguation', body: 'When your brand name is ambiguous, AI engines guess. We use schema and contextual signals to disambiguate so they cite YOU, not a competitor.' },
  { title: 'Prompt-Reverse Content', body: 'Map the prompts your prospects ask AI engines, then build content that directly answers those prompts. Backwards content engineering.' },
];

const faqs = [
  { q: 'How is GEO different from SEO?', a: 'SEO optimizes for traditional search engines (Google\'s 10 blue links). GEO optimizes for generative AI engines that synthesize answers and cite sources. Different signals, different content patterns. Most engagements bundle SEO + AIO + GEO.' },
  { q: 'How do you measure GEO success?', a: 'Citation count in AI responses, brand mention frequency, and prompt coverage rates. KillerSEOx tracks these monthly. We benchmark against competitors.' },
  { q: 'Will GEO content hurt my Google ranking?', a: 'No — entity-rich, structured, authoritative content ranks well in Google AND gets cited by AI engines. The patterns reinforce each other.' },
  { q: 'How fast does GEO show results?', a: 'Faster than SEO. AI engines index content quickly — citations can appear within weeks once content is structured correctly. Tracking is monthly, results meaningful by month 2–3.' },
  { q: 'What\'s the highest-leverage GEO move?', a: 'FAQ depth on your most important pages. AI engines lift FAQ answers verbatim, so a comprehensive FAQ section on a service page is the single highest-leverage GEO move.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/seo-aio/geo#webpage', url: 'https://killerspots.com/services/seo-aio/geo', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'SEO & AIO', item: 'https://killerspots.com/services/seo-aio' }, { '@type': 'ListItem', position: 3, name: 'GEO', item: 'https://killerspots.com/services/seo-aio/geo' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/seo-aio" class="hover:text-white">SEO &amp; AIO</a><span class="mx-2">/</span><span class="text-ink">GEO</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Generative Engine Optimization</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Engineered for <span class="text-brand-500">how AI actually cites.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">GEO is the discipline of writing content specifically for generative AI engines. Long-tail entity coverage, FAQ depth, structured answer blocks, and citation-friendly formatting.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/services/seo-aio/killerseox-audit" class="btn btn-primary magnetic">Run a Free AI Audit</a><a href="/contact" class="btn btn-ghost">Get a Quote</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">The brands that get cited in AI responses control the new search. GEO is how you become one of them.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Do</span><h2 class="section-headline mt-5">Six layers of GEO content engineering.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">GEO questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Build for AI Citation</span><h2 class="section-headline mt-5">Tell us your topics. We'll engineer the content.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We\'ll map your prompts, your entities, and your AI visibility baseline — then come back with a GEO content plan.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href="/services/seo-aio" class="btn btn-ghost">See SEO + AIO</a></div></div></div></section>
</BaseLayout>
