---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'SEO Services | Local + National Search Engine Optimization | Killerspots',
  description: 'Local and national SEO that compounds. Technical audits, on-page optimization, content production, link building, GBP management. Built on our KillerSEOx audit platform.',
  ogTitle: 'SEO That Compounds — Local + National | Killerspots',
  ogDescription: 'Real SEO work — technical, content, links, local — reported by traffic, leads, and revenue. Not vanity DA scores.',
};

const trustPills = ['Local + National SEO', 'KillerSEOx Powered', 'Compounding Channel'];

const what = [
  { title: 'Technical SEO', body: 'Site architecture, schema markup, Core Web Vitals, crawl efficiency, internal linking, mobile-first audits. The plumbing that lets content rank.' },
  { title: 'On-Page Optimization', body: 'Title tags, meta descriptions, heading structure, entity coverage, internal links, and content depth — tuned page-by-page.' },
  { title: 'Content Production', body: 'Long-form, entity-rich content built for Google + AI engines. Topical authority maps, content cluster strategies, and editorial calendars.' },
  { title: 'Local SEO + GBP', body: 'Google Business Profile optimization, local citations, review velocity, and "near me" ranking signals. The compounding asset for service businesses.' },
  { title: 'Link Building', body: 'Editorial links from real publications. Guest posts, digital PR placements, HARO, and resource-page outreach. Slow but durable.' },
  { title: 'Reporting + Attribution', body: 'Organic traffic, qualified leads, conversion rate, revenue attribution. Real metrics, plain English. Reported monthly.' },
];

const faqs = [
  { q: 'How fast does SEO produce results?', a: 'Local SEO: 60–90 days for measurable rank movement. National SEO: 6–12 months. We set expectations up front and report against them every month.' },
  { q: 'Do you do AI Optimization (AIO) too?', a: 'Yes — see our AI Optimization page. SEO and AIO are bundled in most engagements because the work overlaps significantly.' },
  { q: 'Is link building safe?', a: 'When done right, yes. We focus on editorial links from real publications — never link schemes, PBNs, or anything that risks penalties. Slow and durable beats fast and risky.' },
  { q: 'What\'s a realistic SEO budget?', a: 'For local businesses: $2K–$8K/mo depending on market competition. National brands: $10K+/mo for meaningful campaigns. Below that, the math doesn\'t work for either side.' },
  { q: 'Will my rankings disappear if I stop?', a: 'Site quality and links you\'ve earned are durable. Active campaigns (content, freshness signals) decay if you stop. Most clients downshift to maintenance retainers rather than fully stopping.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/seo-aio/seo#webpage', url: 'https://killerspots.com/services/seo-aio/seo', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'SEO & AIO', item: 'https://killerspots.com/services/seo-aio' }, { '@type': 'ListItem', position: 3, name: 'SEO', item: 'https://killerspots.com/services/seo-aio/seo' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/seo-aio" class="hover:text-white">SEO &amp; AIO</a><span class="mx-2">/</span><span class="text-ink">SEO</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">SEO Services</span>
        <h1 id="hero-headline" class="hero-headline mt-5">SEO that <span class="text-brand-500">compounds — not coasts.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Technical, content, links, and local — done in-house, reported by traffic and leads, not domain authority. Built on our proprietary KillerSEOx audit platform.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/services/seo-aio/killerseox-audit" class="btn btn-primary magnetic">Run a Free Audit</a><a href="/contact" class="btn btn-ghost">Get a Quote</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">25+ years building organic traffic. We've been doing SEO since when "ranking #1" actually meant something simple.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Do</span><h2 class="section-headline mt-5">Six layers of SEO. Coordinated.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">SEO questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Start With a Free Audit</span><h2 class="section-headline mt-5">See what's broken — and what's possible.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">KillerSEOx audit takes 60 seconds. Run it on your site (or your competitor's), then we'll talk about what to do with the results.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/services/seo-aio/killerseox-audit" class="btn btn-primary magnetic">Run a Free Audit</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
