---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo, logoUrls } from '../../../data/navigation';

const meta = {
  title: 'SEO & AI Optimization (AIO) | Rank in Google + AI Search | Killerspots',
  description: 'SEO and AI Optimization (AIO) for Google + ChatGPT, Perplexity, and Gemini. Local SEO, technical audits, content production, GEO/LLM visibility, plus our KillerSEOx audit tool.',
  ogTitle: 'SEO + AIO — Rank in Google AND in ChatGPT | Killerspots',
  ogDescription: 'SEO that drives organic traffic, plus AI Optimization (AIO) that gets you cited in ChatGPT, Perplexity, Google AI Overviews, and Gemini. KillerSEOx audit included.',
};

const trustPills = ['SEO + AI Search', 'KillerSEOx Audit Tool', 'Compounding Channel'];

const services = [
  { title: 'SEO', href: '/services/seo-aio/seo', body: 'Local + national SEO. Technical audits, on-page optimization, content production, link building, and GBP management. Built to compound.' },
  { title: 'AI Optimization (AIO)', href: '/services/seo-aio/ai-optimization', body: 'Get cited in ChatGPT, Claude, Perplexity, Google AI Overviews, and Gemini. Entity-rich content, structured data, and citation strategy.' },
  { title: 'GEO (Generative Engine Optimization)', href: '/services/seo-aio/geo', body: 'Optimize content specifically for the way AI engines source and cite — different from classical SEO. Long-tail entity coverage, FAQ depth, structured answers.' },
  { title: 'LLM Visibility', href: '/services/seo-aio/llm-visibility', body: 'Monitor and improve how your brand shows up in LLM responses. Citation tracking, brand mention monitoring, and content gap analysis.' },
  { title: 'KillerSEOx Audit', href: '/services/seo-aio/killerseox-audit', body: 'Our proprietary audit tool. Plug in a domain, get a complete SEO + AI visibility report in 60 seconds — free.' },
  { title: 'Content Writing', href: '/services/creative/content-writing', body: 'Long-form, entity-rich content production. Built to rank in Google and get cited by AI search engines.' },
];

const why = [
  { title: 'SEO + AIO Together', body: 'Most agencies still optimize for Google\'s 10 blue links. The web shifted — AI search is now 30%+ of how people find answers. We optimize for both, in one engagement.' },
  { title: 'Built On Our Own Tools', body: 'KillerSEOx is our proprietary audit platform. We dogfood it on every client. Custom data + custom workflows = better SEO than agencies running rented tools.' },
  { title: 'Real Content, Not Spun', body: 'We produce content with real subject matter expertise — not AI-spun blog posts. Google\'s helpful content updates and AI engines both reward authentic authority.' },
  { title: 'Reported By Outcome', body: 'Organic traffic, qualified leads, AI citations, brand mentions. Not "we improved your domain authority." Real metrics, plain English.' },
];

const faqs = [
  { q: 'What\'s the difference between SEO and AIO?', a: 'SEO optimizes for traditional search engines (Google, Bing). AIO (AI Optimization) optimizes for how AI search engines (ChatGPT, Perplexity, Google AI Overviews, Gemini) source and cite content. Different ranking signals, different content patterns. We do both.' },
  { q: 'How fast does SEO produce results?', a: 'Local SEO: 60–90 days for measurable rank movement, 6 months for compounding traffic. National SEO: 6–12 months. AIO: faster — citations can appear in weeks once content is structured correctly.' },
  { q: 'Will my content get cited in ChatGPT and Perplexity?', a: 'That\'s the goal of AIO. We optimize for entity-rich, well-structured, authoritative content that AI engines can confidently cite. We track citation appearance monthly.' },
  { q: 'Do you offer link building?', a: 'Yes — but we focus on editorial links from real publications, not link schemes. PR placements, guest posts in legitimate publications, and digital PR campaigns. Slow but durable.' },
  { q: 'How does KillerSEOx fit in?', a: 'Free audit tool we built. Plug in your domain, get a complete SEO + AI visibility audit in 60 seconds. We use it on every client engagement and we offer it free for prospects to try.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/seo-aio#webpage', url: 'https://killerspots.com/services/seo-aio', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'SEO & AIO', item: 'https://killerspots.com/services/seo-aio' }] };
const serviceSchema = { '@context': 'https://schema.org', '@type': 'Service', serviceType: 'SEO and AI Optimization', provider: { '@id': 'https://killerspots.com/#localbusiness' }, areaServed: 'US', description: meta.description, url: 'https://killerspots.com/services/seo-aio' };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, serviceSchema, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-44 pb-20 md:pb-28">
      <div class="max-w-5xl">
        <img src={logoUrls.killerSeox} alt="KillerSEOx" width="200" height="48" class="h-10 md:h-12 w-auto mb-6" loading="lazy" decoding="async" />
        <span class="eyebrow">SEO &amp; AIO</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Rank in Google. <span class="text-brand-500">Get cited by ChatGPT.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">SEO and AI Optimization (AIO) for the entire search landscape — Google, Perplexity, ChatGPT, Claude, Gemini, and Google AI Overviews. Built on our proprietary KillerSEOx audit platform.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/services/seo-aio/killerseox-audit" class="btn btn-primary magnetic">Run a Free Audit</a><a href="#services" class="btn btn-ghost">See Services</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">SEO is no longer just Google. AI search engines now answer 30%+ of queries that used to send traffic to your site. We optimize for both.</p></div></div></section>

  <section id="services" class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Run</span><h2 class="section-headline mt-5">Search optimization across every engine that matters.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{services.map((s) => (<li data-reveal><a href={s.href} class="card-tile group"><h3 class="text-lg md:text-xl font-semibold text-white">{s.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{s.body}</p><div class="mt-6 inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-brand-500 group-hover:text-brand-300">Explore<svg class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg></div></a></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">Why Killerspots</span><h2 class="section-headline mt-5">Built for the search landscape that actually exists in 2026.</h2></div><ul class="grid md:grid-cols-2 gap-5 md:gap-6">{why.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"><h3 class="text-lg md:text-xl font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">SEO + AIO questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-deep"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Start With a Free Audit</span><h2 class="section-headline mt-5">Plug in your domain. Get the full picture.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">KillerSEOx audit takes 60 seconds. Full SEO health, AI search visibility, technical issues, and competitor gaps. Free, no credit card.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/services/seo-aio/killerseox-audit" class="btn btn-primary magnetic">Run a Free Audit</a><a href="/contact" class="btn btn-ghost">Get a Quote</a></div></div></div></section>
</BaseLayout>
