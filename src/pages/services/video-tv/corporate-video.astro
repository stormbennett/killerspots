---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Corporate Video Production | Training, Recruiting, Internal Comms | Killerspots',
  description: 'Corporate video production — training videos, recruiting content, internal communications, and investor video. Talking-head, B-roll, and full editorial production.',
  ogTitle: 'Corporate Video That Doesn\'t Bore the Audience | Killerspots',
  ogDescription: 'Training, recruiting, internal comms, and investor video. Studio + on-location production. Editorial polish that elevates corporate from "stuffy" to "watched."',
};

const trustPills = ['Studio + Location', 'Editorial Polish', 'Multi-Use Cuts'];

const what = [
  { title: 'Training & E-Learning Video', body: 'Onboarding video, product training, compliance modules, and L&D content. Clear, concise, instructional. SCORM-friendly outputs available.' },
  { title: 'Recruiting Video', body: 'Talent attraction video — culture, perks, what working there is like. The single highest-impact recruiting asset most companies don\'t have.' },
  { title: 'Internal Communications', body: 'CEO updates, all-hands recordings, change-management messaging. Polished but human — corporate without being stuffy.' },
  { title: 'Investor & Fundraising', body: 'Pitch video, investor updates, board reporting visuals. Production quality that signals seriousness without being over-produced.' },
  { title: 'Talking-Head + B-Roll', body: 'Standard corporate format done well. Teleprompter-supported interviews, professional lighting, and B-roll that supports the narrative.' },
  { title: 'Multi-Use Editorial', body: 'Same shoot, multiple cuts. Long-form internal use, short-form social cuts, recruitment trailers. Maximize ROI per shoot day.' },
];

const faqs = [
  { q: 'Do you shoot in our office?', a: 'Yes — most corporate video is best on-location at your office, with your real environment as the backdrop. We travel for the shoot. Studio production available for green-screen needs or controlled environments.' },
  { q: 'How long does corporate video take?', a: 'Standard talking-head + B-roll: 3–5 weeks from kickoff to final delivery. Larger projects (full training series, multi-location shoots): 8–16 weeks.' },
  { q: 'Can you handle compliance/regulated industries?', a: 'Yes. Healthcare, financial services, legal — we work within compliance constraints, get scripts approved by your legal/compliance team before shooting, and deliver final cuts ready for review.' },
  { q: 'Do you provide teleprompter?', a: 'Yes — teleprompter is standard on talking-head shoots. Helps non-actor talent (your CEO, your subject-matter experts) deliver clean reads without memorizing scripts.' },
  { q: 'What\'s a realistic budget?', a: 'Single-talking-head video: $5K–$15K. Multi-day, multi-subject corporate productions: $20K–$60K+. Wildly variable based on travel, talent, and post-production complexity.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/video-tv/corporate-video#webpage', url: 'https://killerspots.com/services/video-tv/corporate-video', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Video & TV', item: 'https://killerspots.com/services/video-tv' }, { '@type': 'ListItem', position: 3, name: 'Corporate Video', item: 'https://killerspots.com/services/video-tv/corporate-video' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/video-tv" class="hover:text-white">Video &amp; TV</a><span class="mx-2">/</span><span class="text-ink">Corporate Video</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Corporate Video</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Corporate video that <span class="text-brand-500">doesn\'t feel corporate.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Training, recruiting, internal comms, and investor video. Studio + on-location production with editorial polish that makes corporate watchable.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Corporate Video Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">Most corporate video is unwatchable. We bring agency-level editorial to internal content so it actually gets watched.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Make</span><h2 class="section-headline mt-5">Six corporate video formats.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Corporate video questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Make Corporate Watchable</span><h2 class="section-headline mt-5">Tell us your project. We'll size the production.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We\'ll review your subjects, your locations, and your audience — then come back with a production plan and quote.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
