---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Motion Graphics & Animation | Logo, Explainer, Kinetic Type | Killerspots',
  description: 'Motion graphics and 2D animation — logo animations, explainer videos, kinetic typography, and animated ad creative. In-house production, supports every video format.',
  ogTitle: 'Motion Graphics & Animation | Killerspots',
  ogDescription: 'Logo animations, explainer videos, kinetic typography, and animated ad creative. In-house team, broadcast quality, multi-format delivery.',
};

const trustPills = ['In-House Animation', 'Multi-Format Delivery', 'Broadcast Quality'];

const what = [
  { title: 'Logo Animations', body: 'Animated logo bumpers and intros for video content, social posts, and brand identity. Scale across every video asset you produce.' },
  { title: 'Animated Explainer Videos', body: '2D animated explainer videos — products, services, processes. Concept, scripting, illustration, animation, and voice over (via VoiceTalent.Agency).' },
  { title: 'Kinetic Typography', body: 'Text-driven animated video — quotes, statistics, value propositions in motion. Strong hook for social-first content.' },
  { title: 'Lower Thirds + Bumpers', body: 'Branded lower thirds, transitions, and bumpers for live video, podcasts, and webinars. Templated for ongoing reuse.' },
  { title: 'Animated Ad Creative', body: 'Motion-graphic ad creative for Meta, TikTok, programmatic, and CTV. Cheaper than live-action shoots; faster to iterate.' },
  { title: 'Mixed-Media Production', body: 'Live-action + motion graphics blended together. Common for explainer content, product demos, and brand films.' },
];

const faqs = [
  { q: 'Do you do 3D animation?', a: 'Light 3D — animated typography, simple product showcases. Heavy 3D (character animation, photoreal product visualization) we\'d partner with a specialist studio. We\'ll be honest about what\'s in our wheelhouse.' },
  { q: 'How long does an animated explainer take?', a: 'Standard 60–90 second 2D explainer: 4–8 weeks. Includes scripting, storyboarding, illustration, animation, voice over, and revisions.' },
  { q: 'Can you animate our existing logo?', a: 'Yes. Logo animation as a standalone deliverable — used across every video asset you make. Typically delivered in multiple lengths and styles.' },
  { q: 'Do you write scripts for animated explainers?', a: 'Yes. Scripting is included in the standard package. We write, you approve, then we storyboard and animate.' },
  { q: 'What\'s the difference between motion graphics and animation?', a: 'Motion graphics = animating typography, icons, and shapes (informational, often abstract). 2D animation = animating illustrated characters, scenes, and storytelling (narrative, often emotional). We do both.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/video-tv/graphics-animations#webpage', url: 'https://killerspots.com/services/video-tv/graphics-animations', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Video & TV', item: 'https://killerspots.com/services/video-tv' }, { '@type': 'ListItem', position: 3, name: 'Graphics & Animations', item: 'https://killerspots.com/services/video-tv/graphics-animations' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/video-tv" class="hover:text-white">Video &amp; TV</a><span class="mx-2">/</span><span class="text-ink">Graphics &amp; Animations</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Motion Graphics &amp; Animation</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Motion that moves <span class="text-brand-500">audiences and metrics.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Logo animations, animated explainer videos, kinetic typography, lower thirds, and motion-graphic ad creative. In-house team. Multi-format delivery.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get an Animation Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">Motion graphics support every other video format we produce. Logo bumpers, animated explainers, kinetic ad creative — all in-house.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Make</span><h2 class="section-headline mt-5">Six motion + animation formats.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Animation questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Make Things Move</span><h2 class="section-headline mt-5">Tell us what to animate. We'll bring it to life.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We\'ll review your project, your style references, and your timeline — then come back with a plan and quote.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
