---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Graphic Design & Branding | Brand Identity, Print, Digital | Killerspots',
  description: 'Graphic design and brand identity built for performance. Logo design, brand systems, print, social graphics, ad creative, and marketing collateral — produced in-house.',
  ogTitle: 'Graphic Design & Branding That Connects to Performance | Killerspots',
  ogDescription: 'Brand identity, print, and digital design produced by an in-house team since 1999. Built to support every channel we run.',
};

const trustPills = ['In-House Design', 'Brand-System Thinking', 'Performance-Connected'];

const what = [
  { title: 'Brand Identity Systems', body: 'Logo, typography, color palette, photography style, voice guidelines, and brand book. The full system, designed to scale and age well.' },
  { title: 'Logo Design', body: 'Original logo design with multiple concept rounds, refinement, and final delivery in every format you\'ll need (vector, transparent, light/dark, social-sized).' },
  { title: 'Print Design', body: 'Brochures, business cards, signage, packaging, trade-show booths, vehicle wraps. We design for print AND we know which print vendors deliver.' },
  { title: 'Social Graphics', body: 'Templated social graphics that scale across daily content, plus custom hero graphics for campaigns. Built for Instagram, Facebook, LinkedIn, and TikTok.' },
  { title: 'Ad Creative', body: 'Static and video ad creative for Google, Meta, LinkedIn, and programmatic. Multiple variants for testing, brand-consistent across channels.' },
  { title: 'Marketing Collateral', body: 'Sales decks, one-pagers, case studies, white papers, email templates. Everything your sales and marketing teams need to ship.' },
];

const faqs = [
  { q: 'Do you design logos from scratch?', a: 'Yes. Original concepts, multiple rounds, refinement, and full final delivery — vector files, transparent backgrounds, light/dark variants, social-optimized sizes. Built to scale across every medium.' },
  { q: 'Can you handle a full rebrand?', a: 'Yes. Logo, type, color, photography, voice, applied across web, print, social, and packaging. Sized to your business stage — startup branding through enterprise rebrand.' },
  { q: 'Do you do print management?', a: 'Yes — we design for print and manage printing through vetted vendors. Trade-show booths, vehicle wraps, signage, packaging, business cards. Saves you from sourcing your own print partners.' },
  { q: 'How long does brand identity work take?', a: 'Logo only: 2–4 weeks. Full brand system (logo + type + color + photography + voice + applied collateral): 6–12 weeks depending on scope.' },
  { q: 'Can you work in our existing brand?', a: 'Yes. Most of our work is creating new assets within established brand systems. We respect the brand, work in it, and only suggest evolution when it\'s genuinely warranted.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/creative/graphic-design#webpage', url: 'https://killerspots.com/services/creative/graphic-design', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Creative & Content', item: 'https://killerspots.com/services/creative' }, { '@type': 'ListItem', position: 3, name: 'Graphic Design', item: 'https://killerspots.com/services/creative/graphic-design' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/creative" class="hover:text-white">Creative &amp; Content</a><span class="mx-2">/</span><span class="text-ink">Graphic Design</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Graphic Design &amp; Branding</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Design that <span class="text-brand-500">connects to performance.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Brand identity, logo design, print, social graphics, and ad creative — produced in-house by a team that builds for every channel we run.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Design Quote</a><a href="/portfolio" class="btn btn-ghost">See Our Work</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">Pretty design isn\'t the goal. Design that drives clicks, calls, and conversions is. We build creative as part of campaigns, not standalone art projects.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Make</span><h2 class="section-headline mt-5">Six layers of design — every channel covered.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Graphic design questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Make Something</span><h2 class="section-headline mt-5">Tell us your project. We'll size the work.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute creative call. We\'ll review your brand, your needs, and your timeline — then come back with a quote.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
