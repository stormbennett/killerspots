---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Logo Design | Original Logos + Brand Marks | Killerspots',
  description: 'Original logo design and brand mark development. Wordmarks, icons, full brand systems. Multiple concept rounds, refinement, and final delivery in every format you\'ll ever need.',
  ogTitle: 'Logo Design That Scales — Across Every Medium | Killerspots',
  ogDescription: 'Original logo design + brand mark development. Multiple concepts, refinement, and full delivery in every format. Built to scale from business card to billboard.',
};

const trustPills = ['Original Concepts', 'Multiple Rounds', 'Full Format Delivery'];

const what = [
  { title: 'Wordmarks', body: 'Type-driven logos using custom or curated typography. Best when the company name itself is distinctive and short.' },
  { title: 'Icon + Symbol Marks', body: 'Pictorial marks, monograms, and abstract symbols. Used standalone or paired with wordmarks for full brand systems.' },
  { title: 'Combination Marks', body: 'Wordmark + icon together as a unified lockup. The most flexible mark type — works in headers, social icons, and signage.' },
  { title: 'Brand Mark Systems', body: 'Primary mark + secondary marks + monogram + favicon — a full system that covers every use case from business card to app icon.' },
  { title: 'Logo Refresh', body: 'Modernizing an existing logo without losing brand equity. Subtle evolution, not teardown. Common when a company has 10+ years of brand recognition to preserve.' },
  { title: 'Full Format Delivery', body: 'Vector files (AI, SVG, EPS), transparent PNGs, light/dark variants, social-optimized sizes, and a brand book documenting usage rules.' },
];

const faqs = [
  { q: 'How many concepts do I get to see?', a: 'Standard process: 3–4 distinct directions in round 1, then refinement of the strongest direction in rounds 2 and 3. We don\'t do "100 logos for $50" — we do focused exploration with real iteration.' },
  { q: 'How long does logo design take?', a: '4–6 weeks for full process from kickoff to final delivery. Includes brand discovery, concepting, refinement, and final-format prep.' },
  { q: 'What\'s a realistic budget?', a: 'Standalone logo design: $4K–$12K depending on scope. Logo + full brand system (typography, color, applied collateral): $15K–$40K. Sized to your business stage.' },
  { q: 'Do I own the final logo?', a: 'Yes. Full ownership transfer included. You get vector source files plus all derived formats. We retain right to display in our portfolio unless you specify otherwise.' },
  { q: 'Can you trademark check?', a: 'Basic visual similarity check yes. Formal trademark search and registration is a legal service — we recommend you engage a trademark attorney for that. We coordinate with them as needed.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/creative/logo-design#webpage', url: 'https://killerspots.com/services/creative/logo-design', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Creative & Content', item: 'https://killerspots.com/services/creative' }, { '@type': 'ListItem', position: 3, name: 'Logo Design', item: 'https://killerspots.com/services/creative/logo-design' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/creative" class="hover:text-white">Creative &amp; Content</a><span class="mx-2">/</span><span class="text-ink">Logo Design</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Logo Design</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Original logos that <span class="text-brand-500">scale and age well.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Wordmarks, icons, combination marks, and full brand mark systems. Multiple concept rounds, refinement, and final delivery in every format you\'ll ever need.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Logo Design Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">A great logo is a 10-year asset. We design for permanence — not trends — so your mark looks current in 2030 and 2035.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Make</span><h2 class="section-headline mt-5">Six logo design types.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Logo design questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Design the Mark</span><h2 class="section-headline mt-5">Tell us your brand. We'll design the mark.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute brand discovery call. We\'ll review your business, your audience, and your style references — then start concepting.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href="/services/creative/graphic-design" class="btn btn-ghost">Full Brand Identity →</a></div></div></div></section>
</BaseLayout>
