---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Content Writing Services | SEO + AIO Optimized | Killerspots',
  description: 'Long-form content writing built to rank in Google AND get cited by AI search engines. Blog posts, website copy, email campaigns, and ad copy — entity-rich, authoritative, real.',
  ogTitle: 'Content Writing That Ranks — and Gets Cited by AI | Killerspots',
  ogDescription: 'Real content writing — researched, interviewed, written by humans. Built for SEO + AI Optimization. No AI-spun blog posts.',
};

const trustPills = ['SEO + AIO Built In', 'Real Research', 'Human-Written'];

const what = [
  { title: 'Long-Form Blog Content', body: 'Researched articles, FAQ deep-dives, comparison guides, and pillar content. Built to rank in Google AND get cited by AI search engines.' },
  { title: 'Website Copy', body: 'Service pages, about pages, landing pages, location pages. Built around the keywords, entities, and intent your prospects actually search.' },
  { title: 'Email Campaigns', body: 'Email sequences, newsletters, drip campaigns, and broadcast emails. Voice-aligned, conversion-tracked, integrated with LeadConnector.' },
  { title: 'Ad Copy', body: 'Google Ads, Meta, LinkedIn, and CTV ad copy. Multiple variants for testing, brand-consistent, written for the platform constraints.' },
  { title: 'Industry-Specific Writing', body: 'Trade publications, regulated industries (legal, medical), B2B technical content. Subject-matter research before we write a word.' },
  { title: 'Content Strategy', body: 'Topic clustering, editorial calendars, internal linking strategy, and topical authority maps. Strategic content production, not random posting.' },
];

const faqs = [
  { q: 'Do you use AI to write content?', a: 'AI accelerates research and outlining, but every piece is researched, interviewed, edited, and written by a human. Google\'s helpful-content updates and AI search engines both reward authentic authority — AI-spun content fails on both.' },
  { q: 'How is content writing priced?', a: 'Per-piece for one-offs ($300–$1,500 depending on depth and research). Monthly retainer for ongoing production (typically 4–12 pieces/month). We size to your topics and SEO/AIO goals.' },
  { q: 'Will you research my industry?', a: 'Yes. We interview subject-matter experts (yours or third-party), read competitor content, study search-intent data, and write from real understanding. No surface-level fluff.' },
  { q: 'What\'s the difference between SEO content and AIO content?', a: 'SEO content optimizes for Google\'s ranking factors. AIO content optimizes for how AI engines source citations. We do both in the same piece — entity-rich, structured, authoritative content that ranks AND gets cited.' },
  { q: 'Can you match our brand voice?', a: 'Yes. Voice training is part of every engagement — we read existing content, interview your founders/leadership, and produce a brand voice guide before writing. Continuity across all your content.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/creative/content-writing#webpage', url: 'https://killerspots.com/services/creative/content-writing', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Creative & Content', item: 'https://killerspots.com/services/creative' }, { '@type': 'ListItem', position: 3, name: 'Content Writing', item: 'https://killerspots.com/services/creative/content-writing' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/creative" class="hover:text-white">Creative &amp; Content</a><span class="mx-2">/</span><span class="text-ink">Content Writing</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Content Writing</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Content that ranks in Google <span class="text-brand-500">and gets cited by ChatGPT.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Long-form blog content, website copy, email campaigns, and ad copy — researched, interviewed, and written by humans. Built for SEO + AI Optimization. No AI-spun fluff.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Content Quote</a><a href="/services/seo-aio/killerseox-audit" class="btn btn-ghost">Run a Free Audit</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">Google\'s helpful-content updates and AI search engines both reward authentic, researched, authoritative content. AI-spun blog posts fail on both. We write the kind that wins.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Write</span><h2 class="section-headline mt-5">Six content formats — every channel covered.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Content writing questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Build Topical Authority</span><h2 class="section-headline mt-5">Tell us your topics. We'll build the content engine.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We\'ll map your topics, your audience, and your SEO/AIO goals — then come back with a content strategy and quote.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href="/services/seo-aio" class="btn btn-ghost">See SEO + AIO Services</a></div></div></div></section>
</BaseLayout>
