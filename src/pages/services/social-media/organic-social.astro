---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Organic Social Media Management | Daily Content + Engagement | Killerspots',
  description: 'Daily organic social posting, content calendars, captions, hashtag strategy, and community management. Instagram, Facebook, TikTok, LinkedIn, YouTube. Real engagement.',
  ogTitle: 'Organic Social — Daily, Not Monthly | Killerspots',
  ogDescription: 'Daily posting, content calendars, captions, hashtags, and community management across Instagram, Facebook, TikTok, LinkedIn, YouTube.',
};

const trustPills = ['Daily Posting', 'Real Engagement', 'Multi-Platform'];

const what = [
  { title: 'Content Calendars', body: 'Monthly content planning aligned to your campaigns, seasonal themes, and content pillars. Drafted, approved, scheduled — never reactive.' },
  { title: 'Daily Posting', body: '5–7 organic posts per week per priority platform. Captions, hashtags, links, and tagged accounts handled.' },
  { title: 'Visual Content', body: 'Templated graphic content for daily posts, plus custom hero graphics for campaigns. Consistent brand voice across every post.' },
  { title: 'Community Management', body: 'A human responds to comments and DMs daily. Not a template, not a bot — real conversation that builds relationships.' },
  { title: 'Hashtag + Trend Strategy', body: 'Hashtag research per platform, trend monitoring, and timely content pivots when platform-specific trends emerge.' },
  { title: 'Reporting + Insights', body: 'Monthly performance reports — follower growth, engagement rate, top-performing content, and platform-by-platform analysis.' },
];

const faqs = [
  { q: 'Which platforms do you cover?', a: 'Instagram, Facebook, TikTok, LinkedIn, and YouTube — depending on where your audience actually is. We won\'t post on platforms your customers don\'t use just to fill a calendar.' },
  { q: 'How much content per month?', a: 'Standard package: 5–7 organic posts per week per platform, plus stories and engagement content. We size to platforms and your audience.' },
  { q: 'Will you respond to comments and DMs?', a: 'Yes — daily community management is included on standard packages. We respond to engagement, route brand-critical conversations to you, and escalate sales-ready inquiries to LeadConnector.' },
  { q: 'How fast will I see growth?', a: 'Engagement and follower growth: 30–60 days of consistent posting. Real audience building: 6+ months. Brand recall and community: 12+ months. Daily presence is the unlock.' },
  { q: 'Do you do paid social too?', a: 'Yes — see our Paid Social page. Most clients run organic + paid together because they amplify each other. Organic builds brand; paid drives leads.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/social-media/organic-social#webpage', url: 'https://killerspots.com/services/social-media/organic-social', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Social Media', item: 'https://killerspots.com/services/social-media' }, { '@type': 'ListItem', position: 3, name: 'Organic Social', item: 'https://killerspots.com/services/social-media/organic-social' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/social-media" class="hover:text-white">Social Media</a><span class="mx-2">/</span><span class="text-ink">Organic Social</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Organic Social Media</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Daily, not monthly. <span class="text-brand-500">Real engagement, not template replies.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Content calendars, daily posting, captions, hashtag strategy, and human community management across Instagram, Facebook, TikTok, LinkedIn, and YouTube.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get an Organic Social Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">Most agencies "manage" social by posting once a week. We post daily because that\'s what actually moves the algorithm and the audience.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Run</span><h2 class="section-headline mt-5">Six layers of organic social management.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Organic social questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Hand It Off</span><h2 class="section-headline mt-5">Tell us your platforms. We'll post daily.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We\'ll review your audience, your platforms, and your content pillars — then come back with a calendar and quote.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
