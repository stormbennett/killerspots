---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'CTV / Streaming TV Ads | Hulu, YouTube TV, Roku | Killerspots',
  description: 'Connected TV (CTV) streaming ads on Hulu, YouTube TV, Roku, Amazon Fire, and other premium platforms. Geo-targeted to neighborhoods you serve. Creative production included.',
  ogTitle: 'CTV Streaming Ads — TV-Quality Reach, Local Targeting | Killerspots',
  ogDescription: 'Run TV-quality video ads on Hulu, YouTube TV, Roku, and ESPN+. Geo-targeted to your service area. Creative production included.',
};

const trustPills = ['CTV / Streaming Specialists', 'Geo-Targeted', 'Creative Included'];

const what = [
  { title: 'Hulu, YouTube TV, Roku', body: 'Premium streaming inventory available to local advertisers at competitive CPMs. Most local businesses don\'t know they can buy this — we do it for them.' },
  { title: 'OTT Sports Inventory', body: 'ESPN+, Peacock, Paramount+, NFL+, MLB.TV — premium sports streaming with high engagement and clear demographic targeting.' },
  { title: 'Geo-Targeted Buys', body: 'ZIP code, DMA, or custom radius targeting around your service area. Your spot only runs in neighborhoods you actually serve.' },
  { title: 'Creative Production', body: ':15, :30, and :60 spots produced in our Cincinnati green-screen studio. Broadcast-quality creative bundled with media buying.' },
  { title: 'Audience Targeting', body: 'Demographic, behavioral, and intent-based audience layers on top of geo. Reach homeowners, vehicle owners, in-market shoppers — whatever fits the campaign.' },
  { title: 'View-Through Attribution', body: 'Household-level conversion tracking, post-impression web traffic lift, and brand recall surveys for larger campaigns. Real attribution, not vanity reach.' },
];

const faqs = [
  { q: 'What\'s a realistic CTV budget?', a: 'Most CTV inventory works at $3K+/mo. Below that, the math gets thin once you account for creative production. We can do smaller test budgets to validate the channel.' },
  { q: 'How does geo-targeting work?', a: 'We can target by ZIP code, DMA, custom radius around your locations, or specific neighborhoods. Devices that meet the geo-fence get served your spot when they stream eligible content.' },
  { q: 'Do you produce the creative?', a: 'Yes. :15, :30, and :60 spots produced in our Cincinnati studio with the same broadcast-quality team that does our TV commercials. Creative usually runs as a separate line item from media spend.' },
  { q: 'How is CTV different from regular YouTube ads?', a: 'CTV runs on actual TV-screen experiences (Hulu, Roku, smart TVs) — premium environments where viewers can\'t skip easily. YouTube ads run on YouTube\'s app, which is different inventory and different intent.' },
  { q: 'Can I just run ads on ESPN+ for sports fans?', a: 'Yes — OTT sports inventory is bookable. Premium environment, engaged audience, clear demographic targeting. Common for local home services, auto, and food/beverage advertisers.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/services/digital-ads/ctv-streaming#webpage', url: 'https://killerspots.com/services/digital-ads/ctv-streaming', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Digital Ads', item: 'https://killerspots.com/services/digital-ads' }, { '@type': 'ListItem', position: 3, name: 'CTV / Streaming', item: 'https://killerspots.com/services/digital-ads/ctv-streaming' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/services/digital-ads" class="hover:text-white">Digital Ads</a><span class="mx-2">/</span><span class="text-ink">CTV / Streaming</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">CTV / Streaming TV Ads</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Premium TV reach. <span class="text-brand-500">Local targeting. Real creative.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Hulu, YouTube TV, Roku, ESPN+, and other premium streaming inventory — geo-targeted to neighborhoods you actually serve. Broadcast-quality creative produced in our studio.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a CTV Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">Streaming TV passed broadcast for many demographics. Local advertisers can buy this inventory. Most agencies don\'t know how. We do.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Run</span><h2 class="section-headline mt-5">Six layers of CTV media buying.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{what.map((w) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7"><h3 class="text-lg font-semibold text-white">{w.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{w.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">CTV / streaming questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Run on Premium TV</span><h2 class="section-headline mt-5">Tell us your geo. We'll build the buy.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We\'ll review your service area, your audience, and your creative needs — then come back with a CTV media plan.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
