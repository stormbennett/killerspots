---
import BaseLayout from '../layouts/BaseLayout.astro';
import { businessInfo } from '../data/navigation';

const meta = {
  title: 'Case Studies | Real Marketing Outcomes | Killerspots',
  description: 'Real client case studies with real numbers — leads driven, deals closed, brand metrics moved. Across home services, legal, small business, and broadcasting verticals.',
  ogTitle: 'Killerspots Case Studies — Real Marketing Outcomes',
  ogDescription: 'Real client wins with real numbers. Home services, legal, small business, broadcasting, and white-label partnerships.',
};

// =====================================================================
// CASE STUDIES
// ---------------------------------------------------------------------
// Each entry below renders as a case-study tile. Add a new study by
// pushing onto this array. Full case-study detail pages can be built
// at src/pages/case-studies/[slug].astro later.
// =====================================================================

type CaseStudy = {
  title: string;
  client: string;
  industry: string;
  summary: string;
  metrics: { value: string; label: string }[];
  slug?: string;
};

const studies: CaseStudy[] = [
  // Placeholder: real case studies get added here as we publish them.
];

const speakable = { '@context': 'https://schema.org', '@type': 'CollectionPage', '@id': 'https://killerspots.com/case-studies#webpage', url: 'https://killerspots.com/case-studies', name: meta.title, description: meta.description, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Case Studies', item: 'https://killerspots.com/case-studies' }] };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs]}>
  <section class="relative overflow-hidden bg-canvas">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div>
    </div>
    <div class="container-page pt-24 md:pt-32 lg:pt-44 pb-20 md:pb-28">
      <div class="max-w-5xl">
        <span class="eyebrow">Case Studies</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Real client wins. <span class="text-brand-500">Real numbers.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">Marketing outcomes from across home services, legal, small business, broadcasting, and white-label partnerships. Leads driven, deals closed, and brand metrics moved.</p>
      </div>
    </div>
  </section>

  <section class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      {studies.length === 0 ? (
        <div class="max-w-3xl" data-reveal>
          <div class="rounded-2xl border border-white/10 bg-surface p-10 md:p-14 text-center">
            <span class="eyebrow">Coming Soon</span>
            <h2 class="section-headline mt-5">Case studies in production.</h2>
            <p class="mt-6 text-base md:text-lg text-muted leading-relaxed max-w-xl mx-auto">
              We\'re assembling case studies from across our client base — HVAC contractors who 4×\'d service calls, law firms that cut case-CPA in half, radio groups that built new digital revenue streams, agencies that scaled white-label past their hiring capacity. First studies publish soon. Want to see specific outcomes for your industry? Ask us on a call.
            </p>
            <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
              <a href="/contact" class="btn btn-primary magnetic">Ask for Industry Examples</a>
              <a href="/portfolio" class="btn btn-ghost">See Our Work →</a>
            </div>
          </div>
        </div>
      ) : (
        <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
          {studies.map((s) => (
            <li data-reveal>
              <a href={s.slug ? `/case-studies/${s.slug}` : '#'} class="card-tile group">
                <div class="text-xs uppercase tracking-[0.18em] text-brand-500 font-semibold">{s.industry}</div>
                <h3 class="mt-3 text-lg md:text-xl font-semibold text-white">{s.client}</h3>
                <p class="mt-2 text-sm md:text-base text-ink font-medium">{s.title}</p>
                <p class="mt-3 text-sm text-muted leading-relaxed">{s.summary}</p>
                <dl class="mt-6 grid grid-cols-2 gap-3">
                  {s.metrics.map((m) => (
                    <div class="rounded-xl border border-white/10 bg-canvas p-3 text-center">
                      <dd class="text-lg md:text-xl font-bold text-white">{m.value}</dd>
                      <dt class="mt-1 text-[10px] uppercase tracking-[0.15em] text-muted">{m.label}</dt>
                    </div>
                  ))}
                </dl>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <section class="relative overflow-hidden bg-deep">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div>
    </div>
    <div class="container-page py-24 md:py-32">
      <div class="max-w-3xl" data-reveal>
        <span class="eyebrow">Want Outcomes Like These?</span>
        <h2 class="section-headline mt-5">Tell us your goals. We'll size the plan.</h2>
        <p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute strategy call. We\'ll review your industry, your competitors, and your current marketing — then come back with a recommendation and quote.</p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary magnetic">Get a Quote</a>
          <a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
