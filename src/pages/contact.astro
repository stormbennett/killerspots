---
import BaseLayout from '../layouts/BaseLayout.astro';
import { businessInfo } from '../data/navigation';

const meta = {
  title: 'Contact Killerspots | Get a Free Marketing Quote',
  description:
    'Contact Killerspots Agency for a free marketing quote. 25+ years of creative expertise in Cincinnati. Get started with custom marketing strategies, jingles, SEO, PPC, and LeadConnector CRM today.',
  ogTitle: 'Contact Killerspots — Get a Quote | Cincinnati Marketing Agency',
  ogDescription:
    'Tell us about your business and we\'ll come back with a quote sized to your goals. 25+ years, full-service creative + digital + AI under one roof.',
};

const trustPills = ['Replies in 1 Business Day', 'Cincinnati, OH', '25+ Years'];

const whatHappensNext = [
  {
    step: '01',
    title: 'We Review Your Info',
    body:
      'A strategist reads what you sent within one business day. No bots, no auto-routed contact-center reply.',
  },
  {
    step: '02',
    title: 'Strategy Call',
    body:
      'We hop on a 30-minute call to understand your goals, your market, and your current marketing — then take notes and go think.',
  },
  {
    step: '03',
    title: 'Custom Proposal',
    body:
      'You get a written proposal sized to your stage and budget. No cookie-cutter packages. No pressure to sign.',
  },
];

const quickStart = [
  {
    title: 'I Need a Quote',
    body: 'Use the form on this page. Tell us what you\'re trying to do — we\'ll size something up.',
    href: '#contact-form',
    label: 'Open the form',
  },
  {
    title: 'Book a Demo',
    body: 'Want to see LeadConnector in action? Pick a time that works.',
    href: '/leadconnector',
    label: 'See LeadConnector',
  },
  {
    title: 'Free SEO Audit',
    body: 'Run KillerSEOx on your domain. Full report on SEO + AI visibility in 60 seconds.',
    href: '/services/seo-aio/killerseox-audit',
    label: 'Run free audit',
  },
];

const faqs = [
  {
    q: 'What\'s your typical turnaround?',
    a: 'Quotes go out within 2–3 business days of the strategy call. Audio production typically turns in 2–3 days. Websites: 4–8 weeks. SEO: 90–180 days to compound. Every quote includes specific timeline expectations.',
  },
  {
    q: 'Do you require long-term contracts?',
    a: 'Standard engagement is a 6-month minimum (so the work has time to compound), then month-to-month. We don\'t lock you into multi-year deals.',
  },
  {
    q: 'What\'s your minimum budget?',
    a: 'Depends entirely on the channel mix. Single-service engagements start lower; integrated marketing plans start higher. Get a quote and we\'ll be straight with you about whether we\'re the right fit.',
  },
  {
    q: 'Do you work with clients outside Cincinnati?',
    a: 'Yes. Our office is in Cincinnati but most of our clients are spread across the U.S. We work remotely with clients in every state and a few internationally.',
  },
  {
    q: 'Can I work with you while keeping my current agency?',
    a: 'Often, yes. Plenty of clients keep a specialist agency in one channel and use us for everything else. We\'ll tell you up front whether that mix actually serves you, or whether consolidating makes more sense.',
  },
  {
    q: 'Do you show pricing on the website?',
    a: 'No — every plan is sized to the business. Get a quote and we\'ll come back with something specific to your goals, market, and stage.',
  },
];

const speakable = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://killerspots.com/contact#webpage',
  url: 'https://killerspots.com/contact',
  name: meta.title,
  description: meta.description,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#hero-headline', '#hero-subhead'],
  },
  isPartOf: { '@id': 'https://killerspots.com/#localbusiness' },
};

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://killerspots.com/contact' },
  ],
};

const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  url: 'https://killerspots.com/contact',
  name: meta.title,
  description: meta.description,
  about: { '@id': 'https://killerspots.com/#localbusiness' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const mapsQuery = encodeURIComponent(
  `${businessInfo.address.street}, ${businessInfo.address.city}, ${businessInfo.address.region} ${businessInfo.address.postal}`
);
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  schema={[speakable, breadcrumbs, contactPageSchema, faqSchema]}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-canvas">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"
      >
      </div>
    </div>

    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-12 md:pb-16">
      <div class="max-w-5xl">
        <span class="eyebrow">Contact</span>
        <h1 id="hero-headline" class="hero-headline mt-5">
          Let's talk about
          <span class="text-brand-500">growing your business.</span>
        </h1>
        <p
          id="hero-subhead"
          class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug"
        >
          Tell us about your goals. We'll come back within one business day with a strategy
          call and — after that — a custom proposal sized to your stage. No pressure. No
          cookie-cutter packages.
        </p>
      </div>
    </div>
  </section>

  <!-- TRUST BAND -->
  <section class="bg-deep">
    <div class="container-page py-10 md:py-14">
      <div class="flex flex-wrap items-center gap-2.5">
        {trustPills.map((p) => <span class="trust-pill">{p}</span>)}
      </div>
    </div>
  </section>

  <!-- FORM + CONTACT INFO -->
  <section id="contact-form" class="bg-canvas">
    <div class="container-page py-20 md:py-28">
      <div class="grid lg:grid-cols-12 gap-10 md:gap-14 items-start">
        <!-- Form column -->
        <div class="lg:col-span-7" data-reveal>
          <span class="eyebrow">Send Us a Message</span>
          <h2 class="section-headline mt-5">Tell us what you're trying to do.</h2>
          <p class="mt-4 text-base md:text-lg text-muted leading-relaxed">
            Quick form. Real human reads it. We reply within one business day.
          </p>

          <div class="mt-8 rounded-2xl border border-white/10 bg-surface p-3 md:p-4">
            <iframe
              src="https://agency.killerspots.com/widget/form/HGqz9DiUdWqku03exdo0"
              id="inline-HGqz9DiUdWqku03exdo0"
              data-layout="{'id':'INLINE'}"
              data-trigger-type="alwaysShow"
              data-trigger-value=""
              data-activation-type="alwaysActivated"
              data-activation-value=""
              data-deactivation-type="neverDeactivate"
              data-deactivation-value=""
              data-form-name="Contact Form [KS]"
              data-height="712"
              data-layout-iframe-id="inline-HGqz9DiUdWqku03exdo0"
              data-form-id="HGqz9DiUdWqku03exdo0"
              title="Contact Form [KS]"
              loading="lazy"
              style="width:100%;min-height:712px;border:none;border-radius:12px;background:transparent;display:block;"
            ></iframe>
          </div>
        </div>

        <!-- Info column -->
        <aside class="lg:col-span-5 lg:sticky lg:top-28" data-reveal>
          <div class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8">
            <h2 class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-500">
              Get in Touch
            </h2>

            <dl class="mt-6 space-y-6">
              <div>
                <dt class="text-xs uppercase tracking-[0.18em] text-muted">Phone</dt>
                <dd class="mt-1 text-base md:text-lg">
                  <a
                    href={`tel:${businessInfo.phoneTel}`}
                    class="text-white hover:text-brand-500 font-semibold"
                  >
                    {businessInfo.phone}
                  </a>
                </dd>
              </div>

              <div>
                <dt class="text-xs uppercase tracking-[0.18em] text-muted">Email</dt>
                <dd class="mt-1 text-base md:text-lg">
                  <a
                    href={`mailto:${businessInfo.email}`}
                    class="text-white hover:text-brand-500 font-semibold"
                  >
                    {businessInfo.email}
                  </a>
                </dd>
              </div>

              <div>
                <dt class="text-xs uppercase tracking-[0.18em] text-muted">Office</dt>
                <dd class="mt-1 text-sm md:text-base text-ink not-italic">
                  <address class="not-italic">
                    {businessInfo.address.street}<br />
                    {businessInfo.address.city}, {businessInfo.address.region}{' '}
                    {businessInfo.address.postal}
                  </address>
                </dd>
              </div>

              <div>
                <dt class="text-xs uppercase tracking-[0.18em] text-muted">Hours</dt>
                <dd class="mt-1 text-sm md:text-base text-ink">
                  Monday – Friday<br />
                  9:00 AM – 5:00 PM EST
                  <p class="mt-2 text-xs text-muted">Closed weekends and holidays.</p>
                </dd>
              </div>
            </dl>

            <div class="mt-7 pt-6 border-t border-white/10 flex flex-wrap items-center gap-3">
              <a
                href={businessInfo.social.facebook}
                rel="noopener"
                aria-label="Killerspots on Facebook"
                class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-ink hover:border-brand-500 hover:text-white transition-colors"
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path
                    d="M13.5 21v-7.5h2.5l.4-3h-2.9V8.6c0-.9.3-1.5 1.5-1.5H16.5V4.4C16.2 4.4 15 4.3 13.7 4.3c-2.5 0-4.2 1.5-4.2 4.3V10.5H7v3h2.5V21h4z"
                  />
                </svg>
              </a>
              <a
                href={businessInfo.social.linkedin}
                rel="noopener"
                aria-label="Killerspots on LinkedIn"
                class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-ink hover:border-brand-500 hover:text-white transition-colors"
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path
                    d="M4.98 3.5c0 1.4-1.1 2.5-2.5 2.5S0 4.9 0 3.5 1.1 1 2.5 1s2.48 1.1 2.48 2.5zM0 8h5v15H0V8zm7.5 0h4.78v2.05h.07c.66-1.25 2.28-2.55 4.7-2.55 5 0 5.95 3.3 5.95 7.6V23h-5v-7.4c0-1.77-.03-4.05-2.46-4.05-2.46 0-2.84 1.92-2.84 3.92V23h-5V8z"
                  />
                </svg>
              </a>
              <a
                href={businessInfo.social.instagram}
                rel="noopener"
                aria-label="Killerspots on Instagram"
                class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-ink hover:border-brand-500 hover:text-white transition-colors"
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path
                    d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.3 1 .4 2.2.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1.2-.2 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .3-2.2.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2-.1-1.8-.2-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.3-1-.4-2.2-.1-1.2-.1-1.6-.1-4.8s0-3.6.1-4.8c.1-1.2.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.3 2.2-.4 1.2-.1 1.6-.1 4.8-.1zM12 0C8.7 0 8.3 0 7.1.1 5.8.1 5 .3 4.2.6 3.4.9 2.7 1.3 2 2c-.7.7-1.1 1.4-1.4 2.2-.3.8-.5 1.6-.6 2.9C0 8.3 0 8.7 0 12s0 3.7.1 4.9c.1 1.3.3 2.1.6 2.9.3.8.7 1.5 1.4 2.2.7.7 1.4 1.1 2.2 1.4.8.3 1.6.5 2.9.6 1.2.1 1.6.1 4.9.1s3.7 0 4.9-.1c1.3-.1 2.1-.3 2.9-.6.8-.3 1.5-.7 2.2-1.4.7-.7 1.1-1.4 1.4-2.2.3-.8.5-1.6.6-2.9.1-1.2.1-1.6.1-4.9s0-3.7-.1-4.9c-.1-1.3-.3-2.1-.6-2.9-.3-.8-.7-1.5-1.4-2.2-.7-.7-1.4-1.1-2.2-1.4-.8-.3-1.6-.5-2.9-.6C15.7 0 15.3 0 12 0zm0 5.8a6.2 6.2 0 1 0 0 12.4 6.2 6.2 0 0 0 0-12.4zm0 10.2a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-10.5a1.4 1.4 0 1 1-2.9 0 1.4 1.4 0 0 1 2.9 0z"
                  />
                </svg>
              </a>
            </div>
          </div>

          <!-- Quick start cards -->
          <div class="mt-6 rounded-2xl border border-white/10 bg-deep/60 p-7 md:p-8">
            <h3 class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-500">
              Quick-Start Options
            </h3>
            <ul class="mt-5 space-y-4">
              {
                quickStart.map((q) => (
                  <li>
                    <a
                      href={q.href}
                      class="group block rounded-xl border border-white/10 bg-surface p-5 hover:border-brand-500/40 transition-colors"
                    >
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <div class="text-sm md:text-base font-semibold text-white">
                            {q.title}
                          </div>
                          <p class="mt-1 text-xs md:text-sm text-muted leading-relaxed">
                            {q.body}
                          </p>
                          <div class="mt-2 text-[11px] uppercase tracking-[0.18em] text-brand-500 group-hover:text-brand-300">
                            {q.label} →
                          </div>
                        </div>
                      </div>
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- WHAT HAPPENS NEXT -->
  <section class="bg-deep">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">What Happens Next</span>
        <h2 class="section-headline mt-5">A real human follow-up. Not a chatbot.</h2>
      </div>

      <ol class="grid md:grid-cols-3 gap-5 md:gap-6">
        {
          whatHappensNext.map((s) => (
            <li
              data-reveal
              class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"
            >
              <div class="text-xs uppercase tracking-[0.22em] text-brand-500 font-bold">
                Step {s.step}
              </div>
              <h3 class="mt-3 text-xl font-semibold text-white">{s.title}</h3>
              <p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 max-w-3xl" data-reveal>
        <span class="eyebrow">FAQ</span>
        <h2 class="section-headline mt-5">Common questions before you reach out.</h2>
      </div>

      <div class="max-w-3xl space-y-3" data-reveal>
        {
          faqs.map((f) => (
            <details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5">
              <summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4">
                <span>{f.q}</span>
                <svg
                  class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M10 4v12M4 10h12"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                  />
                </svg>
              </summary>
              <p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- MAP -->
  <section class="bg-deep">
    <div class="container-page py-20 md:py-28">
      <div class="mb-10 max-w-3xl" data-reveal>
        <span class="eyebrow">Our Office</span>
        <h2 class="section-headline mt-5">Cincinnati, Ohio.</h2>
        <p class="mt-4 text-base md:text-lg text-muted leading-relaxed">
          {businessInfo.address.street}, {businessInfo.address.city},{' '}
          {businessInfo.address.region} {businessInfo.address.postal}
        </p>
      </div>

      <div
        data-reveal
        class="rounded-2xl border border-white/10 overflow-hidden bg-surface"
      >
        <iframe
          src={`https://www.google.com/maps?q=${mapsQuery}&output=embed`}
          title="Killerspots Agency office on Google Maps"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
          style="width:100%;height:420px;border:0;display:block;filter:invert(0.92) hue-rotate(180deg) saturate(0.7);"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- GHL form embed loader (last, so the iframe is in the DOM) -->
  <script
    is:inline
    src="https://agency.killerspots.com/js/form_embed.js"></script>
</BaseLayout>
