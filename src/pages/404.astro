---
import BaseLayout from '../layouts/BaseLayout.astro';
import { businessInfo } from '../data/navigation';
---

<BaseLayout
  title="404 — Your Page Is in Another Castle | Killerspots Agency"
  description="The page you were looking for doesn't exist. Let's get you back to building campaigns that actually convert."
  noindex={true}
>
  <section class="relative overflow-hidden bg-canvas">
    <!-- Ambient red glow -->
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div>
      <div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/10 blur-[160px]"></div>
    </div>

    <div class="container-page pt-24 md:pt-32 pb-20 md:pb-28">
      <!-- Top: headline + subhead -->
      <div class="max-w-4xl mx-auto text-center" data-reveal>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-500">
          Error 404
        </p>
        <h1 class="hero-headline mt-5">
          Your page is in <span class="text-brand-500">another castle.</span>
        </h1>
        <p class="mt-8 text-xl md:text-2xl text-ink max-w-2xl mx-auto leading-snug">
          We hate broken funnels too. This URL is a dead-end — but your next campaign doesn't have to be.
        </p>
      </div>

      <!-- Middle: Mario GIF, smaller -->
      <div class="relative mt-12 md:mt-16 max-w-2xl mx-auto" data-reveal data-reveal-from="scale">
        <div class="relative rounded-3xl border border-white/10 bg-deep p-3 md:p-4 overflow-hidden">
          <div
            aria-hidden="true"
            class="absolute inset-0 opacity-30"
            style="background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 32px 32px;"
          ></div>

          <img
            src="https://assets.cdn.filesafe.space/E3Rv5E7JpJH3jrDtAbaE/media/69f78594086be1f079d30309.gif"
            alt="Mario running through a level still searching for the Princess — and your page"
            loading="eager"
            decoding="async"
            class="relative block w-full h-auto rounded-2xl shadow-[0_30px_80px_-20px_rgba(0,0,0,0.6)]"
            style="image-rendering: pixelated;"
          />

          <p class="relative mt-4 text-center text-xs uppercase tracking-[0.22em] text-muted">
            Mario's been searching since 1985. Your leads shouldn't.
          </p>
        </div>
      </div>

      <!-- Below: bullet list + CTAs -->
      <div class="mt-12 md:mt-16 max-w-4xl mx-auto text-center" data-reveal>
        <ul class="space-y-3 text-base md:text-lg text-muted text-left max-w-2xl mx-auto">
          <li class="flex items-start gap-3">
            <span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-500 shrink-0"></span>
            <span>Looking for our work? Check out <a class="text-white underline decoration-brand-500/50 underline-offset-4 hover:decoration-brand-500" href="/case-studies">case studies</a>.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-500 shrink-0"></span>
            <span>Need a service? Browse <a class="text-white underline decoration-brand-500/50 underline-offset-4 hover:decoration-brand-500" href="/services/audio-production">audio</a>, <a class="text-white underline decoration-brand-500/50 underline-offset-4 hover:decoration-brand-500" href="/services/video-tv">video</a>, <a class="text-white underline decoration-brand-500/50 underline-offset-4 hover:decoration-brand-500" href="/services/seo-aio">SEO</a>, or <a class="text-white underline decoration-brand-500/50 underline-offset-4 hover:decoration-brand-500" href="/services/ppc">PPC</a>.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-500 shrink-0"></span>
            <span>Want a free SEO audit? Try <a class="text-white underline decoration-brand-500/50 underline-offset-4 hover:decoration-brand-500" href="/services/seo-aio/killerseox-audit">KillerSEOx</a>.</span>
          </li>
        </ul>

        <div class="mt-10 flex flex-wrap justify-center items-center gap-3">
          <a href="/" class="btn btn-primary magnetic">Back to Home</a>
          <a href="/contact" class="btn btn-ghost magnetic">Talk to a Human</a>
          <a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost magnetic">
            Call {businessInfo.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom: re-engagement ribbon -->
  <section class="bg-deep border-t border-white/5">
    <div class="container-page py-12 md:py-16">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <p class="text-base md:text-lg text-ink leading-relaxed max-w-2xl">
          <span class="text-brand-500 font-semibold">Pro tip:</span>
          while you're here, we run free 60-second SEO audits — see exactly where your real site is leaking traffic.
        </p>
        <a href="/services/seo-aio/killerseox-audit" class="btn btn-primary magnetic shrink-0">
          Run Free Audit
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
