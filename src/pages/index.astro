        </div>

        <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm">
          <a href="/case-studies" class="text-ink hover:text-white">
            See our case studies →
          </a>
          <a href="/blog" class="text-ink hover:text-white">Read our blog →</a>
          <a href="/case-studies" class="text-ink hover:text-white">
            Check out our work →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
