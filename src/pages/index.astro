          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/contact" class="btn btn-primary magnetic">Book my strategy call</a>
            <a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">
              Call {businessInfo.phone}
            </a>
