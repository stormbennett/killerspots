    body: 'See your full sales pipeline at a glance. Know exactly where every lead stands.',
  },
  {
    title: 'Deal Closed & ROI Tracking',
    body: 'Track which campaigns, keywords, and traffic sources actually close deals. Stop guessing.',
  },
  {
    title: 'White-Label Option',
    body: 'Agencies and platforms can rebrand LeadConnector and resell under their own name.',
  },
];

type Stat = {
  value: string;
  label: string;
  // Optional: animate the number portion. The display string is `prefix + counter + suffix`.
  // Once the user fills in real numbers, swap to e.g. { counter: 1200, suffix: '+', value: '1.2K+' }.
  counter?: number;
  prefix?: string;
  suffix?: string;
  decimals?: number;
  accent?: 'arrow-up';
};

const heroStats: Stat[] = [
  { value: '5,750+', label: 'Clients served nationwide', counter: 5750, suffix: '+' },
  { value: '47%', label: 'Avg. lead increase, first 90 days', counter: 47, suffix: '%', accent: 'arrow-up' },
  { value: '6×', label: 'Telly Award winner', counter: 6, suffix: '×' },
];

const seoxFeatures = [
