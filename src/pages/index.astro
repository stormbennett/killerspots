  <script is:inline>
    var AUDIT_API_URL = 'https://killerseox-audit.killerspots.workers.dev/audit';
    var auditReportUrl = null;
    function ksxNextStep(currentStep) {
      if (currentStep === 1) {
        var urlInput = document.getElementById('ksxUrl');
        var url = urlInput.value.trim();
        if (!url) {
          urlInput.classList.add('ksx-error');
          urlInput.focus();
          return;
        }
        if (!url.match(/^https?:\/\//)) url = 'https://' + url;
        if (!url.match(/\.[a-z]{2,}/i)) {
          urlInput.classList.add('ksx-error');
          urlInput.focus();
          return;
        }
        urlInput.value = url;
        document.getElementById('ksxUrlChip').textContent =
          '🔗 ' + url.replace(/^https?:\/\//, '');
        document.getElementById('ksxFormStep1').classList.remove('active');
        document.getElementById('ksxFormStep2').classList.add('active');
        document.getElementById('ksxStep1Ind').classList.remove('active');
        document.getElementById('ksxStep1Ind').classList.add('completed');
        document.getElementById('ksxStep2Ind').classList.add('active');
      } else if (currentStep === 2) {
        var fields = ['ksxFirst', 'ksxLast', 'ksxEmail', 'ksxPhone'];
        var hasError = false;
        fields.forEach(function (id) {
          var el = document.getElementById(id);
          el.classList.remove('ksx-error');
          if (!el.value.trim()) {
            el.classList.add('ksx-error');
            hasError = true;
          }
        });
        if (hasError) return;
        var email = document.getElementById('ksxEmail').value.trim();
        if (email.indexOf('@') === -1 || email.indexOf('.') === -1) {
          document.getElementById('ksxEmail').classList.add('ksx-error');
          return;
        }
        document.getElementById('ksxSubmitBtn').disabled = true;
        document.getElementById('ksxSubmitBtn').textContent = 'Processing...';
        document.getElementById('ksxFormStep2').classList.remove('active');
        document.getElementById('ksxFormStep3').classList.add('active');
        document.getElementById('ksxStep2Ind').classList.remove('active');
        document.getElementById('ksxStep2Ind').classList.add('completed');
        document.getElementById('ksxStep3Ind').classList.add('active');
        var payload = {
          url: document.getElementById('ksxUrl').value.trim(),
          first_name: document.getElementById('ksxFirst').value.trim(),
          last_name: document.getElementById('ksxLast').value.trim(),
          email: email,
          phone: document.getElementById('ksxPhone').value.trim(),
          company_name: document.getElementById('ksxBiz').value.trim(),
        };
        ksxAnimateScan();
        ksxRunAudit(payload);
      }
    }
    function ksxRunAudit(payload) {
      fetch(AUDIT_API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
        .then(function (response) {
          if (!response.ok) throw new Error('Audit failed');
          return response.json();
        })
        .then(function (data) {
          if (data.success && data.reportUrl) {
            auditReportUrl = data.reportUrl;
          }
        })
        .catch(function (err) {
          console.error('Audit error:', err);
          auditReportUrl = null;
        });
    }
    function ksxAnimateScan() {
      var checks = ['ksxChk1', 'ksxChk2', 'ksxChk3', 'ksxChk4', 'ksxChk5', 'ksxChk6'];
      var progress = document.getElementById('ksxProgress');
      var messages = [
        'Checking SSL & security...',
        'Analyzing page speed metrics...',
        'Auditing on-page SEO elements...',
        'Scanning for technical issues...',
        'Measuring AI search visibility...',
        'Generating your personalized report...',
      ];
      var step = 0;
      function advanceCheck() {
        if (step > 0) {
          var prev = document.getElementById(checks[step - 1]);
          prev.classList.remove('active');
          prev.classList.add('done');
          prev.querySelector('.ksx-ci-icon').textContent = '✓';
        }
        if (step < checks.length) {
          document.getElementById(checks[step]).classList.add('active');
          document.getElementById('ksxLoadingText').textContent = messages[step];
          progress.style.width = ((step + 1) / checks.length) * 100 + '%';
          step++;
          setTimeout(advanceCheck, 2500 + Math.random() * 1500);
        } else {
          progress.style.width = '100%';
          document.getElementById('ksxLoadingText').textContent = 'Your report is ready!';
          document.getElementById('ksxLoadingSub').textContent = 'Redirecting to your results...';
          document.querySelector('.ksx-spinner').style.display = 'none';
          setTimeout(function () {
            if (auditReportUrl) {
              window.location.href = auditReportUrl;
              document.getElementById('ksxLoadingSub').innerHTML =
                'Redirecting now... <a href="' +
                auditReportUrl +
                '" target="_blank" style="color:#2D6CCA;font-weight:600;">Click here</a> if it didn\'t open.';
            } else {
              var pollCount = 0;
              var pollInterval = setInterval(function () {
                pollCount++;
                if (auditReportUrl) {
                  clearInterval(pollInterval);
                  window.location.href = auditReportUrl;
                  document.getElementById('ksxLoadingSub').innerHTML =
                    'Redirecting now... <a href="' +
                    auditReportUrl +
                    '" target="_blank" style="color:#2D6CCA;font-weight:600;">Click here</a> if it didn\'t open.';
                } else if (pollCount > 30) {
                  clearInterval(pollInterval);
                  document.getElementById('ksxLoadingText').textContent =
                    'Your audit is complete!';
                  document.getElementById('ksxLoadingSub').textContent =
                    'Your full report has been sent to your email.';
                }
              }, 1000);
            }
          }, 1000);
        }
      }
      advanceCheck();
    }
    document.querySelectorAll('.ksx-audit-widget input').forEach(function (input) {
      input.addEventListener('input', function () {
        this.classList.remove('ksx-error');
      });
      input.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          var step = this.closest('.ksx-form-step');
          if (step.id === 'ksxFormStep1') ksxNextStep(1);
          else if (step.id === 'ksxFormStep2') ksxNextStep(2);
        }
      });
    });
  </script>

