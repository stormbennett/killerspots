const homeFaqs = [
  {
    q: 'What does Killerspots actually do?',
    a: 'Three things, all under one roof: Technology (LeadConnector — our managed CRM), Advertising (PPC, social, CTV, plus traditional TV and radio), and Marketing (SEO, AI search visibility, social media management, jingles, video, and content). Most clients run an integrated marketing plan that combines all three.',
  },
  {
    q: 'What size businesses do you work with?',
    a: 'Most of our clients are doing $250K–$50M in annual revenue — local and regional businesses, multi-location brands, law firms, radio station groups, and white-label agency partners. We size every engagement to your stage, not a one-size-fits-all package.',
  },
  {
    q: 'Do you require long-term contracts?',
    a: 'Standard engagement is a 6-month minimum so the work has time to compound, then month-to-month. We don\'t lock you into multi-year deals — we earn the next month every month.',
  },
  {
    q: 'Do you work with clients outside Cincinnati?',
    a: 'Yes. Our office and studio are in Cincinnati, but most of our clients are spread across the U.S. — every state and a few internationally. We work remotely the same way we work locally.',
  },
  {
    q: 'How fast can we launch a campaign?',
    a: 'Audio production: 2–3 days. Paid ads: 1 week from kickoff. SEO compounds over 90–180 days. Websites: 4–8 weeks. We set timelines up front so promised dates hold.',
  },
  {
    q: 'Why don\'t you show pricing on the website?',
    a: 'Every plan is sized to the business — your market, your goals, your stage. Get a quote and we\'ll come back with something specific and honest. If we\'re not the right fit we\'ll tell you that too.',
  },
];

const homeFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const speakable = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://killerspots.com/#webpage',
  url: 'https://killerspots.com/',
  name: meta.title,
  description: meta.description,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#hero-headline', '#hero-subhead'],
  },
  isPartOf: { '@id': 'https://killerspots.com/#localbusiness' },
};

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://killerspots.com/',
    },
  ],
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  schema={[speakable, breadcrumbs, homeFaqSchema]}
>
  <!-- ======================================================== -->
  <!-- SECTION 1: HERO — Vimeo background + headline overlay      -->
  <!-- ======================================================== -->
  <section class="hero-video cursor-glow relative overflow-hidden bg-canvas">
    <!-- Video layer (scroll-scrubbed via .hero-scroll-bg) -->
    <div class="hero-video__bg hero-scroll-bg" aria-hidden="true">
      <iframe
        src="https://player.vimeo.com/video/1175215931?background=1&autopause=0&app_id=58479"
        title="Killerspots — 2026 Reel"
        loading="eager"
        allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        tabindex="-1"
      ></iframe>
    </div>

    <!-- Dark + brand-tinted overlays for legibility (scrim deepens on scroll) -->
    <div
      aria-hidden="true"
      class="hero-video__scrim hero-scroll-scrim absolute inset-0"
    >
      <div
        class="absolute inset-0 bg-[linear-gradient(180deg,_rgba(15,20,25,0.55)_0%,_rgba(15,20,25,0.78)_55%,_rgba(15,20,25,0.95)_100%)]"
      >
      </div>
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_15%_20%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"
      >
      </div>
    </div>

    <div
      class="relative container-page pt-28 md:pt-36 lg:pt-44 pb-28 md:pb-36 lg:pb-44"
    >
      <!-- hero-scroll-text drives translateY on scroll for cinematic parallax -->
      <div class="hero-scroll-text max-w-5xl">
        <h1
          id="hero-headline"
          class="hero-headline drop-shadow-[0_4px_24px_rgba(0,0,0,0.5)]"
        >
          {
            'Your Full-Service Marketing Agency For'.split(' ').map((w, i) => (
              <span class="hero-word" style={`--i:${i}`}>
                <span>{w}</span>
              </span>
            ))
          }
          {' '}
          {
            'Creative, Digital & AI Solutions'.split(' ').map((w, i) => (
              <span class="hero-word" style={`--i:${i + 5}`}>
                <span class="text-brand-500">{w}</span>
              </span>
            ))
          }
        </h1>
        <p
          id="hero-subhead"
          class="mt-8 md:mt-10 text-xl md:text-2xl text-white/90 max-w-4xl leading-snug drop-shadow-[0_2px_16px_rgba(0,0,0,0.5)]"
        >
          Killerspots combines award-winning creative production—jingles, TV, and radio
          commercials—with full-stack digital marketing (SEO, PPC, CTV) and AI-powered CRM
          solutions. We're the only agency that brings it all together under one roof.
        </p>

        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3">
          <a
            href="/services/seo-aio/killerseox-audit"
            class="btn btn-primary magnetic"
          >
            Get Your Free Marketing Audit
          </a>
          <a
            href="https://vimeo.com/1175215931"
            rel="noopener"
            target="_blank"
            class="btn btn-ghost magnetic"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 16 16"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M5 3.5v9l7-4.5z" />
            </svg>
            Watch the Reel
          </a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero-video {
      isolation: isolate;
    }
    .hero-video__bg {
      position: absolute;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 0;
    }
    .hero-video__bg iframe {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 100vw;
      height: 56.25vw; /* 16:9 of 100vw */
      min-height: 100%;
      min-width: 177.7778vh; /* 16:9 of 100vh */
      transform: translate(-50%, -50%);
      border: 0;
    }
    .hero-video__scrim {
      z-index: 1;
      pointer-events: none;
    }
    .hero-video > .container-page {
      z-index: 2;
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-video__bg iframe {
        display: none;
      }
      .hero-video__bg {
        background: linear-gradient(135deg, #1a1f2e 0%, #0f1419 100%);
      }
    }
  </style>

  <!-- ======================================================== -->
  <!-- TRUST BAND — pills + supporting copy below the hero       -->
  <!-- ======================================================== -->
  <section class="bg-deep">
    <div class="container-page py-14 md:py-20 lg:py-24">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="flex flex-wrap items-center gap-6 md:gap-8">
          {
            trustBadges.map((badge) => (
              <img
                src={badge.src}
                alt={badge.name.startsWith('Trust Badge') ? '' : `${badge.name} logo`}
                loading="lazy"
                decoding="async"
                class="trust-badge"
              />
            ))
          }
        </div>
        <p class="text-base md:text-lg text-muted leading-relaxed">
          Since 1999, we've helped home service contractors, law firms, small businesses,
          radio station groups, and white-label partners dominate their markets. Proven results.
        </p>
      </div>
    </div>
  </section>

  <!-- ======================================================== -->
  <!-- CLIENT LOGOS MARQUEE                                       -->
  <!-- ======================================================== -->
  <section class="bg-canvas border-t border-b border-white/5">
    <div class="container-page pt-12 md:pt-14 pb-4">
      <p
        class="text-center text-xs uppercase tracking-[0.22em] text-muted"
        data-reveal
      >
        Trusted by brands across every industry
      </p>
    </div>

    <div class="logos-marquee py-8 md:py-10" aria-label="Client logos">
      <div class="logos-track">
        {
          clientLogos.map((logo) => (
            <img
              src={logo.src}
              alt={logo.name.startsWith('Unknown') ? '' : `${logo.name} logo`}
              loading="lazy"
              decoding="async"
              class="logos-item"
            />
          ))
        }
        {
          /* duplicate set for seamless loop */
          clientLogos.map((logo) => (
            <img
              src={logo.src}
              alt=""
