---
import BaseLayout from '../layouts/BaseLayout.astro';
import { businessInfo } from '../data/navigation';

const meta = {
  title: 'Terms of Service | Killerspots Agency',
  description: 'Terms of service for Killerspots Agency website and services. Acceptable use, intellectual property, liability, and governing law.',
};

const lastUpdated = 'January 2026';

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' },
    { '@type': 'ListItem', position: 2, name: 'Terms of Service', item: 'https://killerspots.com/terms' },
  ],
};
---

<BaseLayout title={meta.title} description={meta.description} schema={[breadcrumbs]}>
  <section class="relative overflow-hidden bg-canvas">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div>
    </div>
    <div class="container-page pt-24 md:pt-32 pb-12 md:pb-16">
      <div class="max-w-3xl">
        <span class="eyebrow">Legal</span>
        <h1 class="hero-headline mt-5" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">Terms of Service</h1>
        <p class="mt-6 text-base md:text-lg text-muted">Last updated: {lastUpdated}</p>
      </div>
    </div>
  </section>

  <section class="bg-canvas">
    <div class="container-page py-12 md:py-16">
      <div class="prose-content max-w-3xl space-y-8 text-base md:text-lg text-ink leading-relaxed">
        <p>
          These Terms of Service ("Terms") govern your access to and use of the
          {businessInfo.name} website and services. By using our site or engaging our
          services, you agree to these Terms.
        </p>

        <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight pt-6">Use of the Website</h2>
        <p>
          You agree to use our website only for lawful purposes and in a way that does not
          infringe on the rights of others or restrict their use of the site. Prohibited
          activities include scraping, reverse-engineering, distributing malware, and
          attempting to gain unauthorized access to our systems.
        </p>

        <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight pt-6">Intellectual Property</h2>
        <p>
          All content on this website — including logos, text, graphics, photography,
          video, audio, and software — is owned by {businessInfo.name} or its licensors and
          protected by U.S. and international copyright, trademark, and other intellectual
          property laws.
        </p>
        <p>
          You may view, download, and share content for personal, non-commercial use only.
          Reproduction, modification, or commercial use without our written permission is
          prohibited.
        </p>

        <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight pt-6">Service Engagements</h2>
        <p>
          When you engage our services, the specific terms of that engagement (deliverables,
          timelines, fees, IP transfer, confidentiality) are governed by a separate Services
          Agreement, Statement of Work, or Master Services Agreement signed by both parties.
          These Terms govern only your use of our public website.
        </p>

        <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight pt-6">Third-Party Links + Services</h2>
        <p>
          Our site links to third-party websites and integrates with third-party services
          (Vimeo, SoundCloud, Cloudflare, Go High Level / LeadConnector, Google Analytics,
          TrustIndex, etc.). We are not responsible for the content, privacy practices, or
          terms of those third parties.
        </p>

        <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight pt-6">Disclaimers</h2>
        <p>
          The website is provided "as is" without warranties of any kind, either express or
          implied. We do not guarantee uninterrupted, error-free, or secure access. We make
          no warranty regarding the accuracy or completeness of website content.
        </p>
        <p>
          Marketing claims, results metrics, and case study outcomes shown on this site are
          examples of past performance and are not guarantees of future results. Your
          marketing outcomes will vary based on your industry, market, budget, and
          execution.
        </p>

        <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight pt-6">Limitation of Liability</h2>
        <p>
          To the fullest extent permitted by law, {businessInfo.name} and its affiliates are
          not liable for any indirect, incidental, consequential, or punitive damages
          arising from your use of the website or services. Our total liability in any
          claim is limited to the amount you paid to us in the 12 months preceding the
          claim (or $100, whichever is greater) for use of the website itself, with separate
          terms applying to paid service engagements.
        </p>

        <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight pt-6">Indemnification</h2>
        <p>
          You agree to indemnify and hold harmless {businessInfo.name} from any claims,
          damages, or expenses arising from your violation of these Terms or misuse of the
          website.
        </p>

        <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight pt-6">Governing Law</h2>
        <p>
          These Terms are governed by the laws of the State of Ohio, USA, without regard to
          conflict-of-law principles. Any dispute arising from these Terms or your use of
          the site shall be resolved in the state or federal courts located in Hamilton
          County, Ohio.
        </p>

        <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight pt-6">Changes to These Terms</h2>
        <p>
          We may revise these Terms at any time by updating this page. The "Last updated"
          date at the top reflects the most recent revision. Continued use of our website
          after changes constitutes acceptance of the updated Terms.
        </p>

        <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight pt-6">Contact</h2>
        <p>
          Questions about these Terms? Reach us at:
        </p>
        <address class="not-italic">
          {businessInfo.name}<br />
          {businessInfo.address.street}<br />
          {businessInfo.address.city}, {businessInfo.address.region} {businessInfo.address.postal}<br />
          <a href={`mailto:${businessInfo.email}`} class="text-brand-500 hover:text-brand-300">{businessInfo.email}</a><br />
          <a href={`tel:${businessInfo.phoneTel}`} class="text-brand-500 hover:text-brand-300">{businessInfo.phone}</a>
        </address>

        <p class="text-sm text-muted pt-8 border-t border-white/10">
          <strong>Note:</strong> These terms are provided as a general template. Consult an attorney to ensure full enforceability and compliance with applicable laws for your specific business and jurisdiction.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
