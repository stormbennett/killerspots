---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HeroVideo from '../../../components/HeroVideo.astro';
import { businessInfo } from '../../../data/navigation';

const heroVideoUrl =
  'https://player.vimeo.com/video/1103464051?h=98ea511891&background=1&autopause=0&app_id=58479';

const meta = {
  title: 'Restaurant, Bar & Nightclub Marketing | Killerspots',
  description: 'Marketing for restaurants, bars, nightclubs, and live-event venues. Social-led campaigns, custom jingles, paid search, and AI-powered booking + reservations.',
  ogTitle: 'Restaurant, Bar & Nightclub Marketing — Built for Foot Traffic & Bookings | Killerspots',
  ogDescription: 'Social-first restaurant, bar, and nightclub marketing — short-form video, jingles, geo-targeted ads, and 24/7 AI reservations.',
};

const trustPills = ['Hospitality Specialists', 'Social-First Creative', 'Foot-Traffic + Bookings'];

const subIndustries = [
  { title: 'Events', href: '/industries/restaurants-bars-nightclubs/events', body: 'Private events, corporate buyouts, brand activations — partnership with our sister company Des Vu Experiences.' },
];

const painPoints = [
  { title: 'Short-Form Video Is Now Table Stakes', body: 'Reels and TikToks drive more foot traffic than any other channel for restaurants/bars right now. Most agencies still post static menu shots. We shoot native short-form weekly.' },
  { title: 'Reservation Friction Kills Conversion', body: 'A guest who can\'t book in 30 seconds finds another spot. AI bots + integrated reservation systems mean booking happens inside the conversation — not after a callback.' },
  { title: 'Reviews Drive Local Discovery', body: 'TripAdvisor, Google, Yelp, OpenTable — every review platform feeds local search and influences the diner before they ever click "directions." Auto-request reviews after every visit.' },
  { title: 'Slow Nights Need Their Own Marketing', body: 'Friday will sell itself. Tuesday won\'t. We build off-peak campaigns — happy hour, ladies\' night, Industry Monday, prix fixe — that smooth the weekly revenue curve.' },
];

const services = [
  { title: 'Short-Form Video + Reels', body: 'Native TikTok/Reels/Shorts shot inside your venue — chef talent, menu reveals, behind-the-bar, Tuesday energy. The format that actually drives foot traffic.', href: '/services/social-media/short-form-video' },
  { title: 'Local SEO + Google Business Profile', body: 'Rank for "[cuisine] near me," "best [neighborhood] bars," "happy hour [city]," and the long-tail terms that drive walk-ins and reservations.', href: '/services/seo-aio/seo' },
  { title: 'Geo-Fenced Paid Social', body: 'Meta, TikTok, and YouTube ads geo-fenced to drive-by neighborhoods, hotels, event venues, and competitor parking lots.', href: '/services/digital-ads/geo-fencing' },
  { title: 'Custom Jingles + Radio', body: 'A jingle that becomes the sound of your concept. Cheap brand asset that compounds over years on radio + on-hold + social.', href: '/services/audio-production/custom-jingles' },
  { title: 'AI Reservations + Bookings', body: '24/7 AI bot handles reservations, party-of-X requests, allergy questions, and event inquiries — even Sunday at 2 AM.', href: '/leadconnector' },
  { title: 'Reviews + Reputation', body: 'Auto-request Google, TripAdvisor, and Yelp reviews after every visit. Compound 4.7+ star ratings into local search dominance.', href: '/services/seo-aio' },
];

const faqs = [
  { q: 'Do you handle restaurants AND bars AND nightclubs?', a: 'Yes — they share the same fundamentals (social-first creative, foot traffic, reviews, reservations) but each has its own nuances. Restaurants lean on menu + chef storytelling, bars on atmosphere + happy hour, nightclubs on talent + bottle service. We tune the channel mix per concept.' },
  { q: 'Can you handle multi-location restaurant groups?', a: 'Yes. Location-specific landing pages, location-specific Google Business Profiles, location-specific Reels/TikTok content. Common for 2–25 location groups.' },
  { q: 'Do you do private events / buyouts marketing?', a: 'Yes — through our sister company Des Vu Experiences. Corporate buyouts, brand activations, weddings, holiday parties. See our Events page for details.' },
  { q: 'How do you measure success?', a: 'Reservations, walk-ins (where measurable via foot traffic data), review velocity, and revenue growth — never just impressions.' },
  { q: 'Can you shoot creative inside our venue?', a: 'Yes. We have a Cincinnati production studio plus mobile crews for in-venue shoots. Most short-form social campaigns get monthly or weekly shoot days at your locations.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/industries/restaurants-bars-nightclubs#webpage', url: 'https://killerspots.com/industries/restaurants-bars-nightclubs', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Restaurants, Bars & Nightclubs', item: 'https://killerspots.com/industries/restaurants-bars-nightclubs' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <HeroVideo videoUrl={heroVideoUrl} videoTitle="Killerspots — Hospitality Reel">
    <div class="max-w-5xl">
      <span class="eyebrow">Restaurants, Bars & Nightclubs</span>
      <h1 id="hero-headline" class="hero-headline mt-5">Marketing built for <span class="text-brand-500">full tables every night.</span></h1>
      <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-white/90 max-w-4xl leading-snug">Social-first creative, custom jingles, geo-targeted paid, and 24/7 AI reservations for restaurants, bars, nightclubs, and live-event venues. Foot traffic + bookings reported.</p>
      <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href="#sub-industries" class="btn btn-ghost magnetic">See Our Specialties</a></div>
    </div>
  </HeroVideo>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">25+ years marketing in hospitality. Through Restaurant Week, COVID, ghost kitchens, and the rise of TikTok-driven foot traffic. We've seen the cycles.</p></div></div></section>

  <section id="sub-industries" class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">Specialties</span><h2 class="section-headline mt-5">Beyond the day-to-day, we also do this.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{subIndustries.map((s) => (<li data-reveal><a href={s.href} class="card-tile group"><h3 class="text-lg md:text-xl font-semibold text-white">{s.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{s.body}</p><div class="mt-6 inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-brand-500 group-hover:text-brand-300">Explore<svg class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg></div></a></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">The Real Problems</span><h2 class="section-headline mt-5">Where most hospitality marketing falls flat.</h2></div><ul class="grid md:grid-cols-2 gap-5 md:gap-6">{painPoints.map((p) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"><h3 class="text-lg md:text-xl font-semibold text-white">{p.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{p.body}</p></li>))}</ul></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Run</span><h2 class="section-headline mt-5">A hospitality channel mix that drives full rooms.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{services.map((s) => (<li data-reveal><a href={s.href} class="card-tile group"><h3 class="text-lg md:text-xl font-semibold text-white">{s.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{s.body}</p><div class="mt-6 inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-brand-500 group-hover:text-brand-300">Explore<svg class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg></div></a></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Hospitality marketing questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Let's Talk</span><h2 class="section-headline mt-5">Tell us your concept. We'll fill the room.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We'll review your concept, your weekly revenue curve, your competition, and your current marketing.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost magnetic">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
