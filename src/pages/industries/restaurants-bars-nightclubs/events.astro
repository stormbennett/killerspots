---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HeroVideo from '../../../components/HeroVideo.astro';
import { businessInfo } from '../../../data/navigation';

const heroVideoUrl =
  'https://player.vimeo.com/video/1103463754?h=dbe6a4b2ae&background=1&autopause=0&app_id=58479';

const desvuLogoUrl = 'https://assets.cdn.filesafe.space/E3Rv5E7JpJH3jrDtAbaE/media/69f7db4dfdf2432ccfe46d61.png';

const meta = {
  title: 'Events & Experiences | Powered by Des Vu Experiences | Killerspots',
  description: 'Immersive events executed with precision. Conferences, experiential activations, incentive travel, and corporate buyouts — through our sister company Des Vu Experiences.',
  ogTitle: 'Events & Experiences — Immersive, Executed With Precision | Killerspots × Des Vu',
  ogDescription: 'Conferences, brand activations, incentive programs, and corporate buyouts — produced end-to-end by our sister company Des Vu Experiences. Cincinnati-based, operating globally.',
};

const trustPills = ['Cincinnati-Based, Global Reach', 'High-Stakes Conferences', 'Brand Activations'];

const eventCategories = [
  { title: 'Experiential Activations', body: 'Brand experiences that earn attention — pop-ups, immersive installations, launch events, and destination activations that audiences post about.' },
  { title: 'Conferences & Corporate Meetings', body: 'High-visibility business events — agendas, AV, keynote production, breakouts, and on-site flow that makes your audience feel like the most important room they\'ve been in this year.' },
  { title: 'Incentive & Brand Travel', body: 'Reward your top performers and clients with incentive trips and brand travel programs that build loyalty no spreadsheet ever did.' },
  { title: 'Corporate Buyouts & Brand Nights', body: 'Whole-venue takeovers, branded restaurant nights, and nightclub buyouts — turning a Killerspots venue partner into your private event for an evening.' },
];

const services = [
  { title: 'Strategy & Planning', body: 'Brief, budget, audience, and outcomes. We start with what success looks like, then engineer the event backwards from it.' },
  { title: 'Venue & Hotel Sourcing', body: 'Strategic venue selection and contract negotiation in any market. Cincinnati to Las Vegas to Lisbon — we know the rooms and the rates.' },
  { title: 'Production & AV', body: 'Stage, lighting, sound, video, scenic, and broadcast — produced through our in-house Killerspots production team and trusted partners.' },
  { title: 'Talent & Entertainment', body: 'Keynote speakers, hosts, DJs, live music, surprise-and-delight talent. Booking, contracts, riders, and on-site management.' },
  { title: 'On-Site Execution', body: 'Our team runs your event on the ground — from load-in through teardown. You stay focused on your guests; we run the run-of-show.' },
  { title: 'Post-Event Content', body: 'Recap reels, sizzle videos, photography, and social-cuts — captured live and turned around fast so the moment compounds online.' },
];

const faqs = [
  { q: 'Who is Des Vu Experiences?', a: 'Des Vu Experiences is our sister company — a full-service events agency for high-stakes conferences, experiential activations, and incentive programs. Cincinnati-based, operating globally, working across consumer brands, healthcare, technology, and leadership sectors.' },
  { q: 'What\'s the relationship between Killerspots and Des Vu?', a: 'Sister companies, shared leadership, complementary teams. Killerspots brings creative production (video, audio, graphics, broadcast). Des Vu brings event production, logistics, and on-site execution. When you hire one, you have access to both.' },
  { q: 'What size events do you produce?', a: '50-person executive offsites to 5,000+ attendee conferences. The right size is the one that achieves your business outcome — we right-size every program.' },
  { q: 'Do you produce events outside Cincinnati?', a: 'Yes. We operate globally. Past events have run across the U.S., Europe, and the Caribbean. Cincinnati is HQ, the world is the venue.' },
  { q: 'Can you handle complex stakeholder logistics?', a: 'Yes — that\'s actually the Des Vu wheelhouse. Multiple internal teams, vendors, venues, sponsors, and approvers. We operate as an extension of your team and provide clarity and execution control from early planning through on-site delivery.' },
  { q: 'Do you do corporate restaurant/bar/nightclub buyouts?', a: 'Yes. Whole-venue takeovers in Killerspots-network venues or anywhere your audience is. Branded décor, custom menus, talent, and the full run-of-show.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/industries/restaurants-bars-nightclubs/events#webpage', url: 'https://killerspots.com/industries/restaurants-bars-nightclubs/events', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Restaurants, Bars & Nightclubs', item: 'https://killerspots.com/industries/restaurants-bars-nightclubs' }, { '@type': 'ListItem', position: 3, name: 'Events', item: 'https://killerspots.com/industries/restaurants-bars-nightclubs/events' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <HeroVideo videoUrl={heroVideoUrl} videoTitle="Des Vu Experiences — Event Reel">
    <nav aria-label="Breadcrumb" class="text-xs text-white/70 uppercase tracking-[0.2em]"><a href="/industries/restaurants-bars-nightclubs" class="hover:text-white">Restaurants, Bars & Nightclubs</a><span class="mx-2">/</span><span class="text-white">Events</span></nav>
    <div class="max-w-5xl mt-6">
      <span class="eyebrow">Events & Experiences</span>
      <h1 id="hero-headline" class="hero-headline mt-5">Immersive experiences, <span class="text-brand-500">executed with precision.</span></h1>
      <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-white/90 max-w-4xl leading-snug">Conferences, brand activations, incentive programs, and corporate buyouts — produced end-to-end by our sister company Des Vu Experiences. Cincinnati-based, global reach.</p>
      <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Plan Your Event</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost magnetic">Call {businessInfo.phone}</a></div>
    </div>
  </HeroVideo>

  <!-- DES VU LOGO + EXPLAINER -->
  <section class="bg-deep">
    <div class="container-page py-16 md:py-20">
      <div class="grid md:grid-cols-12 gap-8 md:gap-12 items-center">
        <div class="md:col-span-4 flex md:justify-start justify-center" data-reveal>
          <img src={desvuLogoUrl} alt="Des Vu Experiences logo" loading="lazy" decoding="async" class="h-20 md:h-28 w-auto" />
        </div>
        <div class="md:col-span-8" data-reveal>
          <p class="text-xs uppercase tracking-[0.22em] text-brand-500 font-bold">Sister Company</p>
          <h2 class="mt-3 text-2xl md:text-3xl font-bold text-white leading-tight">Des Vu Experiences — built for events where expectations are high and details matter.</h2>
          <p class="mt-5 text-base md:text-lg text-muted leading-relaxed">
            Des Vu designs and delivers high-visibility corporate events across consumer brands, healthcare, technology, and leadership sectors. They specialize in managing complex logistics — multiple teams, vendors, venues, and stakeholders — and operate as an extension of your internal team from early planning through on-site delivery.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Produce</span><h2 class="section-headline mt-5">Categories of work.</h2></div><ul class="grid md:grid-cols-2 gap-5 md:gap-6">{eventCategories.map((c) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"><h3 class="text-lg md:text-xl font-semibold text-white">{c.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{c.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">Capabilities</span><h2 class="section-headline mt-5">End-to-end event production.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{services.map((s) => (<li data-reveal class="rounded-2xl border border-white/5 bg-canvas/60 p-7"><h3 class="text-lg font-semibold text-white">{s.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{s.body}</p></li>))}</ul></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Events questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-deep"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Plan Your Event</span><h2 class="section-headline mt-5">Tell us what you're producing. We'll build the plan.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call with the Des Vu team. We'll review your goals, your audience, your timeline, and your budget — and come back with a concept and approach.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Plan Your Event</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost magnetic">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
