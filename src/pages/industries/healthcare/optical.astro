---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HeroVideo from '../../../components/HeroVideo.astro';
import { businessInfo } from '../../../data/navigation';

const heroVideoUrl =
  'https://player.vimeo.com/video/1103463873?h=79a608cc56&background=1&autopause=0&app_id=58479';

const meta = {
  title: 'Optical & Vision Marketing | Eye Exams, Frames, Contacts | Killerspots',
  description: 'Marketing for independent and franchise optical practices. SEO, paid search, AI intake, and recall automation. Drive eye-exam bookings and frame/contact revenue.',
  ogTitle: 'Optical Marketing — Eye Exams, Frames, Contacts | Killerspots',
  ogDescription: 'SEO, paid search, AI intake, and recall automation for optical and vision practices. Booked-exam CPA reporting + frame/contact revenue tracking.',
};

const trustPills = ['Optical Practice Specialists', 'Insurance + Self-Pay Funnels', 'Recall Built-In'];

const painPoints = [
  { title: 'Vision Insurance Confuses Patients', body: 'VSP, EyeMed, Davis — patients don\'t know if they\'re covered until they call. AI intake bots can pre-qualify insurance and trigger booking — eliminating a major drop-off.' },
  { title: 'Frame Margins Beat Exam Margins', body: 'A $90 exam is fine. A $400 designer frame + lens upsell is the real revenue. We build campaigns and creative that drive eyewear traffic — not just exam volume.' },
  { title: 'Big-Box Optical + Online Disruptors', body: 'You\'re fighting LensCrafters/Pearle on volume and Warby Parker on price. We position around your differentiator — eye health expertise, designer brands, or local relationships.' },
  { title: 'Annual Recall Drives Lifetime Value', body: 'Annual exams = annual revenue. Most agencies don\'t run recall. We do — SMS + email sequences that bring patients back every 12 months for the next exam and frame replacement.' },
];

const services = [
  { title: 'Local SEO + AI Search', body: 'Rank for "eye doctor near me," "[insurance] eye exam," "designer frames [city]," and the long-tail terms that drive bookings.' },
  { title: 'Google Ads + Performance Max', body: 'Paid search and Performance Max campaigns managed for booked-exam CPA, with separate funnels for self-pay and insurance patients.' },
  { title: 'Frame + Contact Lens Marketing', body: 'Dedicated campaigns for premium frame brands, sunglasses, and contact lens subscriptions — driving the higher-margin product mix.' },
  { title: 'AI Intake (LeadConnector)', body: '24/7 AI bot that handles exam inquiries, pre-qualifies insurance, and books appointments — even after-hours.' },
  { title: 'Annual Recall + Reactivation', body: 'SMS + email sequences that bring patients back every 12 months and reactivate lapsed patients with personalized frame/exam offers.' },
  { title: 'Reviews + Reputation', body: 'Auto-request Google reviews after every visit. Local 4.9-star reputation drives both organic visits and walk-ins.' },
];

const faqs = [
  { q: 'Do you understand HIPAA and optical advertising rules?', a: 'Yes. HIPAA, FTC Endorsement Guides for testimonials, and state optometry/optician board rules. We\'ll ask for your state\'s rules on the discovery call.' },
  { q: 'Can you handle multi-location optical chains?', a: 'Yes. Location-specific landing pages, location-specific Google Business Profiles, and per-location attribution. Common for 2–50 location optical groups.' },
  { q: 'Do you market specific frame brands?', a: 'Yes — designer frame campaigns, brand-coop marketing where available, and exclusive-brand positioning for boutique optical. We respect brand standards while running local-market campaigns.' },
  { q: 'How do you measure success?', a: 'Booked exams + frame/contact revenue per visit. Eyewear margin is where the real revenue is — we report on both.' },
  { q: 'Can you handle insurance vs self-pay segmentation?', a: 'Yes. Different intent, different funnels. Insurance patients want verification fast; self-pay patients want pricing transparency. We build separate campaigns and intake flows for each.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/industries/healthcare/optical#webpage', url: 'https://killerspots.com/industries/healthcare/optical', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Healthcare', item: 'https://killerspots.com/industries/healthcare' }, { '@type': 'ListItem', position: 3, name: 'Optical', item: 'https://killerspots.com/industries/healthcare/optical' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <HeroVideo videoUrl={heroVideoUrl} videoTitle="Killerspots — Healthcare Reel">
    <nav aria-label="Breadcrumb" class="text-xs text-white/70 uppercase tracking-[0.2em]"><a href="/industries/healthcare" class="hover:text-white">Healthcare</a><span class="mx-2">/</span><span class="text-white">Optical</span></nav>
    <div class="max-w-5xl mt-6">
      <span class="eyebrow">Optical & Vision Marketing</span>
      <h1 id="hero-headline" class="hero-headline mt-5">Eye exams that book — <span class="text-brand-500">and frames that move.</span></h1>
      <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-white/90 max-w-4xl leading-snug">SEO, paid search, AI intake, and recall automation for independent and franchise optical practices. Insurance + self-pay funnels. Frame revenue tracked.</p>
      <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get an Optical Marketing Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost magnetic">Call {businessInfo.phone}</a></div>
    </div>
  </HeroVideo>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">Optical sits at the intersection of healthcare and retail. Most agencies pick one. We do both — exam-side marketing AND frame-revenue marketing.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">The Real Problems</span><h2 class="section-headline mt-5">Where optical marketing usually breaks.</h2></div><ul class="grid md:grid-cols-2 gap-5 md:gap-6">{painPoints.map((p) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"><h3 class="text-lg md:text-xl font-semibold text-white">{p.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{p.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Run</span><h2 class="section-headline mt-5">An optical channel mix tuned to exam + eyewear.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{services.map((s) => (<li data-reveal class="rounded-2xl border border-white/5 bg-canvas/60 p-7"><h3 class="text-lg font-semibold text-white">{s.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{s.body}</p></li>))}</ul></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Optical marketing questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-deep"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Drive Exam + Frame Revenue</span><h2 class="section-headline mt-5">Tell us your optical practice. We'll build the plan.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We'll review your exam volume, your frame mix, your insurance/self-pay split, and your current marketing.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost magnetic">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
