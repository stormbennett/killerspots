---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'White-Label Commercial Production for Radio Stations | Killerspots',
  description:
    'White-label radio and TV commercial production for stations and broadcasting groups. 2–3 day turnaround, professional voice talent, sound design — fully branded as your station\'s production team.',
  ogTitle: 'Your Station\'s Invisible Production Department | Killerspots',
  ogDescription:
    'Sales sells the spot. We produce it. Branded as your station. 2–3 day turnaround. Volume retainers, no per-project fees.',
};

const trustPills = ['Since 1999', '2–3 Day Turnaround', '6× Telly Award Winner'];

const features = [
  {
    title: 'Fully White-Labeled',
    body:
      'Spots delivered branded as your station\'s production team. Your advertisers never see Killerspots. Reports, deliverables, and portals all carry your station identity.',
  },
  {
    title: '2–3 Day Standard Turnaround',
    body:
      'Standard radio and TV spots produced and delivered in 2–3 business days. Same-day rush available. Your sales team can finally promise dates and hit them.',
  },
  {
    title: 'Professional Voice Talent',
    body:
      'Thousands of male and female voices, every age range, accent, and read style. Your producer picks the voice that fits the spot — no extra cost on standard tiers.',
  },
  {
    title: 'Custom Sound Design',
    body:
      'Music beds, SFX, ambiences, and final mixes built to broadcast standards. Spots that sound like a national agency made them — because effectively, one did.',
  },
  {
    title: 'Volume Retainers',
    body:
      'Monthly retainer covers a defined production volume — no per-project surcharges, no surprise invoices. Easy to budget, easy to scale.',
  },
  {
    title: 'Dedicated Account Producer',
    body:
      'One named producer who knows your station, your formats, and your sales team. Your reps brief them directly. No ticket queues, no swapped contacts.',
  },
];

const workflow = [
  {
    step: '01',
    title: 'Sales Sells the Spot',
    body:
      'Your rep closes the deal and submits a brief — copy, brand info, deadline — through your branded production portal.',
  },
  {
    step: '02',
    title: 'We Produce It',
    body:
      'Your dedicated producer scripts (if needed), casts the voice, builds the sound design, and mixes to broadcast spec.',
  },
  {
    step: '03',
    title: 'You Deliver',
    body:
      'Final files delivered to your traffic system in 2–3 business days. Branded as your station. Ready to air.',
  },
];

const faqs = [
  {
    q: 'How does the white-label part actually work?',
    a: 'Spots are delivered with your station branding only. Reporting portals, email communications, and producer credentials are all branded as your station. Your advertisers will never see the Killerspots name unless you choose to introduce us.',
  },
  {
    q: 'What format do you deliver in?',
    a: 'Whatever your traffic system needs — WAV, MP3, AIFF, broadcast video formats. We integrate with major traffic and trafficking platforms; if yours is exotic, just tell us and we\'ll match it.',
  },
  {
    q: 'Can we use our own voice talent or sound libraries?',
    a: 'Absolutely. Plenty of station partners have house voices and audio standards. We work to your style guide.',
  },
  {
    q: 'What if the advertiser wants revisions?',
    a: 'Standard tiers include revisions — typically up to two rounds. Most spots wrap in one. Heavy-revision custom work is quoted separately so volume retainers stay predictable.',
  },
  {
    q: 'Do you produce TV spots too?',
    a: 'Yes — TV commercials, OTT/CTV creative, social cutdowns, and voice-over for any video format. Many station partners use us for cross-media campaigns.',
  },
];

const speakable = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id':
    'https://killerspots.com/industries/radio-stations-groups/white-label-production#webpage',
  url: 'https://killerspots.com/industries/radio-stations-groups/white-label-production',
  name: meta.title,
  description: meta.description,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#hero-headline', '#hero-subhead'],
  },
  isPartOf: { '@id': 'https://killerspots.com/#localbusiness' },
};

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Radio Stations & Groups',
      item: 'https://killerspots.com/industries/radio-stations-groups',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'White-Label Production',
      item:
        'https://killerspots.com/industries/radio-stations-groups/white-label-production',
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  schema={[speakable, breadcrumbs, faqSchema]}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-canvas">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"
      >
      </div>
    </div>

    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]">
        <a href="/industries/radio-stations-groups" class="hover:text-white">
          Radio Stations &amp; Groups
        </a>
        <span class="mx-2">/</span>
        <span class="text-ink">White-Label Production</span>
      </nav>

      <div class="max-w-5xl mt-6">
        <span class="eyebrow">White-Label Production</span>
        <h1 id="hero-headline" class="hero-headline mt-5">
          Your sales team sells it.
          <span class="text-brand-500">We produce it. Branded as you.</span>
        </h1>
        <p
          id="hero-subhead"
          class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug"
        >
          Radio and TV commercial production for stations and broadcasting groups. 2–3 day
          turnaround, professional voice talent, broadcast-grade sound design — delivered
          fully branded as your station's in-house team.
        </p>

        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3">
          <a href="/contact" class="btn btn-primary">Get a Production Partnership Quote</a>
          <a href="#workflow" class="btn btn-ghost">See How It Works</a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAND -->
  <section class="bg-deep">
    <div class="container-page py-14 md:py-20">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="flex flex-wrap items-center gap-2.5">
          {trustPills.map((p) => <span class="trust-pill">{p}</span>)}
        </div>
        <p class="text-base md:text-lg text-muted leading-relaxed">
          We've produced thousands of spots for station partners across the U.S. — for
          local advertisers, regional brands, and national campaigns alike.
        </p>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">What You Get</span>
        <h2 class="section-headline mt-5">
          A full production department — without the headcount.
        </h2>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {
          features.map((f) => (
            <li
              data-reveal
              class="rounded-2xl border border-white/5 bg-deep/60 p-7 md:p-8"
            >
              <h3 class="text-lg font-semibold text-white">{f.title}</h3>
              <p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{f.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- WORKFLOW -->
  <section id="workflow" class="bg-deep">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">How It Works</span>
        <h2 class="section-headline mt-5">Three steps. Every spot. Every week.</h2>
      </div>

      <ol class="grid md:grid-cols-3 gap-5 md:gap-6">
        {
          workflow.map((s) => (
            <li
              data-reveal
              class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"
            >
              <div class="text-xs uppercase tracking-[0.22em] text-brand-500 font-bold">
                Step {s.step}
              </div>
              <h3 class="mt-3 text-xl font-semibold text-white">{s.title}</h3>
              <p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 max-w-3xl" data-reveal>
        <span class="eyebrow">FAQ</span>
        <h2 class="section-headline mt-5">Production partnership questions.</h2>
      </div>

      <div class="max-w-3xl space-y-3" data-reveal>
        {
          faqs.map((f) => (
            <details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5">
              <summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4">
                <span>{f.q}</span>
                <svg
                  class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M10 4v12M4 10h12"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                  />
                </svg>
              </summary>
              <p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden bg-deep">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div
        class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"
      >
      </div>
    </div>

    <div class="container-page py-24 md:py-32">
      <div class="max-w-3xl" data-reveal>
        <span class="eyebrow">Let's Talk Volume</span>
        <h2 class="section-headline mt-5">
          Tell us your spot volume. We'll size a partnership.
        </h2>
        <p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">
          30-minute partnership call. We'll walk through formats, monthly volume, and
          turnaround needs, then come back with a quote sized for your station or group.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary">Get a Quote</a>
          <a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">
            Call {businessInfo.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
