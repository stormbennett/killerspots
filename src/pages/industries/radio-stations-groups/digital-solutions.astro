---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Digital Solutions for Radio Stations | White-Label SEO, PPC & CTV | Killerspots',
  description:
    'White-label digital services your radio sales team can resell — SEO, PPC, websites, social, and CTV — branded as your station or group. New revenue stream. No new hires.',
  ogTitle: 'New Digital Revenue for Your Radio Station | Killerspots',
  ogDescription:
    'White-label SEO, PPC, websites, and CTV your sales reps can sell to local advertisers. We deliver behind the scenes. You keep the spread.',
};

const trustPills = ['Since 1999', 'White-Label Delivery', 'Built For Broadcasters'];

const services = [
  {
    title: 'SEO & Local Search',
    body:
      'Local SEO, Google Business Profile management, and content built to rank in your advertisers\' markets. Reports branded for your station, delivered monthly.',
  },
  {
    title: 'Google Ads & LSA',
    body:
      'Paid search and Local Service Ads managed for your advertisers. Campaign builds, optimization, and conversion tracking — branded as your station\'s digital team.',
  },
  {
    title: 'Meta & Social Ads',
    body:
      'Facebook and Instagram campaigns sized for local advertiser budgets. Creative, targeting, and weekly optimization handled end-to-end.',
  },
  {
    title: 'Websites & Landing Pages',
    body:
      'Fast, mobile-first sites and campaign landing pages. Built to capture leads and integrate with your station\'s ad campaigns and traffic systems.',
  },
  {
    title: 'CTV & Streaming',
    body:
      'Connected TV and OTT campaigns with full creative production and media buying. A natural extension for stations already producing video for traditional TV.',
  },
  {
    title: 'Programmatic Display & Video',
    body:
      'Geo-targeted display, video, and retargeting campaigns. Layer on top of your over-the-air buys for true cross-channel reach.',
  },
];

const benefits = [
  {
    title: 'New Revenue Stream',
    body:
      'Add high-margin digital services to your rate card without hiring a digital team. Every dollar you sell is incremental to your spot revenue.',
  },
  {
    title: 'You Set the Markup',
    body:
      'We give you wholesale rates. You set retail. Keep the spread. Most station partners run 40–70% margins on white-label digital.',
  },
  {
    title: 'Full Sales Enablement',
    body:
      'Branded rate cards, proposal templates, talk tracks, prospecting playbooks, and live deal support. Your reps don\'t need to be digital experts to sell digital.',
  },
  {
    title: 'Branded Reporting',
    body:
      'Client-facing dashboards and monthly reports branded as your station. We\'re invisible to your advertisers — every win belongs to your team.',
  },
];

const workflow = [
  {
    step: '01',
    title: 'Onboard Your Sales Team',
    body:
      'Sales training, branded collateral, talk tracks, and pricing. Your reps walk out ready to pitch on Monday morning.',
  },
  {
    step: '02',
    title: 'Sell + Hand Off the Brief',
    body:
      'Your rep closes the digital deal alongside the spot buy. They submit a brief through your branded partner portal. We pick it up.',
  },
  {
    step: '03',
    title: 'We Deliver, You Bill',
    body:
      'Campaigns built, launched, and optimized. Reports branded as your station. You bill the advertiser. We bill you wholesale.',
  },
];

const faqs = [
  {
    q: 'My reps don\'t know digital. How do they sell it?',
    a: 'They don\'t have to be experts. We provide sales training, talk tracks, prospecting playbooks, and live deal support — including joining sales calls when needed. Reps just need to know the customer; we handle the technical pitch.',
  },
  {
    q: 'How is pricing structured?',
    a: 'Wholesale rate card you mark up to retail. Most partners run 40–70% margins. Volume discounts kick in as your digital book of business grows. Get a quote and we\'ll walk you through the math.',
  },
  {
    q: 'Will you ever talk to my advertisers directly?',
    a: 'Only when you ask us to — and only as your station\'s digital team. White-label means white-label. Reports, dashboards, emails, calls — all branded as you.',
  },
  {
    q: 'How fast can we launch a campaign?',
    a: 'PPC campaigns can launch in a week. SEO is a 90-day ramp. Websites typically take 4–8 weeks depending on scope. We set timelines up front so your reps can promise dates that hold.',
  },
  {
    q: 'Do we have to sell every service?',
    a: 'No. Plenty of station partners start with just SEO and Google Ads, then add social, websites, and CTV as their book grows. Pick what fits your market and your reps.',
  },
];

const speakable = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id':
    'https://killerspots.com/industries/radio-stations-groups/digital-solutions#webpage',
  url: 'https://killerspots.com/industries/radio-stations-groups/digital-solutions',
  name: meta.title,
  description: meta.description,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#hero-headline', '#hero-subhead'],
  },
  isPartOf: { '@id': 'https://killerspots.com/#localbusiness' },
};

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Radio Stations & Groups',
      item: 'https://killerspots.com/industries/radio-stations-groups',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Digital Solutions',
      item: 'https://killerspots.com/industries/radio-stations-groups/digital-solutions',
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  schema={[speakable, breadcrumbs, faqSchema]}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-canvas">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"
      >
      </div>
    </div>

    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]">
        <a href="/industries/radio-stations-groups" class="hover:text-white">
          Radio Stations &amp; Groups
        </a>
        <span class="mx-2">/</span>
        <span class="text-ink">Digital Solutions</span>
      </nav>

      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Digital Solutions for Stations</span>
        <h1 id="hero-headline" class="hero-headline mt-5">
          Add a digital agency to your station —
          <span class="text-brand-500">without hiring one.</span>
        </h1>
        <p
          id="hero-subhead"
          class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug"
        >
          White-label SEO, PPC, websites, social, and CTV your sales team can resell to
          local advertisers. We deliver behind the scenes. You keep the relationship — and
          the margin.
        </p>

        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3">
          <a href="/contact" class="btn btn-primary">Get a Digital Partnership Quote</a>
          <a href="#how" class="btn btn-ghost">See How It Works</a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAND -->
  <section class="bg-deep">
    <div class="container-page py-14 md:py-20">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="flex flex-wrap items-center gap-2.5">
          {trustPills.map((p) => <span class="trust-pill">{p}</span>)}
        </div>
        <p class="text-base md:text-lg text-muted leading-relaxed">
          We run digital campaigns under station-partner brands across multiple markets.
          Your advertisers never see the Killerspots name unless you choose to introduce us.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">What Your Sales Team Can Sell</span>
        <h2 class="section-headline mt-5">
          A full digital agency stack — packaged for resale.
        </h2>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {
          services.map((s) => (
            <li
              data-reveal
              class="rounded-2xl border border-white/5 bg-deep/60 p-7 md:p-8"
            >
              <h3 class="text-lg font-semibold text-white">{s.title}</h3>
              <p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{s.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="bg-deep">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">Why It Works</span>
        <h2 class="section-headline mt-5">
          Built so your sales team wins — and your station keeps every dollar it should.
        </h2>
      </div>

      <ul class="grid md:grid-cols-2 gap-5 md:gap-6">
        {
          benefits.map((b) => (
            <li
              data-reveal
              class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"
            >
              <h3 class="text-lg md:text-xl font-semibold text-white">{b.title}</h3>
              <p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{b.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how" class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">How It Works</span>
        <h2 class="section-headline mt-5">
          Three steps from kickoff to live campaigns.
        </h2>
      </div>

      <ol class="grid md:grid-cols-3 gap-5 md:gap-6">
        {
          workflow.map((s) => (
            <li
              data-reveal
              class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"
            >
              <div class="text-xs uppercase tracking-[0.22em] text-brand-500 font-bold">
                Step {s.step}
              </div>
              <h3 class="mt-3 text-xl font-semibold text-white">{s.title}</h3>
              <p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-deep">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 max-w-3xl" data-reveal>
        <span class="eyebrow">FAQ</span>
        <h2 class="section-headline mt-5">Digital partnership questions.</h2>
      </div>

      <div class="max-w-3xl space-y-3" data-reveal>
        {
          faqs.map((f) => (
            <details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5">
              <summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4">
                <span>{f.q}</span>
                <svg
                  class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M10 4v12M4 10h12"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                  />
                </svg>
              </summary>
              <p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden bg-canvas">
    <div aria-hidden="true" class="absolute inset-0 -z-10">
      <div
        class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"
      >
      </div>
    </div>

    <div class="container-page py-24 md:py-32">
      <div class="max-w-3xl" data-reveal>
        <span class="eyebrow">Station Partnership</span>
        <h2 class="section-headline mt-5">
          Add digital revenue to your rate card. Let's talk margin.
        </h2>
        <p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">
          30-minute partnership call. Walk through your sales team, your markets, and what
          digital services would fit. We'll come back with a wholesale rate card and a
          launch plan.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary">Get a Quote</a>
          <a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">
            Call {businessInfo.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
