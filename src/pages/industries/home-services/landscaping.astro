---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HeroVideo from '../../../components/HeroVideo.astro';
import { businessInfo } from '../../../data/navigation';

const heroVideoUrl =
  'https://player.vimeo.com/video/1103463904?h=b2a0dd1642&background=1&autopause=0&app_id=58479';

const meta = {
  title: 'Landscaping Marketing | Lawn Care, Hardscape, Snow Contracts | Killerspots',
  description: 'Landscaping marketing built for seasonal demand cycles — spring rush, summer maintenance, fall cleanup, and winter snow contracts. SEO, paid social, and AI-powered follow-up.',
  ogTitle: 'Landscaping Marketing — Year-Round Revenue From Seasonal Demand | Killerspots',
  ogDescription: 'SEO, paid social, jingles, and 24/7 AI lead capture for landscapers. Maintenance plan campaigns. Snow contract recruiting. Real CPL reporting.',
};

const trustPills = ['Landscaping Specialists', 'Seasonal Strategy', '24/7 Lead Capture'];

const painPoints = [
  { title: 'Seasonal Demand Kills Cash Flow', body: 'Spring rush hits and you can\'t hire fast enough. November comes and revenue drops 70%. We level the curve with maintenance plan campaigns, snow contracts, and off-season offers.' },
  { title: 'Hardscape Margins vs. Mowing Margins', body: 'A patio install pays 20× a lawn cut. Different campaigns, different intent, different landing pages. Most landscapers blend them and bleed margin.' },
  { title: 'You Need Crews, Not Just Customers', body: 'Half the marketing problem is recruiting. We run dedicated hiring campaigns alongside customer acquisition.' },
  { title: 'Reviews Are the Whole Game', body: 'Customers Google "landscaper near me" and look at the stars. We auto-request reviews after every job and respond to negatives in real time.' },
];

const services = [
  { title: 'Local SEO + AI Search', body: 'Rank for "landscaper near me," "lawn care [city]," "hardscape contractor," "snow removal" — all by season.' },
  { title: 'Google LSA + Ads', body: 'Local Service Ads with active dispute management plus paid search for terms LSA doesn\'t cover.' },
  { title: 'Maintenance Plan Campaigns', body: 'High-leverage email + SMS sequences that convert one-time customers into recurring revenue. Levels seasonal cash flow.' },
  { title: 'Snow Contract Marketing', body: 'Off-season hardscape and snow contract acquisition campaigns. Keep crews busy and revenue flowing year-round.' },
  { title: 'Recruiting Campaigns', body: 'Dedicated hiring campaigns on Indeed, Meta, and local job boards. Most agencies don\'t do this — we do, because the trades need it.' },
  { title: 'AI Lead Capture (LeadConnector)', body: '24/7 AI bot qualifies maintenance vs install jobs, books estimates, texts back missed calls.' },
];

const faqs = [
  { q: 'What\'s a realistic CPL for landscaping?', a: 'Typically $35–$100 per qualified lead in mid-size markets. Maintenance accounts run lower CPL, hardscape installs run higher. We benchmark by category.' },
  { q: 'Do you market hardscape installs separately?', a: 'Yes. Hardscape ($5K–$50K projects) needs different messaging, landing pages, and longer follow-up sequences than recurring lawn care.' },
  { q: 'Can you help with snow contract acquisition?', a: 'Yes. Off-season contract acquisition campaigns starting August/September, targeting commercial and residential properties looking for winter coverage.' },
  { q: 'Do you do recruiting marketing too?', a: 'Yes — half the trades problem is hiring. Dedicated campaigns on Indeed, Meta, and local job boards. Same agency, same reporting, no extra vendor.' },
  { q: 'Can you handle multi-location landscapers?', a: 'Yes. Single-crew operations up to multi-location regional players. Per-location attribution, location-specific GBPs, and dedicated landing pages.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/industries/home-services/landscaping#webpage', url: 'https://killerspots.com/industries/home-services/landscaping', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Home Services', item: 'https://killerspots.com/industries/home-services' }, { '@type': 'ListItem', position: 3, name: 'Landscaping', item: 'https://killerspots.com/industries/home-services/landscaping' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <HeroVideo videoUrl={heroVideoUrl} videoTitle="Killerspots — Home Services Reel">
    <nav aria-label="Breadcrumb" class="text-xs text-white/70 uppercase tracking-[0.2em]"><a href="/industries/home-services" class="hover:text-white">Home Services</a><span class="mx-2">/</span><span class="text-white">Landscaping</span></nav>
    <div class="max-w-5xl mt-6">
      <span class="eyebrow">Landscaping Marketing</span>
      <h1 id="hero-headline" class="hero-headline mt-5">Year-round revenue <span class="text-brand-500">from seasonal demand.</span></h1>
      <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-white/90 max-w-4xl leading-snug">SEO, Google LSA, maintenance plan campaigns, snow contract acquisition, and AI lead capture for landscapers. Recruiting campaigns included.</p>
      <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Landscaping Marketing Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost magnetic">Call {businessInfo.phone}</a></div>
    </div>
  </HeroVideo>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">25+ years in the trades. We've run landscaping campaigns through every season cycle.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">The Real Problems</span><h2 class="section-headline mt-5">Marketing built for the way landscaping actually runs.</h2></div><ul class="grid md:grid-cols-2 gap-5 md:gap-6">{painPoints.map((p) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"><h3 class="text-lg md:text-xl font-semibold text-white">{p.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{p.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Run</span><h2 class="section-headline mt-5">A landscaping channel mix that compounds.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{services.map((s) => (<li data-reveal class="rounded-2xl border border-white/5 bg-canvas/60 p-7"><h3 class="text-lg font-semibold text-white">{s.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{s.body}</p></li>))}</ul></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Landscaping marketing questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-deep"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Level Your Cash Flow</span><h2 class="section-headline mt-5">Tell us your service area. We'll build the seasonal plan.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We'll map your seasons, review your CPL, and propose a year-round channel mix.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
