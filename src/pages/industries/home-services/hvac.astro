---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'HVAC Marketing | SEO, LSA & Lead Generation | Killerspots',
  description:
    'HVAC marketing built for the realities of the trade — emergency calls, seasonal demand, LSA disputes, and brand recall. SEO, Google LSA, jingles, and AI-powered follow-up.',
  ogTitle: 'HVAC Marketing That Actually Books Trucks | Killerspots',
  ogDescription:
    'Marketing for HVAC contractors that brings qualified service calls — not vanity traffic. SEO, LSA, paid social, jingles, and 24/7 AI lead capture.',
};

const trustPills = ['HVAC Specialists', 'Active LSA Management', '24/7 Lead Capture'];

const painPoints = [
  { title: 'Summer Brings the Calls — Then It Dies', body: 'Cooling season hits and your phones explode. October comes and revenue drops 60%. We level the curve with maintenance plan campaigns, fall heating push, and indoor air quality offers.' },
  { title: 'LSA Charges You For Bad Leads', body: 'Wrong number, out of service area, "just looking" — Google charges you anyway. We dispute every bad lead and get most of them refunded. Most agencies don\'t bother.' },
  { title: 'Emergency Calls Go to Whoever Answers First', body: 'Pipe burst, AC out in July — the homeowner calls the first three names that come up. We make sure you\'re one of them via SEO, LSA, and missed-call text-back.' },
  { title: 'Big Box Buyers Are Eating the Market', body: 'Private equity rolling up local HVAC. The way you survive is brand recognition + repeat customers + reviews. All things we build.' },
];

const services = [
  { title: 'Local SEO + AI Search', body: 'Rank in maps, AI overviews, and organic for "HVAC near me," "AC repair [city]," "furnace replacement [zip]," and the long-tail terms that convert.' },
  { title: 'Google LSA + Ads', body: 'Local Service Ads with active dispute management, plus paid search for high-intent terms LSA doesn\'t cover.' },
  { title: 'Custom Jingles + Radio', body: 'A jingle that becomes the sound of HVAC in your market. Pair with smart radio buys for top-of-mind recall.' },
  { title: 'CTV Streaming Ads', body: 'TV-quality spots running on Hulu, YouTube TV, Roku — geo-targeted to neighborhoods you actually serve.' },
  { title: 'Social Media + Reviews', body: 'Daily content, paid Meta, and automated review requests after every service call.' },
  { title: 'AI Lead Capture (LeadConnector)', body: 'AI bot answers FAQs at 3 AM, qualifies emergencies, and books service appointments. Missed calls auto-text back. Lead never goes cold.' },
];

const faqs = [
  { q: 'What\'s a realistic CPL for HVAC?', a: 'Depends on your market and channel mix, but typically $40–$120 per qualified lead in mid-size markets. We benchmark you against trade averages and report real CPL by channel monthly.' },
  { q: 'Can you handle multi-truck operations?', a: 'Yes. Single-truck shops up to 50+ truck regional players. Multi-location HVAC gets location-specific landing pages, location-specific GBPs, and per-location attribution.' },
  { q: 'Do you do maintenance plan marketing?', a: 'Yes — that\'s a high-leverage channel for HVAC. Email + SMS sequences, paid social retargeting, and direct mail for existing customer reactivation. Maintenance plans flatten your seasonal revenue curve.' },
  { q: 'How do you handle LSA disputes?', a: 'We monitor every lead Google charges you for. Wrong number, out of service area, junk, or non-HVAC inquiry → we file the dispute. Most clients get 20–40% of LSA spend back in disputed-lead credits.' },
  { q: 'Do you work with HVAC franchises?', a: 'Both at the franchisor and franchisee level. We\'ve helped franchisees outrank corporate listings without violating brand standards.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/industries/home-services/hvac#webpage', url: 'https://killerspots.com/industries/home-services/hvac', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Home Services', item: 'https://killerspots.com/industries/home-services' }, { '@type': 'ListItem', position: 3, name: 'HVAC', item: 'https://killerspots.com/industries/home-services/hvac' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas">
    <div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]">
        <a href="/industries/home-services" class="hover:text-white">Home Services</a><span class="mx-2">/</span><span class="text-ink">HVAC</span>
      </nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">HVAC Marketing</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Marketing built for <span class="text-brand-500">cooling season chaos and shoulder-season survival.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">SEO, Google LSA, paid social, jingles, CTV, and 24/7 AI lead capture — engineered for HVAC realities. Active LSA dispute management included.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3">
          <a href="/contact" class="btn btn-primary magnetic">Get an HVAC Marketing Quote</a>
          <a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-deep">
    <div class="container-page py-12 md:py-16">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div>
        <p class="text-base md:text-lg text-muted leading-relaxed">We've run HVAC marketing through PE rollups, fuel-price spikes, summer heat domes, and four LSA category overhauls. We know the trade.</p>
      </div>
    </div>
  </section>

  <section class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">The Real Problems</span>
        <h2 class="section-headline mt-5">Built for the way HVAC actually runs.</h2>
      </div>
      <ul class="grid md:grid-cols-2 gap-5 md:gap-6">
        {painPoints.map((p) => (
          <li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8">
            <h3 class="text-lg md:text-xl font-semibold text-white">{p.title}</h3>
            <p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{p.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-deep">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 md:mb-20 max-w-3xl" data-reveal>
        <span class="eyebrow">What We Run</span>
        <h2 class="section-headline mt-5">An HVAC channel mix that compounds.</h2>
      </div>
      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {services.map((s) => (
          <li data-reveal class="rounded-2xl border border-white/5 bg-canvas/60 p-7">
            <h3 class="text-lg font-semibold text-white">{s.title}</h3>
            <p class="mt-3 text-sm text-muted leading-relaxed">{s.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-canvas">
    <div class="container-page py-24 md:py-32">
      <div class="mb-14 max-w-3xl" data-reveal>
        <span class="eyebrow">FAQ</span>
        <h2 class="section-headline mt-5">HVAC marketing questions.</h2>
      </div>
      <div class="max-w-3xl space-y-3" data-reveal>
        {faqs.map((f) => (
          <details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5">
            <summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4">
              <span>{f.q}</span>
              <svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg>
            </summary>
            <p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-deep">
    <div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div>
    <div class="container-page py-24 md:py-32">
      <div class="max-w-3xl" data-reveal>
        <span class="eyebrow">Get the Phones Ringing</span>
        <h2 class="section-headline mt-5">Tell us your service area. We'll build the plan.</h2>
        <p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We'll review your CPL, your competition, and your current marketing spend, then come back with a recommendation.</p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary magnetic">Get a Quote</a>
          <a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
