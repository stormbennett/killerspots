---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Roofing Marketing | Storm Lead, Insurance Claims, Replacement | Killerspots',
  description: 'Roofing marketing built for residential and commercial roofers. SEO, Google LSA, paid social, storm-lead campaigns, and AI-powered follow-up. Storm-chaser-resistant.',
  ogTitle: 'Roofing Marketing That Wins on Quality, Not Door Knocks | Killerspots',
  ogDescription: 'SEO, LSA, paid social, jingles, and 24/7 AI lead capture for roofers. Outrank storm chasers with brand authority and review velocity.',
};

const trustPills = ['Roofing Specialists', 'Storm-Lead Ready', '24/7 Lead Capture'];

const painPoints = [
  { title: 'Storm Chasers Flood Your Market', body: 'Out-of-state crews door-knock for two weeks after a hailstorm and disappear. We help local roofers win on brand authority, reviews, and faster digital response.' },
  { title: 'Insurance Claims Are Half Your Job', body: 'Marketing has to translate "I think I have damage" into a qualified inspection. Landing pages, AI bot scripts, and follow-up sequences handle the insurance conversation.' },
  { title: 'Residential vs Commercial Mix', body: 'Different decision-makers, different sales cycles, different ad creative. We segment campaigns so you\'re not paying residential rates for commercial leads.' },
  { title: 'Reviews Are the Whole Game', body: 'Roofing buyers are scared. They Google reviews before they call anyone. We automate review requests after every job and dispute fake negatives.' },
];

const services = [
  { title: 'Local SEO + AI Search', body: 'Rank for "roofer near me," "roof replacement [city]," "storm damage roofer," and the long-tail terms that close.' },
  { title: 'Google LSA + Ads', body: 'LSA with active dispute management plus paid search for terms LSA doesn\'t cover (commercial, specific roof types).' },
  { title: 'Storm-Response Campaigns', body: 'Geo-targeted ads activated within hours of major storm events. Be there when homeowners start searching for damage assessment.' },
  { title: 'CTV + YouTube Ads', body: 'Brand-building video that establishes authority — homeowners need to trust you before they let you on their roof.' },
  { title: 'Reviews + Reputation', body: 'Auto-request Google reviews after every project. Respond fast to negatives. Compound that 4.9-star rating into search dominance.' },
  { title: 'AI Lead Capture (LeadConnector)', body: '24/7 AI bot qualifies inspection requests, books estimates, and texts back missed calls. Lead never goes cold.' },
];

const faqs = [
  { q: 'How do you compete with storm chasers?', a: 'Storm chasers win on speed and door-knocking. You win on reviews, local trust, and being the first result when the homeowner Googles. We build that compounding asset over 6–12 months.' },
  { q: 'Can you handle insurance restoration roofing?', a: 'Yes. Insurance restoration has different messaging — we build dedicated landing pages, AI bot scripts that triage claim status, and follow-up sequences that handle the carrier conversation.' },
  { q: 'Do you do commercial roofing too?', a: 'Yes. Commercial uses different channels — LinkedIn, targeted display, and content marketing — alongside search. We segment campaigns and report separately.' },
  { q: 'What\'s a realistic CPL for roofing?', a: 'Typically $80–$250 per qualified inspection request in mid-size markets. Storm seasons drop CPL dramatically. We benchmark and report monthly.' },
  { q: 'How fast will I see leads?', a: 'LSA and Google Ads can drive inspection requests in 1–2 weeks. SEO compounds over 90–180 days. Brand-building (CTV, YouTube) shows up in lead quality and close rate over 6 months.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/industries/home-services/roofing#webpage', url: 'https://killerspots.com/industries/home-services/roofing', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Home Services', item: 'https://killerspots.com/industries/home-services' }, { '@type': 'ListItem', position: 3, name: 'Roofing', item: 'https://killerspots.com/industries/home-services/roofing' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/industries/home-services" class="hover:text-white">Home Services</a><span class="mx-2">/</span><span class="text-ink">Roofing</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Roofing Marketing</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Win on reviews and authority — <span class="text-brand-500">not door knocks.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">SEO, Google LSA, paid social, storm-response campaigns, and AI lead capture for residential and commercial roofers. Storm-chaser-resistant by design.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Roofing Marketing Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">25+ years in the trades. We've run roofing campaigns through hailstorms, insurance changes, and PE rollups.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">The Real Problems</span><h2 class="section-headline mt-5">Marketing built for the way roofing actually runs.</h2></div><ul class="grid md:grid-cols-2 gap-5 md:gap-6">{painPoints.map((p) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"><h3 class="text-lg md:text-xl font-semibold text-white">{p.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{p.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Run</span><h2 class="section-headline mt-5">A roofing channel mix that compounds.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{services.map((s) => (<li data-reveal class="rounded-2xl border border-white/5 bg-canvas/60 p-7"><h3 class="text-lg font-semibold text-white">{s.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{s.body}</p></li>))}</ul></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Roofing marketing questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-deep"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Out-Compete Storm Chasers</span><h2 class="section-headline mt-5">Tell us your market. We'll build the plan.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. Review your CPL, your competition, your storm response capability, and your current marketing.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
