---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { businessInfo } from '../../../data/navigation';

const meta = {
  title: 'Pool & Spa Marketing | Build, Service, Retail | Killerspots',
  description: 'Pool & spa marketing for builders, service companies, and retail showrooms. SEO, Google LSA, paid social, and AI-powered follow-up — sized for a high-ticket seasonal business.',
  ogTitle: 'Pool & Spa Marketing — Full-Funnel for a Seasonal Business | Killerspots',
  ogDescription: 'SEO, LSA, paid social, jingles, and AI lead capture for pool builders, service companies, and retail. Real CPL reporting, real seasonal strategy.',
};

const trustPills = ['Pool & Spa Specialists', 'Seasonal Strategy', '24/7 Lead Capture'];

const painPoints = [
  { title: 'New Build Sales Cycles Are Long', body: 'A $80K pool build takes 3–9 months from first inquiry to close. Marketing has to nurture, not just capture. We build long-form sequences that hold attention.' },
  { title: 'Service Calls vs. New Builds', body: 'Different buyers, different intent, different ROI. We segment campaigns so service revenue and build pipeline both grow without bleeding into each other.' },
  { title: 'Spring/Summer Is Brutal', body: 'May–August: phones explode. November–February: tumbleweeds. We level the curve with off-season service campaigns and pre-season build promotions.' },
  { title: 'Retail Foot Traffic Needs Local Search', body: 'If you have a showroom, "pool store near me" is the highest-intent search you can rank for. We optimize GBPs, store landing pages, and inventory feeds.' },
];

const services = [
  { title: 'Local SEO + AI Search', body: 'Rank for "pool builder [city]," "spa repair," "pool store near me" — separate campaigns by service type.' },
  { title: 'Google LSA + Ads', body: 'Local Service Ads where eligible plus paid search for high-ticket new-build terms.' },
  { title: 'Long-Form Nurture Sequences', body: 'Email + SMS sequences that hold attention through 3–9 month build cycles. Drip campaigns, design inspiration, and milestone follow-ups.' },
  { title: 'CTV + Streaming Ads', body: 'Premium video targeting affluent neighborhoods. Build brand authority for high-ticket purchases.' },
  { title: 'Reviews + Reputation', body: 'Auto-request reviews after every service call and build. Pool buyers obsess over reviews — make yours dominant.' },
  { title: 'AI Lead Capture (LeadConnector)', body: '24/7 AI bot qualifies service vs build, books showroom visits, texts back missed calls.' },
];

const faqs = [
  { q: 'Do you handle high-ticket pool builds?', a: 'Yes — that\'s where most of the margin is. Long-form nurture sequences, dedicated landing pages per build type, and retargeting campaigns hold attention through the multi-month sales cycle.' },
  { q: 'Can you market both builds and service?', a: 'Yes — and we segment carefully. Service campaigns target homeowners with existing pools (different intent, different keywords). Build campaigns target prospective buyers.' },
  { q: 'What about retail showrooms?', a: 'Local SEO + GBP optimization + inventory feeds + targeted Meta ads to drive foot traffic. We\'ve helped pool retailers double showroom visits in the spring rush.' },
  { q: 'How do we keep crews busy off-season?', a: 'Service marketing campaigns starting October, hot tub installs (less seasonal), and pre-spring build promotions. Off-season is where margin lives.' },
  { q: 'What\'s a realistic CPL for pool & spa?', a: 'Service: $60–$150 per qualified lead. New builds: $200–$600 per qualified inspection request (high-ticket justifies higher CPL). We benchmark and report monthly.' },
];

const speakable = { '@context': 'https://schema.org', '@type': 'WebPage', '@id': 'https://killerspots.com/industries/home-services/pool-spa#webpage', url: 'https://killerspots.com/industries/home-services/pool-spa', name: meta.title, description: meta.description, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#hero-headline', '#hero-subhead'] }, isPartOf: { '@id': 'https://killerspots.com/#localbusiness' } };
const breadcrumbs = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://killerspots.com/' }, { '@type': 'ListItem', position: 2, name: 'Home Services', item: 'https://killerspots.com/industries/home-services' }, { '@type': 'ListItem', position: 3, name: 'Pool & Spa', item: 'https://killerspots.com/industries/home-services/pool-spa' }] };
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription} schema={[speakable, breadcrumbs, faqSchema]}>
  <section class="relative overflow-hidden bg-canvas"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-10%,_rgba(239,82,83,0.18)_0%,_rgba(15,20,25,0)_55%)]"></div></div>
    <div class="container-page pt-24 md:pt-32 lg:pt-40 pb-20 md:pb-28">
      <nav aria-label="Breadcrumb" class="text-xs text-muted uppercase tracking-[0.2em]"><a href="/industries/home-services" class="hover:text-white">Home Services</a><span class="mx-2">/</span><span class="text-ink">Pool & Spa</span></nav>
      <div class="max-w-5xl mt-6">
        <span class="eyebrow">Pool &amp; Spa Marketing</span>
        <h1 id="hero-headline" class="hero-headline mt-5">Full-funnel marketing — <span class="text-brand-500">build, service, and retail.</span></h1>
        <p id="hero-subhead" class="mt-8 md:mt-10 text-xl md:text-2xl text-ink max-w-4xl leading-snug">SEO, Google LSA, paid social, long-form nurture, CTV, and AI lead capture for pool builders, service companies, and retail showrooms.</p>
        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Pool & Spa Marketing Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div>
      </div>
    </div>
  </section>

  <section class="bg-deep"><div class="container-page py-12 md:py-16"><div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center"><div class="flex flex-wrap items-center gap-2.5">{trustPills.map((p) => <span class="trust-pill">{p}</span>)}</div><p class="text-base md:text-lg text-muted leading-relaxed">25+ years in the trades. Pool & spa is a high-ticket seasonal business — we've built campaigns through every cycle.</p></div></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">The Real Problems</span><h2 class="section-headline mt-5">Marketing built for the way pool & spa actually runs.</h2></div><ul class="grid md:grid-cols-2 gap-5 md:gap-6">{painPoints.map((p) => (<li data-reveal class="rounded-2xl border border-white/10 bg-surface p-7 md:p-8"><h3 class="text-lg md:text-xl font-semibold text-white">{p.title}</h3><p class="mt-3 text-sm md:text-base text-muted leading-relaxed">{p.body}</p></li>))}</ul></div></section>

  <section class="bg-deep"><div class="container-page py-24 md:py-32"><div class="mb-14 md:mb-20 max-w-3xl" data-reveal><span class="eyebrow">What We Run</span><h2 class="section-headline mt-5">A pool & spa channel mix that compounds.</h2></div><ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">{services.map((s) => (<li data-reveal class="rounded-2xl border border-white/5 bg-canvas/60 p-7"><h3 class="text-lg font-semibold text-white">{s.title}</h3><p class="mt-3 text-sm text-muted leading-relaxed">{s.body}</p></li>))}</ul></div></section>

  <section class="bg-canvas"><div class="container-page py-24 md:py-32"><div class="mb-14 max-w-3xl" data-reveal><span class="eyebrow">FAQ</span><h2 class="section-headline mt-5">Pool & spa marketing questions.</h2></div><div class="max-w-3xl space-y-3" data-reveal>{faqs.map((f) => (<details class="group rounded-2xl border border-white/10 bg-surface px-6 py-5"><summary class="cursor-pointer list-none text-base md:text-lg font-semibold text-white flex items-start justify-between gap-4"><span>{f.q}</span><svg class="h-5 w-5 shrink-0 mt-1 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" /></svg></summary><p class="mt-4 text-sm md:text-base text-muted leading-relaxed">{f.a}</p></details>))}</div></div></section>

  <section class="relative overflow-hidden bg-deep"><div aria-hidden="true" class="absolute inset-0 -z-10"><div class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-brand-500/15 blur-[160px]"></div></div><div class="container-page py-24 md:py-32"><div class="max-w-3xl" data-reveal><span class="eyebrow">Build the Pipeline</span><h2 class="section-headline mt-5">Tell us your business mix. We'll build the plan.</h2><p class="mt-6 text-lg md:text-xl text-ink leading-relaxed">30-minute call. We'll review your build/service/retail mix, your seasons, and your current CPL.</p><div class="mt-10 flex flex-wrap gap-3"><a href="/contact" class="btn btn-primary magnetic">Get a Quote</a><a href={`tel:${businessInfo.phoneTel}`} class="btn btn-ghost">Call {businessInfo.phone}</a></div></div></div></section>
</BaseLayout>
